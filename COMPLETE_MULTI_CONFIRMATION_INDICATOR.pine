tf7_mid_color = input.color(color.new(#FF69B4, 50), '', inline = 'TF7M', group = g_TF)

var g_ALERT = 'CRT Alert Options'
alert_on_m15 = input.bool(false, 'Alert on M15 touch', group = g_ALERT)
alert_on_h1 = input.bool(false, 'Alert on H1 touch', group = g_ALERT)
alert_on_h2 = input.bool(false, 'Alert on H2 touch', group = g_ALERT)
alert_on_h4 = input.bool(false, 'Alert on H4 touch', group = g_ALERT)
alert_on_daily = input.bool(false, 'Alert on Daily touch', group = g_ALERT)
alert_on_weekly = input.bool(false, 'Alert on Weekly touch', group = g_ALERT)
alert_on_monthly = input.bool(false, 'Alert on Monthly touch', group = g_ALERT)

var g_OPT = 'CRT Options'
minbars = input.int(1, 'Minimum Bars', group = g_OPT)
maxbars = input.int(250, 'Maximum Bars', group = g_OPT)
hllinewidth = input.int(2, 'High/Low Line Width', group = g_OPT)
midlinewidth = input.int(1, 'Mid Line Width', group = g_OPT)

var g_LABEL = 'CRT Label Options'
bullishLabelStyle = input.string('Label Up', 'Bullish Label Style', options = ['None', 'Label Up', 'Label Down', 'Label Left', 'Label Right', 'Label Center', 'Triangle Up', 'Triangle Down', 'Triangle Left', 'Triangle Right', 'Flag', 'Circle', 'Square', 'Diamond', 'Cross', 'X-Cross', 'Arrow Up', 'Arrow Down'], group = g_LABEL)
bearishLabelStyle = input.string('Label Down', 'Bearish Label Style', options = ['None', 'Label Up', 'Label Down', 'Label Left', 'Label Right', 'Label Center', 'Triangle Up', 'Triangle Down', 'Triangle Left', 'Triangle Right', 'Flag', 'Circle', 'Square', 'Diamond', 'Cross', 'X-Cross', 'Arrow Up', 'Arrow Down'], group = g_LABEL)
labelSize = input.string('Small', 'Label Size', options = ['Auto', 'Tiny', 'Small', 'Normal', 'Large', 'Huge'], group = g_LABEL)

bullishBgColor = input.color(color.new(color.green, 50), 'Bullish Background Color', group = g_LABEL)
bullishTextColor = input.color(color.green, 'Bullish Text Color', group = g_LABEL)
bearishBgColor = input.color(color.new(color.red, 50), 'Bearish Background Color', group = g_LABEL)
bearishTextColor = input.color(color.red, 'Bearish Text Color', group = g_LABEL)

show_m15_labels = input.bool(true, 'Show M15 Labels', group = g_LABEL)
show_h1_labels = input.bool(true, 'Show H1 Labels', group = g_LABEL)
show_h2_labels = input.bool(true, 'Show H2 Labels', group = g_LABEL)
show_h4_labels = input.bool(true, 'Show H4 Labels', group = g_LABEL)
show_daily_labels = input.bool(true, 'Show Daily Labels', group = g_LABEL)
show_weekly_labels = input.bool(true, 'Show Weekly Labels', group = g_LABEL)
show_monthly_labels = input.bool(true, 'Show Monthly Labels', group = g_LABEL)
max_labels = input.int(50, 'Maximum number of labels to show', minval = 1, maxval = 500, group = g_LABEL)
show_eol_labels = input.bool(true, 'Show End-of-Line Labels', group = g_LABEL)
eol_label_offset = input.int(5, 'End-of-Line Label Offset', minval = 1, maxval = 50, group = g_LABEL)

var g_TOUCH = 'CRT Touch Options'
use_wick_touch = input.bool(true, 'Use Wick Touch', group = g_TOUCH)
use_body_touch = input.bool(true, 'Use Body Touch', group = g_TOUCH)

// Original process_tf function (UNCHANGED)
process_tf(tf) =>
    var float rangeHigh = na
    var float rangeLow = na
    var float rangeMid = na
    var int rangeStart = 0
    var bool inConsolidation = true
    var bool bullishTouch = false
    var bool bearishTouch = false

    [tfOpen, tfHigh, tfLow, tfClose, tfTime] = request.security(syminfo.tickerid, tf, [open, high, low, close, time], barmerge.gaps_off, barmerge.lookahead_on)

    newBar = ta.change(tfTime) != 0

    tfUp = tfHigh
    tfDown = tfLow
    tfChildUp = tfOpen > tfClose ? tfOpen : tfClose
    tfChildDown = tfOpen > tfClose ? tfClose : tfOpen

    if newBar
        upControl = tfChildUp > rangeHigh and bar_index - rangeStart > minbars and bar_index - rangeStart <= maxbars
        downControl = tfChildDown < rangeLow and bar_index - rangeStart > minbars and bar_index - rangeStart <= maxbars

        if upControl or downControl
            inConsolidation := false

        if inConsolidation and tfChildDown <= rangeHigh and tfChildDown >= rangeLow and tfChildUp <= rangeHigh and tfChildUp >= rangeLow and bar_index > 1
            rangeStart := rangeStart
        else
            rangeHigh := tfHigh
            rangeLow := tfLow
            rangeStart := bar_index
            inConsolidation := true
 
        if not inConsolidation and (bar_index - rangeStart > maxbars or bar_index - rangeStart < minbars)
            inConsolidation := true

        rangeMid := (rangeHigh + rangeLow) / 2
        bullishTouch := false
        bearishTouch := false

    if inConsolidation
        bullishWickTouch = low < rangeLow and close > rangeLow and high < rangeHigh
        bullishBodyTouch = open < rangeLow and close > rangeLow
        bearishWickTouch = high > rangeHigh and close < rangeHigh and low > rangeLow
        bearishBodyTouch = open > rangeHigh and close < rangeHigh

        bullishTouch := use_wick_touch and bullishWickTouch or use_body_touch and bullishBodyTouch
        bearishTouch := use_wick_touch and bearishWickTouch or use_body_touch and bearishBodyTouch

    [rangeHigh, rangeLow, rangeMid, rangeStart, inConsolidation, newBar, bullishTouch, bearishTouch]

// Process data for each timeframe
[high1, low1, mid1, start1, inRange1, newBar1, bullishTouch1, bearishTouch1] = process_tf(tf1)
[high2, low2, mid2, start2, inRange2, newBar2, bullishTouch2, bearishTouch2] = process_tf(tf2)
[high3, low3, mid3, start3, inRange3, newBar3, bullishTouch3, bearishTouch3] = process_tf(tf3)
[high4, low4, mid4, start4, inRange4, newBar4, bullishTouch4, bearishTouch4] = process_tf(tf4)
[high5, low5, mid5, start5, inRange5, newBar5, bullishTouch5, bearishTouch5] = process_tf(tf5)
[high6, low6, mid6, start6, inRange6, newBar6, bullishTouch6, bearishTouch6] = process_tf(tf6)
[high7, low7, mid7, start7, inRange7, newBar7, bullishTouch7, bearishTouch7] = process_tf(tf7)

// Original plot_lines function (UNCHANGED)
plot_lines(tfColor, midColor, high, low, mid, start, inRange, newBar, useMid, bullishTouch, bearishTouch, tfName) =>
    var line highLine = na
    var line lowLine = na
    var line midLine = na

    if newBar and inRange
        if not na(highLine)
            line.delete(highLine)
            line.delete(lowLine)
            line.delete(midLine)

        validStart = math.max(start, 0)
        highLine := line.new(validStart, high, bar_index, high, color = tfColor, width = hllinewidth)
        lowLine := line.new(validStart, low, bar_index, low, color = tfColor, width = hllinewidth)
        if useMid
            midLine := line.new(validStart, mid, bar_index, mid, color = midColor, width = midlinewidth, style = line.style_dashed)

        if show_eol_labels
            label.new(bar_index + eol_label_offset, high, text = tfName + ' CRT High', color = color.new(tfColor, 70), textcolor = tfColor, style = label.style_none, size = size.small)
            label.new(bar_index + eol_label_offset, low, text = tfName + ' CRT Low', color = color.new(tfColor, 70), textcolor = tfColor, style = label.style_none, size = size.small)

    if not na(highLine) and inRange
        line.set_x2(highLine, bar_index)
        line.set_x2(lowLine, bar_index)
        if useMid and not na(midLine)
            line.set_x2(midLine, bar_index)

    [bullishTouch, bearishTouch]

// Plot lines for each timeframe (UNCHANGED)
if use_tf1
    [bullishTouch1, bearishTouch1] = plot_lines(tf1_color, tf1_mid_color, high1, low1, mid1, start1, inRange1, newBar1, use_tf1_mid, bullishTouch1, bearishTouch1, 'M15')
if use_tf2
    [bullishTouch2, bearishTouch2] = plot_lines(tf2_color, tf2_mid_color, high2, low2, mid2, start2, inRange2, newBar2, use_tf2_mid, bullishTouch2, bearishTouch2, 'H1')
if use_tf3
    [bullishTouch3, bearishTouch3] = plot_lines(tf3_color, tf3_mid_color, high3, low3, mid3, start3, inRange3, newBar3, use_tf3_mid, bullishTouch3, bearishTouch3, 'H2')
if use_tf4
    [bullishTouch4, bearishTouch4] = plot_lines(tf4_color, tf4_mid_color, high4, low4, mid4, start4, inRange4, newBar4, use_tf4_mid, bullishTouch4, bearishTouch4, 'H4')
if use_tf5
    [bullishTouch5, bearishTouch5] = plot_lines(tf5_color, tf5_mid_color, high5, low5, mid5, start5, inRange5, newBar5, use_tf5_mid, bullishTouch5, bearishTouch5, 'D')
if use_tf6
    [bullishTouch6, bearishTouch6] = plot_lines(tf6_color, tf6_mid_color, high6, low6, mid6, start6, inRange6, newBar6, use_tf6_mid, bullishTouch6, bearishTouch6, 'W')
if use_tf7
    [bullishTouch7, bearishTouch7] = plot_lines(tf7_color, tf7_mid_color, high7, low7, mid7, start7, inRange7, newBar7, use_tf7_mid, bullishTouch7, bearishTouch7, 'M')

// Function to convert string input to label style (UNCHANGED)
getLabelStyle(styleString) =>
    switch styleString
        'None' => label.style_none
        'Label Up' => label.style_label_up
        'Label Down' => label.style_label_down
        'Label Left' => label.style_label_left
        'Label Right' => label.style_label_right
        'Label Center' => label.style_label_center
        'Triangle Up' => label.style_triangleup
        'Triangle Down' => label.style_triangledown
        'Flag' => label.style_flag
        'Circle' => label.style_circle
        'Square' => label.style_square
        'Diamond' => label.style_diamond
        'Cross' => label.style_cross
        'X-Cross' => label.style_xcross
        'Arrow Up' => label.style_arrowup
        'Arrow Down' => label.style_arrowdown
        => label.style_label_up // default

// Function to convert string input to size (UNCHANGED)
getLabelSize(sizeString) =>
    switch sizeString
        'Auto' => size.auto
        'Tiny' => size.tiny
        'Small' => size.small
        'Normal' => size.normal
        'Large' => size.large
        'Huge' => size.huge
        => size.auto // default

// Enhanced label management with multi-confirmation filtering
manageLabelCount(labelText, y, bgColor, textColor, style, size) =>
    if array.size(labels) >= max_labels
        label.delete(array.shift(labels))
    newLabel = label.new(bar_index, y, labelText, color = bgColor, textcolor = textColor, style = style, size = size)
    array.push(labels, newLabel)

// ENHANCED function with MULTI-CONFIRMATION SYSTEM (NO EMA DEPENDENCY) - SYNTAX FIXED
checkAndCreateLabel(show, bullishTouch, bearishTouch, tfText) =>
    // Check volume condition if enabled
    volume_ok = not enable_volume_filter or (volume > volume_avg * volume_multiplier)
    
    if show and bullishTouch and volume_ok
        // For bullish CRT signals, check multi-confirmation consensus
        if trend_aligned_signal(true)
            // ENHANCED: Multi-confirmation status (not EMA-dependent)
            string trend_status = ""
            if true_bullish_reversal
                trend_status := "🔄REV[" + str.tostring(bull_votes) + "v]"  // Multi-confirmed reversal
            else if bullish_continuation
                trend_status := "➡️CONT[" + str.tostring(bull_votes) + "v]"  // Multi-confirmed continuation
            else if new_bullish_trend
                trend_status := "🚀NEW[" + str.tostring(bull_votes) + "v]"  // Multi-confirmed new trend
            else if strong_bullish_trend
                trend_status := "💪STR[" + str.tostring(bull_votes) + "v]"  // Multi-confirmed strong trend
            else if bullish_trend
                trend_status := "📈BULL[" + str.tostring(bull_votes) + "v]" // Multi-confirmed bullish
            else
                trend_status := "⚠️[" + str.tostring(bull_votes) + "v" + str.tostring(bear_votes) + "]"  // Weak/conflicting signals
            
            enhanced_label = 'BUY-' + tfText + trend_status
            manageLabelCount(enhanced_label, low, bullishBgColor, bullishTextColor, getLabelStyle(bullishLabelStyle), getLabelSize(labelSize))
    
    if show and bearishTouch and volume_ok
        // For bearish CRT signals, check multi-confirmation consensus
        if trend_aligned_signal(false)
            // ENHANCED: Multi-confirmation status (not EMA-dependent)
            string trend_status = ""
            if true_bearish_reversal
                trend_status := "🔄REV[" + str.tostring(bear_votes) + "v]"  // Multi-confirmed reversal
            else if bearish_continuation
                trend_status := "➡️CONT[" + str.tostring(bear_votes) + "v]"  // Multi-confirmed continuation
            else if new_bearish_trend
                trend_status := "🚀NEW[" + str.tostring(bear_votes) + "v]"  // Multi-confirmed new trend
            else if strong_bearish_trend
                trend_status := "💪STR[" + str.tostring(bear_votes) + "v]"  // Multi-confirmed strong trend
            else if bearish_trend
                trend_status := "📉BEAR[" + str.tostring(bear_votes) + "v]" // Multi-confirmed bearish
            else
                trend_status := "⚠️[" + str.tostring(bear_votes) + "v" + str.tostring(bull_votes) + "]"  // Weak/conflicting signals
            
            enhanced_label = 'SELL-' + tfText + trend_status
            manageLabelCount(enhanced_label, high, bearishBgColor, bearishTextColor, getLabelStyle(bearishLabelStyle), getLabelSize(labelSize))

// Apply ENHANCED labels for each timeframe
checkAndCreateLabel(show_m15_labels, bullishTouch1, bearishTouch1, 'M15')
checkAndCreateLabel(show_h1_labels, bullishTouch2, bearishTouch2, 'H1')
checkAndCreateLabel(show_h2_labels, bullishTouch3, bearishTouch3, 'H2')
checkAndCreateLabel(show_h4_labels, bullishTouch4, bearishTouch4, 'H4')
checkAndCreateLabel(show_daily_labels, bullishTouch5, bearishTouch5, 'D')
checkAndCreateLabel(show_weekly_labels, bullishTouch6, bearishTouch6, 'W')
checkAndCreateLabel(show_monthly_labels, bullishTouch7, bearishTouch7, 'M')

//==============================================================================
// ENHANCED TREND STATUS DISPLAY WITH MULTI-CONFIRMATION (NO EMA DEPENDENCY)
//==============================================================================

// Show current trend status on chart with multi-confirmation system
var label trend_label = na
if barstate.islast
    if not na(trend_label)
        label.delete(trend_label)
    
    trend_text = ""
    trend_color = color.gray
    
    if true_bullish_reversal
        trend_text := "🔄 MULTI-CONFIRMED BULLISH REVERSAL [" + str.tostring(bull_votes) + " votes]"
        trend_color := color.new(color.lime, 0)
    else if true_bearish_reversal
        trend_text := "🔄 MULTI-CONFIRMED BEARISH REVERSAL [" + str.tostring(bear_votes) + " votes]"
        trend_color := color.new(color.red, 0)
    else if bullish_continuation
        trend_text := "➡️ BULLISH CONTINUATION [" + str.tostring(bull_votes) + " votes]"
        trend_color := color.new(color.green, 20)
    else if bearish_continuation
        trend_text := "➡️ BEARISH CONTINUATION [" + str.tostring(bear_votes) + " votes]"
        trend_color := color.new(color.red, 20)
    else if new_bullish_trend
        trend_text := "🚀 NEW BULLISH TREND [" + str.tostring(bull_votes) + " votes]"
        trend_color := color.new(color.lime, 0)
    else if new_bearish_trend
        trend_text := "🚀 NEW BEARISH TREND [" + str.tostring(bear_votes) + " votes]"
        trend_color := color.new(color.red, 0)
    else if strong_bullish_trend
        trend_text := "💪 STRONG BULLISH CONSENSUS [" + str.tostring(bull_votes) + " votes]"
        trend_color := color.new(color.lime, 20)
    else if strong_bearish_trend
        trend_text := "💪 STRONG BEARISH CONSENSUS [" + str.tostring(bear_votes) + " votes]"
        trend_color := color.new(color.red, 20)
    else if bullish_trend
        trend_text := "📈 BULLISH CONSENSUS [" + str.tostring(bull_votes) + " votes]"
        trend_color := color.new(color.green, 30)
    else if bearish_trend
        trend_text := "📉 BEARISH CONSENSUS [" + str.tostring(bear_votes) + " votes]"
        trend_color := color.new(color.red, 30)
    else
        trend_text := "⚠️ NO CONSENSUS [" + str.tostring(bull_votes) + "v" + str.tostring(bear_votes) + "]"
        trend_color := color.new(color.yellow, 30)
    
    trend_label := label.new(bar_index, high + ta.atr(14), text=trend_text, style=label.style_label_down, color=trend_color, textcolor=color.white, size=size.normal)

//==============================================================================
// MULTI-CONFIRMATION ANALYSIS DASHBOARD (NEW)
//==============================================================================

var g_MULTI_DASHBOARD = "🎯 Multi-Confirmation Dashboard"
show_multi_dashboard = input.bool(true, "Show Multi-Confirmation Dashboard", group=g_MULTI_DASHBOARD)

if show_multi_dashboard and barstate.islast
    var table multi_table = table.new(position.top_right, 4, 8, bgcolor=color.new(color.black, 85), border_width=1)
    
    // Header
    table.cell(multi_table, 0, 0, "🎯 MULTI-CONFIRMATION", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 70))
    table.cell(multi_table, 1, 0, "BULLISH", text_color=color.lime, text_size=size.normal, bgcolor=color.new(color.blue, 70))
    table.cell(multi_table, 2, 0, "BEARISH", text_color=color.red, text_size=size.normal, bgcolor=color.new(color.blue, 70))
    table.cell(multi_table, 3, 0, "STATUS", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 70))
    
    // RSI Analysis
    table.cell(multi_table, 0, 1, "⚡ RSI", text_color=color.white, text_size=size.small)
    rsi_bull_text = (rsi_bullish or rsi_oversold_bounce) ? "✅" : "❌"
    rsi_bear_text = (rsi_bearish or rsi_overbought_drop) ? "✅" : "❌"
    rsi_status = rsi > 70 ? "OB" : rsi < 30 ? "OS" : "MID"
    table.cell(multi_table, 1, 1, rsi_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 1, rsi_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 1, rsi_status, text_color=color.white, text_size=size.small)
    
    // MACD Analysis
    table.cell(multi_table, 0, 2, "📈 MACD", text_color=color.white, text_size=size.small)
    macd_bull_text = (macd_bullish or macd_bullish_cross) ? "✅" : "❌"
    macd_bear_text = (macd_bearish or macd_bearish_cross) ? "✅" : "❌"
    macd_status = macd_line > signal_line ? "+" : "-"
    table.cell(multi_table, 1, 2, macd_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 2, macd_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 2, macd_status, text_color=color.white, text_size=size.small)
    
    // Market Structure Analysis
    table.cell(multi_table, 0, 3, "🏗️ Structure", text_color=color.white, text_size=size.small)
    struct_bull_text = (structure_bullish or resistance_break) ? "✅" : "❌"
    struct_bear_text = (structure_bearish or support_break) ? "✅" : "❌"
    struct_status = str.tostring(bull_structure_score) + ":" + str.tostring(bear_structure_score)
    table.cell(multi_table, 1, 3, struct_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 3, struct_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 3, struct_status, text_color=color.white, text_size=size.small)
    
    // Volume Profile Analysis
    table.cell(multi_table, 0, 4, "📊 Volume", text_color=color.white, text_size=size.small)
    vol_bull_text = volume_bullish ? "✅" : "❌"
    vol_bear_text = volume_bearish ? "✅" : "❌"
    vol_status = obv_bull ? "OBV+" : obv_bear ? "OBV-" : "OBV="
    table.cell(multi_table, 1, 4, vol_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 4, vol_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 4, vol_status, text_color=color.white, text_size=size.small)
    
    // Momentum Divergence Analysis
    table.cell(multi_table, 0, 5, "⚡ Momentum", text_color=color.white, text_size=size.small)
    mom_bull_text = (momentum_bullish or bullish_divergence) ? "✅" : "❌"
    mom_bear_text = (momentum_bearish or bearish_divergence) ? "✅" : "❌"
    mom_status = bullish_divergence ? "DIV+" : bearish_divergence ? "DIV-" : "SYNC"
    table.cell(multi_table, 1, 5, mom_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 5, mom_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 5, mom_status, text_color=color.white, text_size=size.small)
    
    // HTF Price Action Analysis
    table.cell(multi_table, 0, 6, "📐 HTF Action", text_color=color.white, text_size=size.small)
    htf_bull_text = (daily_uptrend and weekly_uptrend) ? "✅" : "❌"
    htf_bear_text = (daily_downtrend and weekly_downtrend) ? "✅" : "❌"
    htf_status = str.tostring(daily_bull_count) + "D:" + str.tostring(daily_bear_count)
    table.cell(multi_table, 1, 6, htf_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 6, htf_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 6, htf_status, text_color=color.white, text_size=size.small)
    
    // Final Consensus
    table.cell(multi_table, 0, 7, "🎯 CONSENSUS", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.purple, 70))
    table.cell(multi_table, 1, 7, str.tostring(bull_votes), text_color=color.lime, text_size=size.normal, bgcolor=color.new(color.purple, 70))
    table.cell(multi_table, 2, 7, str.tostring(bear_votes), text_color=color.red, text_size=size.normal, bgcolor=color.new(color.purple, 70))
    table.cell(multi_table, 3, 7, str.tostring(trend_strength) + "%", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.purple, 70))

// NOTE: The remaining sections (Advanced FVG, CISD, CRT Time Analysis, HTF Candles) 
