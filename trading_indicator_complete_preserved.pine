bearishTouch4 = array.get(tf_results_4, 7)

tf_results_5 = process_tf(tf5)
high5 = array.get(tf_results_5, 0)
low5 = array.get(tf_results_5, 1)
mid5 = array.get(tf_results_5, 2)
start5 = array.get(tf_results_5, 3)
inRange5 = array.get(tf_results_5, 4)
newBar5 = array.get(tf_results_5, 5)
