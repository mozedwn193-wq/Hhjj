newBar3 = array.get(tf_results_3, 5)
bullishTouch3 = array.get(tf_results_3, 6)
bearishTouch3 = array.get(tf_results_3, 7)

tf_results_4 = process_tf(tf4)
high4 = array.get(tf_results_4, 0)
low4 = array.get(tf_results_4, 1)
