// Modified plot_lines function (UNCHANGED)
plot_lines(tfColor, midColor, high, low, mid, start, inRange, newBar, useMid, bullishTouch, bearishTouch, tfName) =>
    var line highLine = na
    var line lowLine = na
    var line midLine = na
    var label highLabel = na
    var label lowLabel = na

    if newBar and inRange
        if not na(highLine)
            line.delete(highLine)
            line.delete(lowLine)
            line.delete(midLine)
        if not na(highLabel)
            label.delete(highLabel)
            label.delete(lowLabel)

        validStart = math.max(start, 0)
        highLine := line.new(validStart, high, bar_index, high, color = tfColor, width = hllinewidth)
        lowLine := line.new(validStart, low, bar_index, low, color = tfColor, width = hllinewidth)
        if useMid
            midLine := line.new(validStart, mid, bar_index, mid, color = midColor, width = midlinewidth, style = line.style_dashed)

        if show_eol_labels
            highLabel := label.new(bar_index + eol_label_offset, high, text = tfName + ' CRT High', color = color.new(tfColor, 70), textcolor = tfColor, style = label.style_none, size = size.small)
            lowLabel := label.new(bar_index + eol_label_offset, low, text = tfName + ' CRT Low', color = color.new(tfColor, 70), textcolor = tfColor, style = label.style_none, size = size.small)

    if not na(highLine) and inRange
        line.set_x2(highLine, bar_index)
        line.set_x2(lowLine, bar_index)
        if useMid and not na(midLine)
            line.set_x2(midLine, bar_index)

        if show_eol_labels
            label.set_x(highLabel, bar_index + eol_label_offset)
            label.set_y(highLabel, high)
            label.set_x(lowLabel, bar_index + eol_label_offset)
            label.set_y(lowLabel, low)

    [bullishTouch, bearishTouch]

// Plot lines for each timeframe (UNCHANGED)
if use_tf1
    plot_result_1 = plot_lines(tf1_color, tf1_mid_color, high1, low1, mid1, start1, inRange1, newBar1, use_tf1_mid, bullishTouch1, bearishTouch1, 'M15')
    bullishTouch1 := array.get(plot_result_1, 0)
    bearishTouch1 := array.get(plot_result_1, 1)
if use_tf2
    plot_result_2 = plot_lines(tf2_color, tf2_mid_color, high2, low2, mid2, start2, inRange2, newBar2, use_tf2_mid, bullishTouch2, bearishTouch2, 'H1')
    bullishTouch2 := array.get(plot_result_2, 0)
    bearishTouch2 := array.get(plot_result_2, 1)
if use_tf3
    plot_result_3 = plot_lines(tf3_color, tf3_mid_color, high3, low3, mid3, start3, inRange3, newBar3, use_tf3_mid, bullishTouch3, bearishTouch3, 'H2')
    bullishTouch3 := array.get(plot_result_3, 0)
    bearishTouch3 := array.get(plot_result_3, 1)
if use_tf4
    plot_result_4 = plot_lines(tf4_color, tf4_mid_color, high4, low4, mid4, start4, inRange4, newBar4, use_tf4_mid, bullishTouch4, bearishTouch4, 'H4')
    bullishTouch4 := array.get(plot_result_4, 0)
    bearishTouch4 := array.get(plot_result_4, 1)
if use_tf5
    plot_result_5 = plot_lines(tf5_color, tf5_mid_color, high5, low5, mid5, start5, inRange5, newBar5, use_tf5_mid, bullishTouch5, bearishTouch5, 'D')
    bullishTouch5 := array.get(plot_result_5, 0)
    bearishTouch5 := array.get(plot_result_5, 1)
if use_tf6
    plot_result_6 = plot_lines(tf6_color, tf6_mid_color, high6, low6, mid6, start6, inRange6, newBar6, use_tf6_mid, bullishTouch6, bearishTouch6, 'W')
    bullishTouch6 := array.get(plot_result_6, 0)
    bearishTouch6 := array.get(plot_result_6, 1)
if use_tf7
    plot_result_7 = plot_lines(tf7_color, tf7_mid_color, high7, low7, mid7, start7, inRange7, newBar7, use_tf7_mid, bullishTouch7, bearishTouch7, 'M')
    bullishTouch7 := array.get(plot_result_7, 0)
    bearishTouch7 := array.get(plot_result_7, 1)

// Function to convert string input to label style (UNCHANGED)
getLabelStyle(styleString) =>
    switch styleString
        'None' => label.style_none
        'Label Up' => label.style_label_up
        'Label Down' => label.style_label_down
        'Label Left' => label.style_label_left
        'Label Right' => label.style_label_right
        'Label Center' => label.style_label_center
        'Triangle Up' => label.style_triangleup
        'Triangle Down' => label.style_triangledown
        'Flag' => label.style_flag
        'Circle' => label.style_circle
        'Square' => label.style_square
        'Diamond' => label.style_diamond
        'Cross' => label.style_cross
        'X-Cross' => label.style_xcross
        'Arrow Up' => label.style_arrowup
        'Arrow Down' => label.style_arrowdown
        => label.style_label_up // default

// Function to convert string input to size (UNCHANGED)
getLabelSize(sizeString) =>
    switch sizeString
        'Auto' => size.auto
        'Tiny' => size.tiny
        'Small' => size.small
        'Normal' => size.normal
        'Large' => size.large
        'Huge' => size.huge
        => size.auto // default

// Optimized label management (ENHANCED)
manageLabelCount(labelText, y, bgColor, textColor, style, size) =>
    if array.size(labels) >= max_labels
        label.delete(array.shift(labels))
    
    // Add enhancement indicator if enabled
    enhancement_suffix = enable_reliability_enhancement ? " ✅" : ""
    enhanced_text = labelText + enhancement_suffix
    
    newLabel = label.new(bar_index, y, enhanced_text, color = bgColor, textcolor = textColor, style = style, size = size)
    array.push(labels, newLabel)

// Function to check and create labels for a timeframe (ENHANCED)
checkAndCreateLabel(show, bullishTouch, bearishTouch, tfText) =>
    if show and bullishTouch
        manageLabelCount('BUY-' + tfText, low, bullishBgColor, bullishTextColor, getLabelStyle(bullishLabelStyle), getLabelSize(labelSize))
    if show and bearishTouch
        manageLabelCount('SELL-' + tfText, high, bearishBgColor, bearishTextColor, getLabelStyle(bearishLabelStyle), getLabelSize(labelSize))

// Apply labels for each timeframe (UNCHANGED)
checkAndCreateLabel(show_m15_labels, bullishTouch1, bearishTouch1, 'M15')
checkAndCreateLabel(show_h1_labels, bullishTouch2, bearishTouch2, 'H1')
checkAndCreateLabel(show_h2_labels, bullishTouch3, bearishTouch3, 'H2')
checkAndCreateLabel(show_h4_labels, bullishTouch4, bearishTouch4, 'H4')
checkAndCreateLabel(show_daily_labels, bullishTouch5, bearishTouch5, 'D')
checkAndCreateLabel(show_weekly_labels, bullishTouch6, bearishTouch6, 'W')
checkAndCreateLabel(show_monthly_labels, bullishTouch7, bearishTouch7, 'M')

// Alert conditions (ENHANCED)
if alert_on_m15 and (bullishTouch1 or bearishTouch1)
    enhancement_status = enable_reliability_enhancement ? " [ENHANCED]" : ""
    alert('M15 touch detected' + enhancement_status, alert.freq_once_per_bar_close)

if alert_on_h1 and (bullishTouch2 or bearishTouch2)
    enhancement_status = enable_reliability_enhancement ? " [ENHANCED]" : ""
    alert('H1 touch detected' + enhancement_status, alert.freq_once_per_bar_close)

if alert_on_h2 and (bullishTouch3 or bearishTouch3)
    enhancement_status = enable_reliability_enhancement ? " [ENHANCED]" : ""
    alert('H2 touch detected' + enhancement_status, alert.freq_once_per_bar_close)

if alert_on_h4 and (bullishTouch4 or bearishTouch4)
    enhancement_status = enable_reliability_enhancement ? " [ENHANCED]" : ""
    alert('H4 touch detected' + enhancement_status, alert.freq_once_per_bar_close)

if alert_on_daily and (bullishTouch5 or bearishTouch5)
    enhancement_status = enable_reliability_enhancement ? " [ENHANCED]" : ""
    alert('Daily touch detected' + enhancement_status, alert.freq_once_per_bar_close)

if alert_on_weekly and (bullishTouch6 or bearishTouch6)
    enhancement_status = enable_reliability_enhancement ? " [ENHANCED]" : ""
    alert('Weekly touch detected' + enhancement_status, alert.freq_once_per_bar_close)

if alert_on_monthly and (bullishTouch7 or bearishTouch7)
    enhancement_status = enable_reliability_enhancement ? " [ENHANCED]" : ""
    alert('Monthly touch detected' + enhancement_status, alert.freq_once_per_bar_close)

// Enhancement Status Display (ADDED)
var label enhancement_status_label = na
if barstate.islast and enable_reliability_enhancement
    if not na(enhancement_status_label)
        label.delete(enhancement_status_label)
    
    enhancement_status_label := label.new(bar_index, low - ta.atr(14), 
                                         text="✅ CRT RELIABILITY ENHANCED", 
                                         style=label.style_label_up, 
                                         color=color.new(color.lime, 20), 
                                         textcolor=color.white, 
                                         size=size.small)