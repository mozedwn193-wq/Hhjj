bearishTouch2 = array.get(tf_results_2, 7)

tf_results_3 = process_tf(tf3)
high3 = array.get(tf_results_3, 0)
low3 = array.get(tf_results_3, 1)
mid3 = array.get(tf_results_3, 2)
start3 = array.get(tf_results_3, 3)
