//@version=6
indicator('Comprehensive Trading Indicator - CRT + FVG + CISD + EMAs - ENHANCED', overlay = true, max_lines_count = 500, max_labels_count = 500, max_bars_back = 5000)

//==============================================================================
// SECTION 0: SIGNAL FILTERING SETTINGS (NEW)
//==============================================================================

var g_FILTER = "🔧 Signal Filtering"
enable_volume_filter = input.bool(true, "Enable Volume Filter", group=g_FILTER, tooltip="Only signals when volume is above average")
volume_multiplier = input.float(1.2, "Volume Multiplier", minval=0.5, maxval=3.0, step=0.1, group=g_FILTER)
enable_trend_filter = input.bool(true, "Enable Trend Alignment", group=g_FILTER, tooltip="Filter signals based on EMA trend")
enable_confirmation = input.bool(true, "Enable Signal Confirmation", group=g_FILTER, tooltip="Wait for next bar confirmation")
min_signal_strength = input.int(60, "Minimum Signal Strength (%)", minval=30, maxval=90, group=g_FILTER)

// Enhanced market analysis for filtering
volume_avg = ta.sma(volume, 20)
atr_value = ta.atr(14)

//==============================================================================
// SECTION 1: ENHANCED BREAKOUT DETECTION
//==============================================================================

// Inputs for Breakout Detection
length = input(14, "Lookback Length", group="Breakout Detection")
threshold = input(1.5, "Range Multiplier", group="Breakout Detection")

// Calculate candle range
candleRange = high - low
averageRange = ta.sma(candleRange, length)

// Enhanced conditions with filtering
volume_condition = not enable_volume_filter or volume > volume_avg * volume_multiplier
price_movement = math.abs(close - open) / open * 100

// Define enhanced conditions
bullish_base = candleRange > (averageRange * threshold) and close > open and price_movement > 0.3
bearish_base = candleRange > (averageRange * threshold) and close < open and price_movement > 0.3

// Apply filters
bullishBreakout = bullish_base and volume_condition
bearishBreakout = bearish_base and volume_condition

// Confirmation logic (NEW)
var bool bull_confirmed = false
var bool bear_confirmed = false

if enable_confirmation
    bull_confirmed := bullishBreakout and close[1] > open[1]
    bear_confirmed := bearishBreakout and close[1] < open[1]
else
    bull_confirmed := bullishBreakout
    bear_confirmed := bearishBreakout

// Plot signals
plotshape(series=bull_confirmed, location=location.belowbar, color=color.green, style=shape.labelup, title="Bullish Breakout")
plotshape(series=bear_confirmed, location=location.abovebar, color=color.red, style=shape.labeldown, title="Bearish Breakout")

// Highlight breakout candles
bgcolor(bull_confirmed ? color.new(color.green, 80) : bear_confirmed ? color.new(color.red, 80) : na)

//==============================================================================
// SECTION 2: ENHANCED EMA ANALYSIS
//==============================================================================

// EMAs
ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)
ema100 = ta.ema(close, 100)
ema200 = ta.ema(close, 200)

// Enhanced trend detection (NEW)
bullish_trend = ema20 > ema50 and ema50 > ema100 and ema100 > ema200
bearish_trend = ema20 < ema50 and ema50 < ema100 and ema100 < ema200
sideways_trend = not bullish_trend and not bearish_trend

// Dynamic Colors Based on Slope and Trend
color20 = bullish_trend ? color.lime : bearish_trend ? color.red : color.yellow
color50 = bullish_trend ? color.orange : bearish_trend ? color.maroon : color.gray
color100 = bullish_trend ? color.aqua : bearish_trend ? color.navy : color.silver
color200 = bullish_trend ? color.blue : bearish_trend ? color.purple : color.gray

// Plot EMAs
plot(ema20, title="EMA 20", color=color20, linewidth=1)
plot(ema50, title="EMA 50", color=color50, linewidth=1)
plot(ema100, title="EMA 100", color=color100, linewidth=1)
plot(ema200, title="EMA 200", color=color200, linewidth=1)

// Labels on latest bar
plotshape(bar_index == ta.highest(bar_index, 1) ? ema20 : na, location=location.absolute, style=shape.labelup, text="EMA 20", color=color.new(color20, 80), textcolor=color.white)
plotshape(bar_index == ta.highest(bar_index, 1) ? ema50 : na, location=location.absolute, style=shape.labelup, text="EMA 50", color=color.new(color50, 80), textcolor=color.white)
plotshape(bar_index == ta.highest(bar_index, 1) ? ema100 : na, location=location.absolute, style=shape.labelup, text="EMA 100", color=color.new(color100, 80), textcolor=color.white)
plotshape(bar_index == ta.highest(bar_index, 1) ? ema200 : na, location=location.absolute, style=shape.labelup, text="EMA 200", color=color.new(color200, 80), textcolor=color.white)

// Trend alignment function (NEW)
trend_aligned(signal_bullish) =>
    if not enable_trend_filter
        true
    else
        signal_bullish ? not bearish_trend : not bullish_trend

//==============================================================================
// SECTION 3: ENHANCED FVG DETECTION - SESSION BASED
//==============================================================================

// Define session times
sess = input.session("0932-1600", title="Session", tooltip="A 9:30 FVG can start at 9:30 but takes 3 candles to form, thus the 9:32 start time for the session. Adjust accordingly.", group="FVG Settings")
// User input for box color
boxColorUp = input.color(color.new(color.green, 80), "Box Color Up", group="FVG Settings")
boxColorDn = input.color(color.new(color.red, 80), "Box Color Down", group="FVG Settings")
max_days = input.int(3, title="Max # of days to draw", group="FVG Settings")
drawOpenTime = input.bool(true, title="Draw 9:30 NY open vertical line", group="FVG Settings")
drawOpenPrice = input.bool(true, title="Draw 9:30 opening price", group="FVG Settings")

// NEW: Minimum FVG size filter
min_fvg_size = input.float(0.5, "Minimum FVG Size (ATR %)", minval=0.1, maxval=2.0, step=0.1, group="FVG Settings")

//lines, boxes and labels
var timezone = "America/New_York"
var boxes = array.new_box()
var ny_open_labels = array.new_box()
var labels = array.new_label()
var ny_open_prices = array.new_line()
var ny_open_times = array.new_line()
var ny_930_labels = array.new_label()

var box ny_open_label = na
var box fvg_box = na
var line ny_open_time = na
var line ny_open_price = na
var label ny_930_label = na
var label fvg_lb = na
var bool first_fvg_found = false

boxColor = color.new(color.gray, 80)
is_target_time = (hour(time, timezone) == 8 and minute == 30) // CME servers in Chicago (CST). 9:30 EST = 8:30 CST
lowest_so_far = ta.lowest(50) - 5*ta.atr(14)

// Calculations
// Get day of week in text
day_of_week_text() =>
     dayofweek == dayofweek.monday    ? "Mon" :
     dayofweek == dayofweek.tuesday   ? "Tue" :
     dayofweek == dayofweek.wednesday ? "Wed" :
     dayofweek == dayofweek.thursday  ? "Thu" :
     dayofweek == dayofweek.friday    ? "Fri" :
     dayofweek == dayofweek.saturday  ? "Sat" :
     dayofweek == dayofweek.sunday    ? "Sun" : "N/A"

// Box creation with enhanced validation (UPDATED)
make_box(_left, _right, _top, _bottom, col) =>
    box.new(left=_left, right=_right, top=_top, bottom=_bottom, border_color=color.new(col, 70), bgcolor=col, text="Validated FVG - " + day_of_week_text(), text_halign = text.align_right, text_size=size.small, text_color = color.black)

// Function to validate FVG (NEW)
validate_fvg(fvg_size, is_bullish) =>
    // Size validation
    size_ok = fvg_size > atr_value * min_fvg_size / 100
    
    // Volume validation
    volume_ok = not enable_volume_filter or volume > volume_avg * volume_multiplier
    
    // Trend validation
    trend_ok = not enable_trend_filter or trend_aligned(is_bullish)
    
    size_ok and volume_ok and trend_ok

// Manage array of lines and labels
manage_lines(li_time, li_price, lb_price, lb_930) =>
    array.push(ny_open_times, li_time)
    array.push(ny_open_prices, li_price)
    array.push(ny_open_labels, lb_price)
    array.push(ny_930_labels, lb_930)
    if array.size(ny_open_times) > max_days
        line.delete(array.shift(ny_open_prices))
        line.delete(array.shift(ny_open_times))
        box.delete(array.shift(ny_open_labels))
        label.delete(array.shift(ny_930_labels))

// Manage array of boxes
manage_boxes(b) =>
    array.push(boxes, b)
    if array.size(boxes) > max_days
        box.delete(array.shift(boxes))

// Update FVG box
update_box(b) =>
    box.set_right(b, bar_index+10)

//@function calculates session valid times
in_session(sess) => not na(time(timeframe.period, sess, timezone))

// Enhanced Core Logic with validation (UPDATED)
if in_session(sess) 
    if not first_fvg_found
        // FVG condition
        fvgUp   = close[1] > open[1] and high[2] < low[0]
        fvgDown = close[1] < open[1] and low[2] > high[0]
        
        if fvgUp and validate_fvg(low[0] - high[2], true)
            first_fvg_found := true
            boxColor := boxColorUp
            // Define box coordinates
            boxTop      = high[2]
            boxBottom   = low[0]

            // Create the box
            fvg_box := make_box(bar_index-2, bar_index + 5, boxTop, boxBottom, boxColor)
            manage_boxes(fvg_box)
            
        else if fvgDown and validate_fvg(low[2] - high[0], false)
            first_fvg_found := true
            boxColor := boxColorDn
            // Define box coordinates
            boxTop      = low[2]
            boxBottom   = high[0]

            // Create the box
            fvg_box := make_box(bar_index-2, bar_index + 5, boxTop, boxBottom, boxColor)
            manage_boxes(fvg_box)

// Reset FVG flag at the end of the session
if not in_session(sess) and in_session(sess)[1]
    first_fvg_found := false

// Extend the box to session end
if first_fvg_found and na(fvg_box) == false
    update_box(fvg_box)

//Draw NY Open at 9:30 am EST / NY Time
if is_target_time
    if drawOpenTime
        ny_open_time    := line.new(x1=time, y1=high, x2=time, y2=low, xloc=xloc.bar_time, color=color.gray, style=line.style_dashed, width=1, extend = extend.both)
        ny_930_label    := label.new(x=bar_index, y=lowest_so_far, text="9:30", style=label.style_none, color=color.new(color.gray, 90), textcolor=color.black)
        manage_lines(ny_open_time, ny_open_price, ny_open_label, ny_930_label)
    if drawOpenPrice
        ny_open_price   := line.new(x1=bar_index, y1=open, x2=bar_index + 10, y2=open, xloc=xloc.bar_index, color=color.gray, style=line.style_dotted, width=1, extend = extend.none)
        ny_open_label   := box.new(left=bar_index+25, top=open+10, 
         right=ny_open_price.get_x2()+25, 
         bottom=open-10, 
         text = day_of_week_text() + " NY Open - " + str.format("{0,number,#,###.00}", close), 
         bgcolor=color.new(color.white, 100), 
         text_halign = text.align_right, 
         text_size = size.small, 
         text_color = color.black, 
         border_color = color.new(color.white, 50))
    
// Keep extended objects until end of the session
if in_session(sess)
    ny_open_label.set_right(bar_index + 55)
    ny_open_price.set_x2(bar_index + 20)

//==============================================================================
// SECTION 4: ENHANCED MULTI-TIMEFRAME CRT (CONSOLIDATION RANGE TOUCH)
//==============================================================================

// Explicitly set max_bars_back for key variables
max_bars_back(time, 5000)
max_bars_back(high, 5000)
max_bars_back(low, 5000)
max_bars_back(close, 5000)
max_bars_back(open, 5000)

// Inputs
var g_TF = 'CRT Timeframes'
use_tf1 = input.bool(true, '15 Minutes', inline = 'TF1', group = g_TF)
tf1 = input.timeframe('15', '', inline = 'TF1', group = g_TF)
tf1_color = input.color(color.new(#FF1493, 70), '', inline = 'TF1', group = g_TF)
use_tf1_mid = input.bool(true, '50% Level', inline = 'TF1M', group = g_TF)
tf1_mid_color = input.color(color.new(#FF1493, 50), '', inline = 'TF1M', group = g_TF)

use_tf2 = input.bool(true, '1 Hour', inline = 'TF2', group = g_TF)
tf2 = input.timeframe('60', '', inline = 'TF2', group = g_TF)
tf2_color = input.color(color.new(#FF4500, 70), '', inline = 'TF2', group = g_TF)
use_tf2_mid = input.bool(true, '50% Level', inline = 'TF2M', group = g_TF)
tf2_mid_color = input.color(color.new(#FF4500, 50), '', inline = 'TF2M', group = g_TF)

use_tf3 = input.bool(true, '2 Hours', inline = 'TF3', group = g_TF)
tf3 = input.timeframe('120', '', inline = 'TF3', group = g_TF)
tf3_color = input.color(color.new(#32CD32, 70), '', inline = 'TF3', group = g_TF)
use_tf3_mid = input.bool(true, '50% Level', inline = 'TF3M', group = g_TF)
tf3_mid_color = input.color(color.new(#32CD32, 50), '', inline = 'TF3M', group = g_TF)

use_tf4 = input.bool(true, '4 Hours', inline = 'TF4', group = g_TF)
tf4 = input.timeframe('240', '', inline = 'TF4', group = g_TF)
tf4_color = input.color(color.new(#1E90FF, 70), '', inline = 'TF4', group = g_TF)
use_tf4_mid = input.bool(true, '50% Level', inline = 'TF4M', group = g_TF)
tf4_mid_color = input.color(color.new(#1E90FF, 50), '', inline = 'TF4M', group = g_TF)

use_tf5 = input.bool(true, 'Daily', inline = 'TF5', group = g_TF)
tf5 = input.timeframe('D', '', inline = 'TF5', group = g_TF)
tf5_color = input.color(color.new(#9932CC, 70), '', inline = 'TF5', group = g_TF)
use_tf5_mid = input.bool(true, '50% Level', inline = 'TF5M', group = g_TF)
tf5_mid_color = input.color(color.new(#9932CC, 50), '', inline = 'TF5M', group = g_TF)

use_tf6 = input.bool(true, 'Weekly', inline = 'TF6', group = g_TF)
tf6 = input.timeframe('W', '', inline = 'TF6', group = g_TF)
tf6_color = input.color(color.new(#FFD700, 70), '', inline = 'TF6', group = g_TF)
use_tf6_mid = input.bool(true, '50% Level', inline = 'TF6M', group = g_TF)
tf6_mid_color = input.color(color.new(#FFD700, 50), '', inline = 'TF6M', group = g_TF)

use_tf7 = input.bool(true, 'Monthly', inline = 'TF7', group = g_TF)
tf7 = input.timeframe('M', '', inline = 'TF7', group = g_TF)
tf7_color = input.color(color.new(#FF69B4, 70), '', inline = 'TF7', group = g_TF)
use_tf7_mid = input.bool(true, '50% Level', inline = 'TF7M', group = g_TF)
tf7_mid_color = input.color(color.new(#FF69B4, 50), '', inline = 'TF7M', group = g_TF)

var g_ALERT = 'CRT Alert Options'
alert_on_m15 = input.bool(false, 'Alert on M15 touch', group = g_ALERT)
alert_on_h1 = input.bool(false, 'Alert on H1 touch', group = g_ALERT)
alert_on_h2 = input.bool(false, 'Alert on H2 touch', group = g_ALERT)
alert_on_h4 = input.bool(false, 'Alert on H4 touch', group = g_ALERT)
alert_on_daily = input.bool(false, 'Alert on Daily touch', group = g_ALERT)
alert_on_weekly = input.bool(false, 'Alert on Weekly touch', group = g_ALERT)
alert_on_monthly = input.bool(false, 'Alert on Monthly touch', group = g_ALERT)

var g_OPT = 'CRT Options'
minbars = input.int(1, 'Minimum Bars', group = g_OPT)
maxbars = input.int(250, 'Maximum Bars', group = g_OPT)
hllinewidth = input.int(2, 'High/Low Line Width', group = g_OPT)
midlinewidth = input.int(1, 'Mid Line Width', group = g_OPT)

var g_LABEL = 'CRT Label Options'
bullishLabelStyle = input.string('Label Up', 'Bullish Label Style', options = ['None', 'Label Up', 'Label Down', 'Label Left', 'Label Right', 'Label Center', 'Triangle Up', 'Triangle Down', 'Triangle Left', 'Triangle Right', 'Flag', 'Circle', 'Square', 'Diamond', 'Cross', 'X-Cross', 'Arrow Up', 'Arrow Down'], group = g_LABEL)
bearishLabelStyle = input.string('Label Down', 'Bearish Label Style', options = ['None', 'Label Up', 'Label Down', 'Label Left', 'Label Right', 'Label Center', 'Triangle Up', 'Triangle Down', 'Triangle Left', 'Triangle Right', 'Flag', 'Circle', 'Square', 'Diamond', 'Cross', 'X-Cross', 'Arrow Up', 'Arrow Down'], group = g_LABEL)
labelSize = input.string('Small', 'Label Size', options = ['Auto', 'Tiny', 'Small', 'Normal', 'Large', 'Huge'], group = g_LABEL)

bullishBgColor = input.color(color.new(color.green, 50), 'Bullish Background Color', group = g_LABEL)
bullishTextColor = input.color(color.green, 'Bullish Text Color', group = g_LABEL)
bearishBgColor = input.color(color.new(color.red, 50), 'Bearish Background Color', group = g_LABEL)
bearishTextColor = input.color(color.red, 'Bearish Text Color', group = g_LABEL)

show_m15_labels = input.bool(true, 'Show M15 Labels', group = g_LABEL)
show_h1_labels = input.bool(true, 'Show H1 Labels', group = g_LABEL)
show_h2_labels = input.bool(true, 'Show H2 Labels', group = g_LABEL)
show_h4_labels = input.bool(true, 'Show H4 Labels', group = g_LABEL)
show_daily_labels = input.bool(true, 'Show Daily Labels', group = g_LABEL)
show_weekly_labels = input.bool(true, 'Show Weekly Labels', group = g_LABEL)
show_monthly_labels = input.bool(true, 'Show Monthly Labels', group = g_LABEL)
max_labels = input.int(50, 'Maximum number of labels to show', minval = 1, maxval = 500, group = g_LABEL)
show_eol_labels = input.bool(true, 'Show End-of-Line Labels', group = g_LABEL)
eol_label_offset = input.int(5, 'End-of-Line Label Offset', minval = 1, maxval = 50, group = g_LABEL)

var g_TOUCH = 'CRT Touch Options'
use_wick_touch = input.bool(true, 'Use Wick Touch', group = g_TOUCH)
use_body_touch = input.bool(true, 'Use Body Touch', group = g_TOUCH)

// Enhanced signal strength calculation (NEW)
calculate_signal_strength(bullish_signal, bearish_signal) =>
    strength = 0.0
    
    // Volume component (30 points)
    vol_ratio = volume / volume_avg
    if vol_ratio > 1.8
        strength += 30
    else if vol_ratio > 1.4
        strength += 20
    else if vol_ratio > 1.1
        strength += 15
    else
        strength += 5
    
    // Trend alignment (25 points)
    if bullish_signal and bullish_trend
        strength += 25
    else if bearish_signal and bearish_trend
        strength += 25
    else if bullish_signal and not bearish_trend
        strength += 15
    else if bearish_signal and not bullish_trend
        strength += 15
    else
        strength += 5
        
    // Volatility component (25 points)
    atr_ratio = candleRange / atr_value
    if atr_ratio > 1.5
        strength += 25
    else if atr_ratio > 1.0
        strength += 15
    else
        strength += 5
        
    // Price action component (20 points)
    body_ratio = math.abs(close - open) / candleRange
    if body_ratio > 0.7
        strength += 20
    else if body_ratio > 0.5
        strength += 10
    else
        strength += 5
    
    math.round(strength)

// Enhanced process_tf function with signal filtering (UPDATED)
process_tf(tf) =>
    var float rangeHigh = na
    var float rangeLow = na
    var float rangeMid = na
    var int rangeStart = 0
    var bool inConsolidation = true
    var bool bullishTouch = false
    var bool bearishTouch = false

    [tfOpen, tfHigh, tfLow, tfClose, tfTime] = request.security(syminfo.tickerid, tf, [open, high, low, close, time], barmerge.gaps_off, barmerge.lookahead_on)

    newBar = ta.change(tfTime) != 0

    tfUp = tfHigh
    tfDown = tfLow
    tfChildUp = tfOpen > tfClose ? tfOpen : tfClose
    tfChildDown = tfOpen > tfClose ? tfClose : tfOpen

    if newBar
        upControl = tfChildUp > rangeHigh and bar_index - rangeStart > minbars and bar_index - rangeStart <= maxbars
        downControl = tfChildDown < rangeLow and bar_index - rangeStart > minbars and bar_index - rangeStart <= maxbars

        if upControl or downControl
            inConsolidation := false

        if not inConsolidation or na(rangeHigh) or na(rangeLow)
            rangeHigh := tfUp
            rangeLow := tfDown
            rangeMid := (rangeHigh + rangeLow) / 2
            rangeStart := bar_index
            inConsolidation := true

    // Enhanced touch detection with filtering (NEW)
    volume_ok = not enable_volume_filter or volume > volume_avg * volume_multiplier
    
    if use_wick_touch
        bullishWickTouch = low <= rangeLow and close > rangeLow and volume_ok and trend_aligned(true)
        bearishWickTouch = high >= rangeHigh and close < rangeHigh and volume_ok and trend_aligned(false)
    else
        bullishWickTouch = false
        bearishWickTouch = false

    if use_body_touch
        bullishBodyTouch = close <= rangeLow and close > rangeLow and volume_ok and trend_aligned(true)
        bearishBodyTouch = close >= rangeHigh and close < rangeHigh and volume_ok and trend_aligned(false)
    else
        bullishBodyTouch = false
        bearishBodyTouch = false

    bullishTouch := bullishWickTouch or bullishBodyTouch
    bearishTouch := bearishWickTouch or bearishBodyTouch
    
    // Calculate signal strength for touches
    bull_strength = bullishTouch ? calculate_signal_strength(true, false) : 0
    bear_strength = bearishTouch ? calculate_signal_strength(false, true) : 0

    [rangeHigh, rangeLow, rangeMid, bullishTouch, bearishTouch, bull_strength, bear_strength]

// Process timeframes with enhanced validation
[tf1_high, tf1_low, tf1_mid, tf1_bull_touch, tf1_bear_touch, tf1_bull_str, tf1_bear_str] = use_tf1 ? process_tf(tf1) : [na, na, na, false, false, 0, 0]
[tf2_high, tf2_low, tf2_mid, tf2_bull_touch, tf2_bear_touch, tf2_bull_str, tf2_bear_str] = use_tf2 ? process_tf(tf2) : [na, na, na, false, false, 0, 0]
[tf3_high, tf3_low, tf3_mid, tf3_bull_touch, tf3_bear_touch, tf3_bull_str, tf3_bear_str] = use_tf3 ? process_tf(tf3) : [na, na, na, false, false, 0, 0]
[tf4_high, tf4_low, tf4_mid, tf4_bull_touch, tf4_bear_touch, tf4_bull_str, tf4_bear_str] = use_tf4 ? process_tf(tf4) : [na, na, na, false, false, 0, 0]
[tf5_high, tf5_low, tf5_mid, tf5_bull_touch, tf5_bear_touch, tf5_bull_str, tf5_bear_str] = use_tf5 ? process_tf(tf5) : [na, na, na, false, false, 0, 0]
[tf6_high, tf6_low, tf6_mid, tf6_bull_touch, tf6_bear_touch, tf6_bull_str, tf6_bear_str] = use_tf6 ? process_tf(tf6) : [na, na, na, false, false, 0, 0]
[tf7_high, tf7_low, tf7_mid, tf7_bull_touch, tf7_bear_touch, tf7_bull_str, tf7_bear_str] = use_tf7 ? process_tf(tf7) : [na, na, na, false, false, 0, 0]

// Draw lines with strength validation (UPDATED)
if use_tf1 and not na(tf1_high) and (tf1_bull_str >= min_signal_strength or tf1_bear_str >= min_signal_strength)
    line.new(bar_index, tf1_high, bar_index + 1, tf1_high, color=tf1_color, width=hllinewidth, extend=extend.right)
    line.new(bar_index, tf1_low, bar_index + 1, tf1_low, color=tf1_color, width=hllinewidth, extend=extend.right)
    if use_tf1_mid
        line.new(bar_index, tf1_mid, bar_index + 1, tf1_mid, color=tf1_mid_color, width=midlinewidth, style=line.style_dashed, extend=extend.right)

if use_tf2 and not na(tf2_high) and (tf2_bull_str >= min_signal_strength or tf2_bear_str >= min_signal_strength)
    line.new(bar_index, tf2_high, bar_index + 1, tf2_high, color=tf2_color, width=hllinewidth, extend=extend.right)
    line.new(bar_index, tf2_low, bar_index + 1, tf2_low, color=tf2_color, width=hllinewidth, extend=extend.right)
    if use_tf2_mid
        line.new(bar_index, tf2_mid, bar_index + 1, tf2_mid, color=tf2_mid_color, width=midlinewidth, style=line.style_dashed, extend=extend.right)

if use_tf3 and not na(tf3_high) and (tf3_bull_str >= min_signal_strength or tf3_bear_str >= min_signal_strength)
    line.new(bar_index, tf3_high, bar_index + 1, tf3_high, color=tf3_color, width=hllinewidth, extend=extend.right)
    line.new(bar_index, tf3_low, bar_index + 1, tf3_low, color=tf3_color, width=hllinewidth, extend=extend.right)
    if use_tf3_mid
        line.new(bar_index, tf3_mid, bar_index + 1, tf3_mid, color=tf3_mid_color, width=midlinewidth, style=line.style_dashed, extend=extend.right)

if use_tf4 and not na(tf4_high) and (tf4_bull_str >= min_signal_strength or tf4_bear_str >= min_signal_strength)
    line.new(bar_index, tf4_high, bar_index + 1, tf4_high, color=tf4_color, width=hllinewidth, extend=extend.right)
    line.new(bar_index, tf4_low, bar_index + 1, tf4_low, color=tf4_color, width=hllinewidth, extend=extend.right)
    if use_tf4_mid
        line.new(bar_index, tf4_mid, bar_index + 1, tf4_mid, color=tf4_mid_color, width=midlinewidth, style=line.style_dashed, extend=extend.right)

if use_tf5 and not na(tf5_high) and (tf5_bull_str >= min_signal_strength or tf5_bear_str >= min_signal_strength)
    line.new(bar_index, tf5_high, bar_index + 1, tf5_high, color=tf5_color, width=hllinewidth, extend=extend.right)
    line.new(bar_index, tf5_low, bar_index + 1, tf5_low, color=tf5_color, width=hllinewidth, extend=extend.right)
    if use_tf5_mid
        line.new(bar_index, tf5_mid, bar_index + 1, tf5_mid, color=tf5_mid_color, width=midlinewidth, style=line.style_dashed, extend=extend.right)

if use_tf6 and not na(tf6_high) and (tf6_bull_str >= min_signal_strength or tf6_bear_str >= min_signal_strength)
    line.new(bar_index, tf6_high, bar_index + 1, tf6_high, color=tf6_color, width=hllinewidth, extend=extend.right)
    line.new(bar_index, tf6_low, bar_index + 1, tf6_low, color=tf6_color, width=hllinewidth, extend=extend.right)
    if use_tf6_mid
        line.new(bar_index, tf6_mid, bar_index + 1, tf6_mid, color=tf6_mid_color, width=midlinewidth, style=line.style_dashed, extend=extend.right)

if use_tf7 and not na(tf7_high) and (tf7_bull_str >= min_signal_strength or tf7_bear_str >= min_signal_strength)
    line.new(bar_index, tf7_high, bar_index + 1, tf7_high, color=tf7_color, width=hllinewidth, extend=extend.right)
    line.new(bar_index, tf7_low, bar_index + 1, tf7_low, color=tf7_color, width=hllinewidth, extend=extend.right)
    if use_tf7_mid
        line.new(bar_index, tf7_mid, bar_index + 1, tf7_mid, color=tf7_mid_color, width=midlinewidth, style=line.style_dashed, extend=extend.right)

// Enhanced Alert conditions with strength filtering (UPDATED)
strong_tf1_touch = alert_on_m15 and (tf1_bull_touch or tf1_bear_touch) and (tf1_bull_str >= min_signal_strength or tf1_bear_str >= min_signal_strength)
strong_tf2_touch = alert_on_h1 and (tf2_bull_touch or tf2_bear_touch) and (tf2_bull_str >= min_signal_strength or tf2_bear_str >= min_signal_strength)
strong_tf3_touch = alert_on_h2 and (tf3_bull_touch or tf3_bear_touch) and (tf3_bull_str >= min_signal_strength or tf3_bear_str >= min_signal_strength)
strong_tf4_touch = alert_on_h4 and (tf4_bull_touch or tf4_bear_touch) and (tf4_bull_str >= min_signal_strength or tf4_bear_str >= min_signal_strength)

alertcondition(strong_tf1_touch, "Strong M15 CRT Touch", "Strong M15 CRT Touch Detected")
alertcondition(strong_tf2_touch, "Strong H1 CRT Touch", "Strong H1 CRT Touch Detected")
alertcondition(strong_tf3_touch, "Strong H2 CRT Touch", "Strong H2 CRT Touch Detected")
alertcondition(strong_tf4_touch, "Strong H4 CRT Touch", "Strong H4 CRT Touch Detected")

//==============================================================================
// SECTION 5: ENHANCED SIGNAL DASHBOARD
//==============================================================================

var g_DASH = "📊 Signal Dashboard"
show_signal_dashboard = input.bool(true, "Show Signal Dashboard", group=g_DASH)

if show_signal_dashboard
    var table signal_dashboard = table.new(position.bottom_right, 2, 7, bgcolor=color.new(color.black, 85), border_width=1)
    
    if barstate.islast
        // Header
        table.cell(signal_dashboard, 0, 0, "📊 SIGNAL QUALITY", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 70))
        table.cell(signal_dashboard, 1, 0, "STATUS", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 70))
        
        // Current Signal Strength
        current_strength = calculate_signal_strength(bull_confirmed, bear_confirmed)
        strength_color = current_strength >= 75 ? color.lime : current_strength >= 60 ? color.yellow : current_strength >= 40 ? color.orange : color.red
        table.cell(signal_dashboard, 0, 1, "Signal Strength", text_color=color.white, text_size=size.small)
        table.cell(signal_dashboard, 1, 1, str.tostring(current_strength) + "%", text_color=strength_color, text_size=size.small)
        
        // Trend Status
        table.cell(signal_dashboard, 0, 2, "Trend", text_color=color.white, text_size=size.small)
        trend_status = bullish_trend ? "🟢 Bullish" : bearish_trend ? "🔴 Bearish" : "🟡 Sideways"
        trend_color = bullish_trend ? color.lime : bearish_trend ? color.red : color.yellow
        table.cell(signal_dashboard, 1, 2, trend_status, text_color=trend_color, text_size=size.small)
        
        // Volume Status
        vol_ratio = volume / volume_avg
        table.cell(signal_dashboard, 0, 3, "Volume", text_color=color.white, text_size=size.small)
        volume_status = vol_ratio > 1.5 ? "🟢 High" : vol_ratio > 1.2 ? "🟡 Above Avg" : vol_ratio > 0.8 ? "⚪ Normal" : "🔴 Low"
        volume_color = vol_ratio > 1.5 ? color.lime : vol_ratio > 1.2 ? color.yellow : vol_ratio > 0.8 ? color.white : color.red
        table.cell(signal_dashboard, 1, 3, volume_status, text_color=volume_color, text_size=size.small)
        
        // Volatility Status
        atr_ratio = candleRange / atr_value
        table.cell(signal_dashboard, 0, 4, "Volatility", text_color=color.white, text_size=size.small)
        volatility_status = atr_ratio > 1.5 ? "🟢 High" : atr_ratio > 1.0 ? "🟡 Normal" : "🔴 Low"
        volatility_color = atr_ratio > 1.5 ? color.lime : atr_ratio > 1.0 ? color.yellow : color.red
        table.cell(signal_dashboard, 1, 4, volatility_status, text_color=volatility_color, text_size=size.small)
        
        // Active Filters
        filters_count = (enable_volume_filter ? 1 : 0) + (enable_trend_filter ? 1 : 0) + (enable_confirmation ? 1 : 0)
        table.cell(signal_dashboard, 0, 5, "Filters Active", text_color=color.white, text_size=size.small)
        table.cell(signal_dashboard, 1, 5, str.tostring(filters_count) + "/3", text_color=color.cyan, text_size=size.small)
        
        // Signal Quality
        table.cell(signal_dashboard, 0, 6, "Quality Rating", text_color=color.white, text_size=size.small)
        quality_rating = current_strength >= 75 ? "⭐⭐⭐ Excellent" : 
                        current_strength >= 60 ? "⭐⭐ Good" : 
                        current_strength >= 40 ? "⭐ Fair" : "❌ Poor"
        quality_color = current_strength >= 75 ? color.lime : 
                       current_strength >= 60 ? color.yellow : 
                       current_strength >= 40 ? color.orange : color.red
        table.cell(signal_dashboard, 1, 6, quality_rating, text_color=quality_color, text_size=size.small)