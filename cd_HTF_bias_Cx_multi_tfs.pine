//@version=6
indicator("cd_HTF_bias_Cx (multi TFs)", overlay=true)

htf = input.timeframe(defval="1D", title= "Tf for bias (HTF):", group = "Bias")
mtf = input.timeframe(defval="60", title= "Tf for confirme (cisd):", group = "Bias")

show_cisd = input.bool(defval=true,title="Show cisd lines",inline="clr", group = "Bias")
bullclr = input.color(defval= color.teal,title="Bull :",inline="clr", group = "Bias")
bearclr = input.color(defval= color.red,title="Bear :",inline="clr", group = "Bias")
pclr = input.color(defval= color.black,title="Next :",inline="clr", group = "Bias")

show_box = input.bool(defval=true,title="Show HTF boxes",inline="box", group = "Bias")
boxclr = input.color(defval= color.navy,title=" Color :",inline="box", group = "Bias")
sw_clr = input.color(defval= color.rgb(219, 219, 219, 65),title="Sweep Zone color :",inline="box1", group = "Bias")
//////////////
tableOn  = input.bool(true, title="HTF Bias Table ", group="Table")
tableOn2 = input.bool(true, title="Add other assets to HTF Bias Table ", group="Table",tooltip = "Alerts are not affected")

// Multi TF Pairs (configurable)
grpPairs = "Multi TF Pairs"
multi_pairs_on = input.bool(true, title="Enable Multi TF Pairs", group=grpPairs)

p1_on  = input.bool(true,  title="Pair 1", group=grpPairs, inline="p1")
p1_htf = input.timeframe("1D",  title="HTF", group=grpPairs, inline="p1")
p1_mtf = input.timeframe("60",  title="MTF", group=grpPairs, inline="p1")

p2_on  = input.bool(true,  title="Pair 2", group=grpPairs, inline="p2")
p2_htf = input.timeframe("1W",  title="HTF", group=grpPairs, inline="p2")
p2_mtf = input.timeframe("240", title="MTF", group=grpPairs, inline="p2")

p3_on  = input.bool(true,  title="Pair 3", group=grpPairs, inline="p3")
p3_htf = input.timeframe("1M",  title="HTF", group=grpPairs, inline="p3")
p3_mtf = input.timeframe("1D",  title="MTF", group=grpPairs, inline="p3")

p4_on  = input.bool(true,  title="Pair 4", group=grpPairs, inline="p4")
p4_htf = input.timeframe("3M",  title="HTF", group=grpPairs, inline="p4")
p4_mtf = input.timeframe("1D",  title="MTF", group=grpPairs, inline="p4")

p5_on  = input.bool(true,  title="Pair 5", group=grpPairs, inline="p5")
p5_htf = input.timeframe("6M",  title="HTF", group=grpPairs, inline="p5")
p5_mtf = input.timeframe("1D",  title="MTF", group=grpPairs, inline="p5")

gr1 = "Alerts"
alert_ind   = input.bool(defval=true, title = "Use indicator alerts", inline="b",group = gr1,tooltip = "When using the TradingView alert feature, it should be inactive.")
alert_bull  = input.bool(defval=false,title = "Bullish alerts", inline="b1",group = gr1)
alert_bear  = input.bool(defval=false,title = "Bearish alerts", inline="b2",group = gr1)
alert_sbull = input.bool(defval=false,title = "Strong Bullish alerts", inline="b1",group = gr1)
alert_sbear = input.bool(defval=false,title = "Strong Bearish alerts", inline="b2",group = gr1)

//Table Location & Size
i_font     = input.string("small", "Text size",  options = ["tiny", "small",  "normal", "large", "huge"], group = "Table", inline  = "1")
i_pos      = input.string(position.top_right, "Table Position", inline  = "1", options = [position.middle_right, position.top_right,position.bottom_right,position.bottom_center], group = "Table")

//Assets
ignore =input.bool(defval = false,  title = "Ignore these assets " , group = "Assets",inline="s0",tooltip = "When the box is selected, assets are passive")

ok1 = input.bool(defval=true,title="",group = "Assets",inline="s1")
ok2 = input.bool(defval=true,title="",group = "Assets",inline="s2")
ok3 = input.bool(defval=true,title="",group = "Assets",inline="s3")
ok4 = input.bool(defval=true,title="",group = "Assets",inline="s4")
ok5 = input.bool(defval=true,title="",group = "Assets",inline="s5")
ok6 = input.bool(defval=true,title="",group = "Assets",inline="s6")
ok7 = input.bool(defval=true,title="",group = "Assets",inline="s7")

s1=input.symbol(defval = "PEPPERSTONE:EURUSD",  title = "1 : " , group = "Assets",inline="s1")
s2=input.symbol(defval = "PEPPERSTONE:GBPUSD",  title = "2 : " , group = "Assets",inline="s2")
s3=input.symbol(defval = "TVC:DXY",             title = "3 : " , group = "Assets",inline="s3")
s4=input.symbol(defval = "PEPPERSTONE:NAS100",  title = "4 : " , group = "Assets",inline="s4")
s5=input.symbol(defval = "PEPPERSTONE:US500",   title = "5 : " , group = "Assets",inline="s5")
s6=input.symbol(defval = "PEPPERSTONE:XAUUSD",  title = "6 : " , group = "Assets",inline="s6")
s7=input.symbol(defval = "PEPPERSTONE:XAGUSD",  title = "7 : " , group = "Assets",inline="s7")

/////////////////////////////
sym= syminfo.tickerid
tf = timeframe.period
plot_conmtf = timeframe.in_seconds(tf) *1000 <= timeframe.in_seconds(mtf)*1000 
plot_conhtf = timeframe.in_seconds(tf) *1000 <  timeframe.in_seconds(htf)*1000
var bearish_bias = false
var bullish_bias = false
var tablo = table.new(position = i_pos,columns = 2,rows = 28,frame_color=color.white,frame_width=2,bgcolor=color.teal,border_color=color.white,border_width=1)
var lasthighswept = 0
var lastlowswept = 0
//////////////////////////////// functions
add_to_array(arr, value) =>
    array.unshift(arr, value)
    if array.size(arr) > 100
        array.pop(arr)
f_text(string _tf)=>
    _text = str.tonumber(_tf) < 59 ? _tf + 'm'  :
     str.tonumber(_tf) > 59  ? 'h'+ str.tostring(math.floor(str.tonumber(_tf)/60))    : _tf
    _text := _tf == "1D" ? "D" : _tf == "1W" ? "W" : _tf == "1M" ? "M" : _tf

f_tfcon(_tf)=>
    timeframe.in_seconds(_tf) / 60 >= timeframe.in_seconds(timeframe.period)/60

f_get_color(_bias)=>
    tb_color= _bias  > 0 ? color.teal : _bias < 0 ? color.red : color.gray
f_get_text(_bias)=>
    txt= 
     _bias  == 11 ? "Strong Bullish" : 
     _bias  ==  1 ? "Bullish" : 
     _bias  == -1 ? "Bearish" :
     _bias  ==-11 ? "Strong Bearish" : "No Bias" 

f_live_mini(_htf)=>
    var _o0 = open
    var _h0 = high
    var _l0 = low
    var _t0 = time
    var _c0 = close
    var _h0bar = time
    var _l0bar = time

    var _h1 = high
    var _l1 = low
    var _t1 = time
    var _c1 = close
    var _o1 = open
    var _h1bar = time
    var _l1bar = time 

    if timeframe.change(_htf)
        _t0 := time
        _o0 := open
        _h0 := high
        _l0 := low
    if high >= _h0
        _h0 := high
        _h0bar := time

    if low <= _l0
        _l0 := low
        _l0bar := time
    if timeframe.change(_htf)        
        _o1 := _o0[1]
        _h1 := _h0[1]
        _l1 := _l0[1]
        _t1 := _t0[1]
        _c1 := close[1]
        _h1bar := _h0bar[1]
        _l1bar := _l0bar[1] 
    _c0:= close
    [_h1,_l1,_c1,_o1,_t1,_h0,_l0,_c0,_o0,_t0,_h1bar,_l1bar,_h0bar,_l0bar]
[hh1,hl1,hc1,ho1,ht1,hh0,hl0,hc0,ho0,ht0,hh1bar,hl1bar,hh0bar,hl0bar]=f_live_mini(htf)  
var hh2 = high
var hh3 = high
var hh4 = high
var lh2  =low 
var hl3  = low 
var hl4  = low
var ht2  = time 
var ht3  = time
var ht4  = time
if timeframe.change(htf)
    hh2 := hh1[1] , hh3 := hh2[1], hh4 := hh3[1]
    lh2 := hl1[1] , hl3 := lh2[1], hl4 := hl3[1]
    ht2 := ht1[1] , ht3 := ht2[1], ht4 := ht3[1]      
f_sweep(_htf)=>
    hsweep = false 
    lsweep = false 
    var hsweep1 = false 
    var lsweep1 = false
    var hsweep2 = false 
    var lsweep2 = false 
    var hbreak =  false 
    var lbreak =  false    
    _hslevel = high 
    _lslevel = low
    _hslevel := hh1
    _lslevel := hl1
    hbreak := false
    lbreak := false   
    if (hh0 > hh1 and math.max(ho0,hc0) <= hh1)  or (ho0 > hh1  and hc0 < hh1)
        hsweep := true
        _hslevel := hh1
    if hh1 > hh0
        hbreak := true
      
    if (hh0 > hh2 and math.max(ho0,hc0) <= hh2 and hh2 > _hslevel)  and not hbreak
        hsweep := true
        _hslevel := hh2 
    if hh2 > hh0
        hbreak := true  

    if (hh0 > hh3 and math.max(ho0,hc0) <= hh3 and hh3 > _hslevel) and not hbreak  
        hsweep := true
        _hslevel := hh3
    if hh3 > hh0
        hbreak := true  

    if (hh0 > hh4 and math.max(ho0,hc0) <= hh4 and hh4 > _hslevel) and not hbreak 
        hsweep := true
        _hslevel := hh4  

    if hc0 > _hslevel 
        hsweep := false


    if (hl0 < hl1 and math.min(ho0,hc0) >= hl1 ) or (ho0 < hl1  and hc0 > hl1)
        lsweep  := true
        _lslevel := hl1
    if hl1 < hl0
        lbreak := true
    if (hl0 < lh2 and math.min(ho0,hc0) >= lh2 and lh2 < _lslevel ) and not lbreak
        lsweep  := true
        _lslevel := lh2 
    if lh2 < hl0
        lbreak := true        
    if (hl0 < hl3 and math.min(ho0,hc0) >=hl3 and hl3 < _lslevel ) and not lbreak
        lsweep  := true
        _lslevel := hl3 
    if hl3 < hl0
        lbreak := true 
    if (hl0 < hl4 and math.min(ho0,hc0) >=hl4 and hl4 < _lslevel ) and not lbreak
        lsweep  := true
        _lslevel := hl4

    if hc0 < _lslevel
        lsweep := false 


    if timeframe.change(_htf)
        hsweep1 := hsweep[1]
        lsweep1 := lsweep[1]
        hsweep2 := hsweep1[1]
        lsweep2 := lsweep1[1] 

    [hh0,hh1,hl0,hl1,hsweep,hsweep1,lsweep,lsweep1,hsweep2,lsweep2,_hslevel,_lslevel]   

f_control(_mtf,_htf)=>
    var bear_cisd = false
    var bear_level = open
    var bear_index = bar_index
    var bull_cisd = false
    var bull_level = open
    var bull_index = bar_index    
    var mtf_h = array.new_float()
    var mtf_l = array.new_float() 
    var mtf_o = array.new_float()
    var mtf_c = array.new_float()
    var mtf_t = array.new_int()
    var mtf_hbar   = array.new_int() 
    var mtf_lbar   = array.new_int()
    var mtf_candle = array.new_int()  
    var mup1 = false
    var mdw1 = false
    var meq1 = false
    var bear_sweepcisd=false
    var bull_sweepcisd=false 
    var bull_plot = 999999999.9
    var bear_plot = 0.0 
    var bear_sl   = high
    var bull_sl   = low
    var bear_time = time
    var bull_time = time
    var bull_key  = low
    var bear_key  = high
    var SCbull_key = low
    var SCbear_key = high  
    var last_cisd = 0
    var bias = 0
    [mh1,ml1,mc1,mo1,mt1,mh0,ml0,mc0,mo0,mt0,mh1bar,ml1bar,mh0bar,ml0bar]=f_live_mini(_mtf)
    [hth0,hth1,htl0,htl1,hsweep,hsweep1,lsweep,lsweep1,hsweep2,lsweep2,hslevel,lslevel]=f_sweep(_htf) 
    mtf_ok = (mt0 + timeframe.in_seconds(_mtf)*1000 == time + timeframe.in_seconds(tf)*1000 and barstate.isconfirmed)

    mup = mc0 > mo0
    mdw = mc0 < mo0
    meq = mc0 == mo0 
    if timeframe.change(_mtf)
        add_to_array(mtf_h, mh1)
        add_to_array(mtf_l, ml1) 
        add_to_array(mtf_o, mo1)
        add_to_array(mtf_c, mc1) 
        add_to_array(mtf_t, mt1)
        add_to_array(mtf_hbar, mh1bar)
        add_to_array(mtf_lbar, ml1bar)
        mup1 := mup[1] 
        mdw1 := mdw[1]
        meq1 := meq[1]                       
        add_to_array(mtf_candle,mup1 ? 1 : mdw1 ? -1 : 0)

/////////////////////bear cisd
    if high == hth0 and high > hth1
        bear_cisd := false
        if (mdw1 or meq1) and mup
            bear_level := mo0
            bear_index := mt0

        if ((mdw1 or meq1) and mup) == false and array.size(mtf_h) > 15
            for i = 1 to 15
                if array.get(mtf_h,i) > mh0
                    break            
                if (array.get(mtf_candle,i) == -1 or array.get(mtf_candle,i) == 0) and array.get(mtf_candle,i-1) == 1 
                    ybar = i - 1
                    bear_level := array.get(mtf_o,ybar)
                    bear_index := array.get(mtf_t,ybar)
                                       
                    for j= ybar to 0
                        if array.get(mtf_o,j) < bear_level and array.get(mtf_candle,j) == 1
                            bear_level := array.get(mtf_o,j)
                            bear_index := array.get(mtf_t,j)                            

                    if bear_level > mo0 and not (mc0 < mo0)
                        bear_level := mo0
                        bear_index := time   
                    if bear_level > mo0 and (mc0 < mo0)
                        bear_level := ml0
                        bear_index := time 
               
                    break
/////////////////////////// bull cisd

    if low == htl0 and low < htl1
        bull_cisd := false
        if (mup1 or meq1) and mdw
            bull_level := mo0
            bull_index := mt0

        if ((mup1 or meq1) and mdw) == false and array.size(mtf_l) > 15
            for i = 1 to 15
                if array.get(mtf_l,i) < ml0
                    break

                if (array.get(mtf_candle,i) == 1 or array.get(mtf_candle,i) == 0) and array.get(mtf_candle,i-1) == -1 
                    xbar = i - 1 
                    bull_level := array.get(mtf_o,xbar)
                    bull_index := array.get(mtf_t,xbar)
                    for j= xbar to 0
                        if array.get(mtf_o,j) > bull_level and array.get(mtf_candle,j) == -1 
                            bull_level := array.get(mtf_o,j)
                            bull_index := array.get(mtf_t,j) 

                    if bull_level < mo0 and not (mc0 > mo0)
                        bull_level := mo0
                        bull_index := time   
                    if bull_level < mo0 and (mc0 > mo0)
                        bull_level := mh0
                        bull_index := time
           
                    break

//////////////////////////////////////////high sweep + cisd


    if mc0 < bear_level  and time > bear_index and bear_cisd == false and mtf_ok
        bear_cisd := true
        bear_plot := bear_level
        bear_level := 0.0 
        bear_time  := time
        last_cisd  := -1
        float hmax = 0.0
        for i = 0 to 100
            if open[i] == bear_plot and close[i] > open[i]
                if  high[i] >= hmax
                    hmax := high[i]                
                break
            if high[i] > hmax
                hmax := high[i]
        bear_key := hmax
/////////////////////////// 
    if (hsweep or (hsweep1 and not hsweep and hth0 <= hth1)or (hsweep2 and not hsweep and not hsweep1 and hh2 > hth1 and hh2 > hth0 )) and bear_cisd
        bear_sweepcisd := true
        SCbear_key := bear_key
        bias := -1
    if mh0 >= SCbear_key
        bear_sweepcisd := false  
////////////////////////////////// bullsweep + cisd


    if mc0 > bull_level  and time > bull_index and bull_cisd == false and mtf_ok
        bull_cisd := true
        bull_plot := bull_level
        bull_level := 999999999.9
        bull_time  := time
        last_cisd  := 1
        float lmin = 99999999999.9
        for i = 0 to 100
            if open[i] == bull_plot and close[i] < open[i]
                if  low[i] <= lmin
                    lmin := low[i] 
                break
            if low[i] < lmin
                lmin := low[i]
        bull_key := lmin
//////////////////////////////////////
    if (lsweep or (lsweep1 and not lsweep and htl0 >= htl1) or (lsweep2 and not lsweep and not lsweep1 and lh2 < htl1 and lh2 < htl0 )   ) and bull_cisd 
        bull_sweepcisd := true
        SCbull_key := bull_key
        bias := 1
/////////////////////////////////////////
    if ml0 < SCbull_key
        bull_sweepcisd := false
//////////////////////////////////////////////////////bias
    if bull_sweepcisd 
        bias := 1
    if bear_sweepcisd
        bias := -1 
    if bull_sweepcisd and bear_sweepcisd 
        if bear_time > bull_time
            bias := -1
        else
            bias := 1
    if not bull_sweepcisd and not bear_sweepcisd
        bias := 0


    if bias == 1 and mc1 > bear_key 
        bias := 11
    if bias == -1 and mc1 < bull_key
        bias := -11
    if bias == 11 and not bear_sweepcisd and bear_cisd
        bias := 1
    if bias == -11 and not bull_sweepcisd and bull_cisd
        bias := -1 

   
    [bear_level,bear_plot,bear_index,bear_cisd,bull_level,bull_plot,bull_index,bull_cisd,bear_sweepcisd,bull_sweepcisd,bias,hslevel,lslevel]
////////////////////////////////////////////////////////////////////////
[pbecisd,becisd,be_index,be_cisd,pbucisd,bucisd,bu_index,bu_cisd,be_sweepcisd,bu_sweepcisd,bias0,hhlevel,lllevel] = f_control(mtf,htf)

// Fixed pairs
[pbecisdD,becisdD,be_indexD,be_cisdD,pbucisdD,bucisdD,bu_indexD,bu_cisdD,be_sweepcisdD,bu_sweepcisdD,biasD,hsD,lsD] = f_control("60",  "1D")
[pbecisdW,becisdW,be_indexW,be_cisdW,pbucisdW,bucisdW,bu_indexW,bu_cisdW,be_sweepcisdW,bu_sweepcisdW,biasW,hsW,lsW] = f_control("240", "1W")
[pbecisdM,becisdM,be_indexM,be_cisdM,pbucisdM,bucisdM,bu_indexM,bu_cisdM,be_sweepcisdM,bu_sweepcisdM,biasM,hsM,lsM] = f_control("1D",  "1M")
[pbecisdQ,becisdQ,be_indexQ,be_cisdQ,pbucisdQ,bucisdQ,bu_indexQ,bu_cisdQ,be_sweepcisdQ,bu_sweepcisdQ,biasQ,hsQ,lsQ] = f_control("1D",  "3M")
[pbecisdH,becisdH,be_indexH,be_cisdH,pbucisdH,bucisdH,bu_indexH,bu_cisdH,be_sweepcisdH,bu_sweepcisdH,biasH,hsH,lsH] = f_control("1D",  "6M")

//////////////////// plot (base pair)
if f_tfcon(htf) and time == ht0 and timeframe.period != htf and show_box and plot_conhtf
    boxhtf1=box.new(left = ht1, top = hh1 , right = ht0, bottom = hl1,xloc = xloc.bar_time,border_width = 1,border_style = line.style_dotted,bgcolor =color.rgb(255, 255, 255, 100) , border_color = boxclr ,text = "",text_color= color.navy, text_size=size.tiny ,text_halign = text.align_right,text_valign = text.align_center )
if f_tfcon(htf) and timeframe.period != htf and show_box  and plot_conhtf
    boxhtf=box.new(left = ht0, top = high > hh0 ? high : hh0 , right = time+1, bottom =low < hl0 ? low : hl0,xloc = xloc.bar_time,border_width = 1,border_style = line.style_dotted,bgcolor =color.rgb(255, 255, 255, 100) , border_color = boxclr  ,text = "",text_color= color.navy, text_size=size.tiny ,text_halign = text.align_right,text_valign = text.align_center)
    box.delete(boxhtf[1])

if hh0 > hhlevel and hc0 < hhlevel and f_tfcon(htf) and timeframe.period != htf and show_box and plot_conhtf
    lasthighswept := ht0
    boxh=box.new(left = ht0, top = hh0 , right = time, bottom = hhlevel,xloc = xloc.bar_time,border_width = 1,bgcolor =sw_clr , border_color = sw_clr )
    if lasthighswept[1] == ht0
        box.delete(boxh[1])
if hl0 < lllevel and hc0 > lllevel and f_tfcon(htf) and timeframe.period != htf and show_box and plot_conhtf
    lastlowswept := ht0
    boxl=box.new(left = ht0, top = lllevel , right = time, bottom = hl0,xloc = xloc.bar_time,border_width = 1,bgcolor =sw_clr , border_color = sw_clr )
    if lastlowswept[1] == ht0
        box.delete(boxl[1])
dt = timeframe.in_seconds(tf)*1000 



var pbu_line = line.new(na,na,na,na)
var pbe_line = line.new(na,na,na,na)
if f_tfcon(mtf) and pbucisd != 999999999.9 and show_cisd  and plot_conhtf and plot_conmtf
    pbu_line :=line.new(x1= bu_index, y1= pbucisd,x2= time+2*dt , y2= pbucisd, xloc=xloc.bar_time,color = pclr,width  = 1,style = line.style_dashed)
    line.delete(pbu_line[1])
if f_tfcon(mtf) and pbecisd != 0.0 and show_cisd  and plot_conhtf and plot_conmtf
    pbe_line :=line.new(x1= be_index, y1= pbecisd,x2= time+2*dt, y2= pbecisd, xloc=xloc.bar_time,color = pclr,width  = 1,style = line.style_dashed)
    line.delete(pbe_line[1])


if bu_cisd and (not bu_cisd[1] or bucisd !=bucisd[1]) and f_tfcon(mtf) and show_cisd  and plot_conhtf and plot_conmtf
    bu_line =box.new(left= bu_index, top= bucisd,right= time,xloc=xloc.bar_time, bottom= bucisd,border_color = bullclr,border_width  = 1,text=f_text(mtf),text_color = bullclr,text_size=i_font,text_halign = text.align_center,text_valign = text.align_bottom)
    line.delete(pbu_line[1])
if be_cisd and (not be_cisd[1] or becisd != becisd[1]) and f_tfcon(mtf)and show_cisd  and plot_conhtf and plot_conmtf 
    be_line =box.new(left= be_index, top= becisd,right= time,xloc=xloc.bar_time, bottom= becisd,border_color = bearclr,border_width  = 1,text=f_text(mtf),text_color = bearclr,text_size=i_font,text_halign = text.align_center,text_valign = text.align_top)
    line.delete(pbe_line[1])

// Fixed pairs plotting (CISD next lines and boxes) D/1H, W/4H, M/1D, 3M/1D, 6M/1D
var pbu_line_D = line.new(na,na,na,na)
var pbe_line_D = line.new(na,na,na,na)
var pbu_line_W = line.new(na,na,na,na)
var pbe_line_W = line.new(na,na,na,na)
var pbu_line_M = line.new(na,na,na,na)
var pbe_line_M = line.new(na,na,na,na)
var pbu_line_Q = line.new(na,na,na,na)
var pbe_line_Q = line.new(na,na,na,na)
var pbu_line_H = line.new(na,na,na,na)
var pbe_line_H = line.new(na,na,na,na)

// D/1H
if f_tfcon("60") and pbucisdD != 999999999.9 and show_cisd
    pbu_line_D := line.new(x1= bu_indexD, y1= pbucisdD, x2= time+2*dt, y2= pbucisdD, xloc=xloc.bar_time, color=pclr, width=1, style=line.style_dashed)
    line.delete(pbu_line_D[1])
if f_tfcon("60") and pbecisdD != 0.0 and show_cisd
    pbe_line_D := line.new(x1= be_indexD, y1= pbecisdD, x2= time+2*dt, y2= pbecisdD, xloc=xloc.bar_time, color=pclr, width=1, style=line.style_dashed)
    line.delete(pbe_line_D[1])
if bu_cisdD and (not bu_cisdD[1] or (bucisdD != bucisdD[1])) and f_tfcon("60") and show_cisd
    box.new(left= bu_indexD, top= bucisdD, right= time, xloc=xloc.bar_time, bottom= bucisdD, border_color=bullclr, border_width=1, text="D/1H", text_color=bullclr, text_size=i_font, text_halign=text.align_center, text_valign=text.align_bottom)
if be_cisdD and (not be_cisdD[1] or (becisdD != becisdD[1])) and f_tfcon("60") and show_cisd
    box.new(left= be_indexD, top= becisdD, right= time, xloc=xloc.bar_time, bottom= becisdD, border_color=bearclr, border_width=1, text="D/1H", text_color=bearclr, text_size=i_font, text_halign=text.align_center, text_valign=text.align_top)

// W/4H
if f_tfcon("240") and pbucisdW != 999999999.9 and show_cisd
    pbu_line_W := line.new(x1= bu_indexW, y1= pbucisdW, x2= time+2*dt, y2= pbucisdW, xloc=xloc.bar_time, color=pclr, width=1, style=line.style_dashed)
    line.delete(pbu_line_W[1])
if f_tfcon("240") and pbecisdW != 0.0 and show_cisd
    pbe_line_W := line.new(x1= be_indexW, y1= pbecisdW, x2= time+2*dt, y2= pbecisdW, xloc=xloc.bar_time, color=pclr, width=1, style=line.style_dashed)
    line.delete(pbe_line_W[1])
if bu_cisdW and (not bu_cisdW[1] or (bucisdW != bucisdW[1])) and f_tfcon("240") and show_cisd
    box.new(left= bu_indexW, top= bucisdW, right= time, xloc=xloc.bar_time, bottom= bucisdW, border_color=bullclr, border_width=1, text="W/4H", text_color=bullclr, text_size=i_font, text_halign=text.align_center, text_valign=text.align_bottom)
if be_cisdW and (not be_cisdW[1] or (becisdW != becisdW[1])) and f_tfcon("240") and show_cisd
    box.new(left= be_indexW, top= becisdW, right= time, xloc=xloc.bar_time, bottom= becisdW, border_color=bearclr, border_width=1, text="W/4H", text_color=bearclr, text_size=i_font, text_halign=text.align_center, text_valign=text.align_top)

// M/1D
if f_tfcon("1D") and pbucisdM != 999999999.9 and show_cisd
    pbu_line_M := line.new(x1= bu_indexM, y1= pbucisdM, x2= time+2*dt, y2= pbucisdM, xloc=xloc.bar_time, color=pclr, width=1, style=line.style_dashed)
    line.delete(pbu_line_M[1])
if f_tfcon("1D") and pbecisdM != 0.0 and show_cisd
    pbe_line_M := line.new(x1= be_indexM, y1= pbecisdM, x2= time+2*dt, y2= pbecisdM, xloc=xloc.bar_time, color=pclr, width=1, style=line.style_dashed)
    line.delete(pbe_line_M[1])
if bu_cisdM and (not bu_cisdM[1] or (bucisdM != bucisdM[1])) and f_tfcon("1D") and show_cisd
    box.new(left= bu_indexM, top= bucisdM, right= time, xloc=xloc.bar_time, bottom= bucisdM, border_color=bullclr, border_width=1, text="M/1D", text_color=bullclr, text_size=i_font, text_halign=text.align_center, text_valign=text.align_bottom)
if be_cisdM and (not be_cisdM[1] or (becisdM != becisdM[1])) and f_tfcon("1D") and show_cisd
    box.new(left= be_indexM, top= becisdM, right= time, xloc=xloc.bar_time, bottom= becisdM, border_color=bearclr, border_width=1, text="M/1D", text_color=bearclr, text_size=i_font, text_halign=text.align_center, text_valign=text.align_top)

// 3M/1D
if f_tfcon("1D") and pbucisdQ != 999999999.9 and show_cisd
    pbu_line_Q := line.new(x1= bu_indexQ, y1= pbucisdQ, x2= time+2*dt, y2= pbucisdQ, xloc=xloc.bar_time, color=pclr, width=1, style=line.style_dashed)
    line.delete(pbu_line_Q[1])
if f_tfcon("1D") and pbecisdQ != 0.0 and show_cisd
    pbe_line_Q := line.new(x1= be_indexQ, y1= pbecisdQ, x2= time+2*dt, y2= pbecisdQ, xloc=xloc.bar_time, color=pclr, width=1, style=line.style_dashed)
    line.delete(pbe_line_Q[1])
if bu_cisdQ and (not bu_cisdQ[1] or (bucisdQ != bucisdQ[1])) and f_tfcon("1D") and show_cisd
    box.new(left= bu_indexQ, top= bucisdQ, right= time, xloc=xloc.bar_time, bottom= bucisdQ, border_color=bullclr, border_width=1, text="3M/1D", text_color=bullclr, text_size=i_font, text_halign=text.align_center, text_valign=text.align_bottom)
if be_cisdQ and (not be_cisdQ[1] or (becisdQ != becisdQ[1])) and f_tfcon("1D") and show_cisd
    box.new(left= be_indexQ, top= becisdQ, right= time, xloc=xloc.bar_time, bottom= becisdQ, border_color=bearclr, border_width=1, text="3M/1D", text_color=bearclr, text_size=i_font, text_halign=text.align_center, text_valign=text.align_top)

// 6M/1D
if f_tfcon("1D") and pbucisdH != 999999999.9 and show_cisd
    pbu_line_H := line.new(x1= bu_indexH, y1= pbucisdH, x2= time+2*dt, y2= pbucisdH, xloc=xloc.bar_time, color=pclr, width=1, style=line.style_dashed)
    line.delete(pbu_line_H[1])
if f_tfcon("1D") and pbecisdH != 0.0 and show_cisd
    pbe_line_H := line.new(x1= be_indexH, y1= pbecisdH, x2= time+2*dt, y2= pbecisdH, xloc=xloc.bar_time, color=pclr, width=1, style=line.style_dashed)
    line.delete(pbe_line_H[1])
if bu_cisdH and (not bu_cisdH[1] or (bucisdH != bucisdH[1])) and f_tfcon("1D") and show_cisd
    box.new(left= bu_indexH, top= bucisdH, right= time, xloc=xloc.bar_time, bottom= bucisdH, border_color=bullclr, border_width=1, text="6M/1D", text_color=bullclr, text_size=i_font, text_halign=text.align_center, text_valign=text.align_bottom)
if be_cisdH and (not be_cisdH[1] or (becisdH != becisdH[1])) and f_tfcon("1D") and show_cisd
    box.new(left= be_indexH, top= becisdH, right= time, xloc=xloc.bar_time, bottom= becisdH, border_color=bearclr, border_width=1, text="6M/1D", text_color=bearclr, text_size=i_font, text_halign=text.align_center, text_valign=text.align_top)

// Alerts (base pair)
if bias0 == -1 and not (bias0[1] == -1) and not (bias0[1] == -11)  and not alert_ind and alert_bear
    alert(sym +',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf) + ',🔴 Bearish Alert', alert.freq_once_per_bar) 

if bias0 == 1 and not (bias0[1] == 1) and not (bias0[1] == 11)  and not alert_ind and alert_bull        
    alert(sym + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf) + ',🟢 Bullish Alarm', alert.freq_once_per_bar) 

if bias0 == -11 and not (bias0[1] == -11) and not alert_ind and alert_sbear
    alert(sym +',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf) + ',🔴 Strong Bearish Alert', alert.freq_once_per_bar) 

if bias0 == 11 and not (bias0[1] == 11) and not alert_ind and alert_sbull        
    alert(sym + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf) + ',🟢 Strong Bullish Alarm', alert.freq_once_per_bar) 

// Fixed pair alertconditions (current symbol)
alertcondition(biasD ==  1 and (biasD[1] != 1 and biasD[1] != 11), "D/1H Bullish",          "D/1H: Bullish")
alertcondition(biasD == -1 and (biasD[1] != -1 and biasD[1] != -11), "D/1H Bearish",        "D/1H: Bearish")
alertcondition(biasD == 11 and biasD[1] != 11,                        "D/1H Strong Bullish","D/1H: Strong Bullish")
alertcondition(biasD == -11 and biasD[1] != -11,                      "D/1H Strong Bearish","D/1H: Strong Bearish")

alertcondition(biasW ==  1 and (biasW[1] != 1 and biasW[1] != 11), "W/4H Bullish",          "W/4H: Bullish")
alertcondition(biasW == -1 and (biasW[1] != -1 and biasW[1] != -11), "W/4H Bearish",         "W/4H: Bearish")
alertcondition(biasW == 11 and biasW[1] != 11,                        "W/4H Strong Bullish", "W/4H: Strong Bullish")
alertcondition(biasW == -11 and biasW[1] != -11,                      "W/4H Strong Bearish", "W/4H: Strong Bearish")

alertcondition(biasM ==  1 and (biasM[1] != 1 and biasM[1] != 11), "M/1D Bullish",          "M/1D: Bullish")
alertcondition(biasM == -1 and (biasM[1] != -1 and biasM[1] != -11), "M/1D Bearish",         "M/1D: Bearish")
alertcondition(biasM == 11 and biasM[1] != 11,                        "M/1D Strong Bullish", "M/1D: Strong Bullish")
alertcondition(biasM == -11 and biasM[1] != -11,                      "M/1D Strong Bearish", "M/1D: Strong Bearish")

alertcondition(biasQ ==  1 and (biasQ[1] != 1 and biasQ[1] != 11), "3M/1D Bullish",          "3M/1D: Bullish")
alertcondition(biasQ == -1 and (biasQ[1] != -1 and biasQ[1] != -11), "3M/1D Bearish",         "3M/1D: Bearish")
alertcondition(biasQ == 11 and biasQ[1] != 11,                        "3M/1D Strong Bullish", "3M/1D: Strong Bullish")
alertcondition(biasQ == -11 and biasQ[1] != -11,                      "3M/1D Strong Bearish", "3M/1D: Strong Bearish")

alertcondition(biasH ==  1 and (biasH[1] != 1 and biasH[1] != 11), "6M/1D Bullish",          "6M/1D: Bullish")
alertcondition(biasH == -1 and (biasH[1] != -1 and biasH[1] != -11), "6M/1D Bearish",         "6M/1D: Bearish")
alertcondition(biasH == 11 and biasH[1] != 11,                        "6M/1D Strong Bullish", "6M/1D: Strong Bullish")
alertcondition(biasH == -11 and biasH[1] != -11,                      "6M/1D Strong Bearish", "6M/1D: Strong Bearish")

// Runtime alerts with toggles for fixed pairs
if not alert_ind
    if alert_bull and biasD == 1 and (biasD[1] != 1 and biasD[1] != 11)
        alert(sym + ", D/1H, 🟢 Bullish", alert.freq_once_per_bar)
    if alert_bear and biasD == -1 and (biasD[1] != -1 and biasD[1] != -11)
        alert(sym + ", D/1H, 🔴 Bearish", alert.freq_once_per_bar)
    if alert_sbull and biasD == 11 and biasD[1] != 11
        alert(sym + ", D/1H, 🟢 Strong Bullish", alert.freq_once_per_bar)
    if alert_sbear and biasD == -11 and biasD[1] != -11
        alert(sym + ", D/1H, 🔴 Strong Bearish", alert.freq_once_per_bar)

    if alert_bull and biasW == 1 and (biasW[1] != 1 and biasW[1] != 11)
        alert(sym + ", W/4H, 🟢 Bullish", alert.freq_once_per_bar)
    if alert_bear and biasW == -1 and (biasW[1] != -1 and biasW[1] != -11)
        alert(sym + ", W/4H, 🔴 Bearish", alert.freq_once_per_bar)
    if alert_sbull and biasW == 11 and biasW[1] != 11
        alert(sym + ", W/4H, 🟢 Strong Bullish", alert.freq_once_per_bar)
    if alert_sbear and biasW == -11 and biasW[1] != -11
        alert(sym + ", W/4H, 🔴 Strong Bearish", alert.freq_once_per_bar)

    if alert_bull and biasM == 1 and (biasM[1] != 1 and biasM[1] != 11)
        alert(sym + ", M/1D, 🟢 Bullish", alert.freq_once_per_bar)
    if alert_bear and biasM == -1 and (biasM[1] != -1 and biasM[1] != -11)
        alert(sym + ", M/1D, 🔴 Bearish", alert.freq_once_per_bar)
    if alert_sbull and biasM == 11 and biasM[1] != 11
        alert(sym + ", M/1D, 🟢 Strong Bullish", alert.freq_once_per_bar)
    if alert_sbear and biasM == -11 and biasM[1] != -11
        alert(sym + ", M/1D, 🔴 Strong Bearish", alert.freq_once_per_bar)

    if alert_bull and biasQ == 1 and (biasQ[1] != 1 and biasQ[1] != 11)
        alert(sym + ", 3M/1D, 🟢 Bullish", alert.freq_once_per_bar)
    if alert_bear and biasQ == -1 and (biasQ[1] != -1 and biasQ[1] != -11)
        alert(sym + ", 3M/1D, 🔴 Bearish", alert.freq_once_per_bar)
    if alert_sbull and biasQ == 11 and biasQ[1] != 11
        alert(sym + ", 3M/1D, 🟢 Strong Bullish", alert.freq_once_per_bar)
    if alert_sbear and biasQ == -11 and biasQ[1] != -11
        alert(sym + ", 3M/1D, 🔴 Strong Bearish", alert.freq_once_per_bar)

    if alert_bull and biasH == 1 and (biasH[1] != 1 and biasH[1] != 11)
        alert(sym + ", 6M/1D, 🟢 Bullish", alert.freq_once_per_bar)
    if alert_bear and biasH == -1 and (biasH[1] != -1 and biasH[1] != -11)
        alert(sym + ", 6M/1D, 🔴 Bearish", alert.freq_once_per_bar)
    if alert_sbull and biasH == 11 and biasH[1] != 11
        alert(sym + ", 6M/1D, 🟢 Strong Bullish", alert.freq_once_per_bar)
    if alert_sbear and biasH == -11 and biasH[1] != -11
        alert(sym + ", 6M/1D, 🔴 Strong Bearish", alert.freq_once_per_bar)

if tableOn
    table.cell(tablo,0,0,text="Tf Alingment & Bias" ,text_color=color.white,bgcolor= color.teal, text_size = size.normal)
    table.cell(tablo,0,1,text="HTF : "+ f_text(htf)+"  MTF : "+ f_text(mtf) ,text_color=color.white,bgcolor= color.teal, text_size = size.normal)
    if plot_conmtf and plot_conhtf
        table.cell(tablo,0,2,text=" Chart Asset's Bias: "+f_get_text(bias0) ,text_color=color.white,bgcolor= f_get_color(bias0), text_size = i_font)

// Extra table rows for fixed pairs
if tableOn
    table.cell(tablo,0,10,text="Multi TF Bias",text_color=color.white,bgcolor=color.teal,text_size=size.normal)
    table.cell(tablo,0,11,text="D/1H: "+ f_get_text(biasD),text_color=color.white,bgcolor=f_get_color(biasD),text_size=i_font)
    table.cell(tablo,0,12,text="W/4H: "+ f_get_text(biasW),text_color=color.white,bgcolor=f_get_color(biasW),text_size=i_font)
    table.cell(tablo,0,13,text="M/1D: "+ f_get_text(biasM),text_color=color.white,bgcolor=f_get_color(biasM),text_size=i_font)
    table.cell(tablo,0,14,text="3M/1D: "+ f_get_text(biasQ),text_color=color.white,bgcolor=f_get_color(biasQ),text_size=i_font)
    table.cell(tablo,0,15,text="6M/1D: "+ f_get_text(biasH),text_color=color.white,bgcolor=f_get_color(biasH),text_size=i_font)

if not ignore
    if plot_conmtf and plot_conhtf
        bias1= ok1 ? request.security(s1,mtf,bias0) : na
        bias2= ok2 ? request.security(s2,mtf,bias0) : na
        bias3= ok3 ? request.security(s3,mtf,bias0) : na
        bias4= ok4 ? request.security(s4,mtf,bias0) : na
        bias5= ok5 ? request.security(s5,mtf,bias0) : na
        bias6= ok6 ? request.security(s6,mtf,bias0) : na
        bias7= ok7 ? request.security(s7,mtf,bias0) : na 
////////////////bullish alerts
        if bias1 == 1 and not (bias1[1] == 1) and not (bias1[1] == 11) and alert_ind and ok1 and alert_bull
            alert( s1 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Bullish Alarm', alert.freq_once_per_bar)
        if bias2 == 1 and not (bias2[1] == 1) and not (bias2[1] == 11) and alert_ind and ok2 and alert_bull
            alert( s2 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Bullish Alarm', alert.freq_once_per_bar)
        if bias3 == 1 and not (bias3[1] == 1) and not (bias3[1] == 11) and alert_ind and ok3 and alert_bull
            alert( s3 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Bullish Alarm', alert.freq_once_per_bar)
        if bias4 == 1 and not (bias4[1] == 1) and not (bias4[1] == 11) and alert_ind and ok4 and alert_bull
            alert( s4 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Bullish Alarm', alert.freq_once_per_bar)
        if bias5 == 1 and not (bias5[1] == 1) and not (bias5[1] == 11) and alert_ind and ok5 and alert_bull
            alert( s5 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Bullish Alarm', alert.freq_once_per_bar)
        if bias6 == 1 and not (bias6[1] == 1) and not (bias6[1] == 11) and alert_ind and ok6 and alert_bull
            alert( s6 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Bullish Alarm', alert.freq_once_per_bar)
        if bias7 == 1 and not (bias7[1] == 1) and not (bias7[1] == 11) and alert_ind and ok7 and alert_bull
            alert( s7 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Bullish Alarm', alert.freq_once_per_bar)
/////////////// bearish alerts
        if bias1 == -1 and not (bias1[1] == -1) and not (bias1[1] == -11) and alert_ind and ok1 and alert_bear
            alert(s1 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🔴 Bearish Alarm', alert.freq_once_per_bar)
        if bias2 == -1 and not (bias2[1] == -1) and not (bias2[1] == -11) and alert_ind and ok2 and alert_bear
            alert(s2 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🔴 Bearish Alarm', alert.freq_once_per_bar)
        if bias3 == -1 and not (bias3[1] == -1) and not (bias3[1] == -11)  and alert_ind and ok3 and alert_bear
            alert(s3 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🔴 Bearish Alarm', alert.freq_once_per_bar)
        if bias4 == -1 and not (bias4[1] == -1) and not (bias4[1] == -11) and alert_ind and ok4 and alert_bear
            alert(s4 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🔴 Bearish Alarm', alert.freq_once_per_bar)
        if bias5 == -1 and not (bias5[1] == -1) and not (bias5[1] == -11) and alert_ind and ok5 and alert_bear
            alert(s5 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🔴 Bearish Alarm', alert.freq_once_per_bar)
        if bias6 == -1 and not (bias6[1] == -1) and not (bias6[1] == -11) and alert_ind and ok6 and alert_bear
            alert(s6 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🔴 Bearish Alarm', alert.freq_once_per_bar)
        if bias7 == -1 and not (bias7[1] == -1)  and not (bias7[1] == -11) and alert_ind and ok7 and alert_bear
            alert(s7 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🔴 Bearish Alarm', alert.freq_once_per_bar)
////// strong bullish alerts
        if bias1 == 11 and not (bias1[1] == 11) and alert_ind and ok1 and alert_sbull
            alert( s1 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Strong Bullish Alarm', alert.freq_once_per_bar)
        if bias2 == 11 and not (bias2[1] == 11)  and alert_ind and ok2 and alert_sbull
            alert( s2 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Strong Bullish Alarm', alert.freq_once_per_bar)
        if bias3 == 11 and not (bias3[1] == 11)  and alert_ind and ok3 and alert_sbull
            alert( s3 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Strong Bullish Alarm', alert.freq_once_per_bar)
        if bias4 == 11 and not (bias4[1] == 11)  and alert_ind and ok4 and alert_sbull
            alert( s4 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Strong Bullish Alarm', alert.freq_once_per_bar)
        if bias5 == 11 and not (bias5[1] == 11)  and alert_ind and ok5 and alert_sbull
            alert( s5 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Strong Bullish Alarm', alert.freq_once_per_bar)
        if bias6 == 11 and not (bias6[1] == 11)   and alert_ind and ok6 and alert_sbull
            alert( s6 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Strong Bullish Alarm', alert.freq_once_per_bar)
        if bias7 == 11 and not (bias7[1] == 11)   and alert_ind and ok7 and alert_sbull
            alert( s7 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Strong Bullish Alarm', alert.freq_once_per_bar)
///////strong bearish
        if bias1 == -11 and not (bias1[1] == -11)   and alert_ind and ok1 and alert_sbear
