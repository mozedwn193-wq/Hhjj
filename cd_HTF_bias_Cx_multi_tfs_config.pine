        if bias2 == 1 and not (bias2[1] == 1) and not (bias2[1] == 11) and alert_ind and ok2 and alert_bull
            alert( s2 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Bullish Alarm', alert.freq_once_per_bar)
        if bias3 == 1 and not (bias3[1] == 1) and not (bias3[1] == 11) and alert_ind and ok3 and alert_bull
            alert( s3 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Bullish Alarm', alert.freq_once_per_bar)
        if bias4 == 1 and not (bias4[1] == 1) and not (bias4[1] == 11) and alert_ind and ok4 and alert_bull
            alert( s4 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Bullish Alarm', alert.freq_once_per_bar)
        if bias5 == 1 and not (bias5[1] == 1) and not (bias5[1] == 11) and alert_ind and ok5 and alert_bull
            alert( s5 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Bullish Alarm', alert.freq_once_per_bar)
        if bias6 == 1 and not (bias6[1] == 1) and not (bias6[1] == 11) and alert_ind and ok6 and alert_bull
            alert( s6 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Bullish Alarm', alert.freq_once_per_bar)
        if bias7 == 1 and not (bias7[1] == 1) and not (bias7[1] == 11) and alert_ind and ok7 and alert_bull
            alert( s7 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🟢 Bullish Alarm', alert.freq_once_per_bar)
        if bias1 == -1 and not (bias1[1] == -1) and not (bias1[1] == -11) and alert_ind and ok1 and alert_bear
            alert(s1 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🔴 Bearish Alarm', alert.freq_once_per_bar)
        if bias2 == -1 and not (bias2[1] == -1) and not (bias2[1] == -11) and alert_ind and ok2 and alert_bear
            alert(s2 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🔴 Bearish Alarm', alert.freq_once_per_bar)
        if bias3 == -1 and not (bias3[1] == -1) and not (bias3[1] == -11)  and alert_ind and ok3 and alert_bear
            alert(s3 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🔴 Bearish Alarm', alert.freq_once_per_bar)
        if bias4 == -1 and not (bias4[1] == -1) and not (bias4[1] == -11) and alert_ind and ok4 and alert_bear
            alert(s4 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🔴 Bearish Alarm', alert.freq_once_per_bar)
        if bias5 == -1 and not (bias5[1] == -1) and not (bias5[1] == -11) and alert_ind and ok5 and alert_bear
            alert(s5 + ',' + 'HTF : '+ f_text(htf)+'  MTF : '+ f_text(mtf)+ ',🔴 Bearish Alarm', alert.freq_once_per_bar)
