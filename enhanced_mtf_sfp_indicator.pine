pivot_high_color = input.color(color.orange, "Pivot High Color", group = g_SFP)
pivot_low_color = input.color(color.blue, "Pivot Low Color", group = g_SFP)

// Alert Options
var g_ALERT = "Alert Options"
alert_on_sfp    = input.bool(false, "Alert on SFP", group = g_ALERT)
