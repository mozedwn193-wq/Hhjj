//@version=5
indicator("Enhanced Order Blocks (EOB) - Simple", shorttitle="EOB", overlay=true, max_boxes_count=500, max_lines_count=500)

// ==========================================
// INPUT GROUPS
// ==========================================

// Confirmation Options
confirm_group = "🔍 CONFIRMATION OPTIONS"
wick_close_confirm = input.bool(true, "Wick Close Confirmation", tooltip="Confirmation candle must close beyond the wick", group=confirm_group)
body_close_confirm = input.bool(false, "Body Close Confirmation", tooltip="Confirmation candle must close beyond the body only", group=confirm_group)

// LTF EOB Visibility
ltf_visibility_group = "👁️ LTF EOB VISIBILITY"
ltf_width = input.int(2, "EOB Width", minval=1, maxval=5, group=ltf_visibility_group)

// EOB Features
features_group = "⚙️ EOB FEATURES"
show_eq = input.bool(true, "Add EQ of EOBs", tooltip="Show equilibrium line of order blocks", group=features_group)
extend_eob = input.bool(true, "Extended EOBs", tooltip="Extend EOB boxes to the right", group=features_group)
mitigation_threshold = input.float(0.5, "Mitigated When", minval=0.1, maxval=1.0, step=0.1, tooltip="0.5 = 50% fill, 1.0 = Full fill", group=features_group)
delete_mitigated = input.bool(false, "Delete Mitigated EOBs", tooltip="Remove EOBs when mitigated", group=features_group)

// Color Settings
color_group = "🎨 COLOR SETTINGS"
bullish_eob_color = input.color(color.new(color.green, 80), "Bullish EOB Color", group=color_group)
bearish_eob_color = input.color(color.new(color.red, 80), "Bearish EOB Color", group=color_group)
partially_mitigated_color = input.color(color.new(color.orange, 70), "Partially Mitigated Color", group=color_group)
eq_line_color = input.color(color.new(color.yellow, 50), "EQ Line Color", group=color_group)

// ==========================================
// FUNCTIONS
// ==========================================

// Function to identify Bearish EOB
is_bearish_eob(setup_candle_index, confirm_candle_index) =>
    // Setup candle: Bullish with decent bottom wick
    setup_open = open[setup_candle_index]
    setup_close = close[setup_candle_index]
    setup_high = high[setup_candle_index]
    setup_low = low[setup_candle_index]
    
    // Confirmation candle: Bearish engulfing
    confirm_open = open[confirm_candle_index]
    confirm_close = close[confirm_candle_index]
    
    // Setup candle conditions
    is_setup_bullish = setup_close > setup_open
    has_bottom_wick = (setup_open - setup_low) > (setup_close - setup_open) * 0.3 // Bottom wick at least 30% of body
    
    // Confirmation conditions
    is_confirm_bearish = confirm_close < confirm_open
    
    // Engulfing condition based on user preference
    engulfing_condition = if wick_close_confirm
        confirm_close < setup_low // Close below entire setup candle including wick
    else if body_close_confirm
        confirm_close < setup_open // Close below setup candle body
    else
        confirm_close < setup_close // Default: close below setup close
    
    is_setup_bullish and has_bottom_wick and is_confirm_bearish and engulfing_condition

// Function to identify Bullish EOB
is_bullish_eob(setup_candle_index, confirm_candle_index) =>
    // Setup candle: Bearish with decent top wick
    setup_open = open[setup_candle_index]
    setup_close = close[setup_candle_index]
    setup_high = high[setup_candle_index]
    setup_low = low[setup_candle_index]
    
    // Confirmation candle: Bullish engulfing
    confirm_open = open[confirm_candle_index]
    confirm_close = close[confirm_candle_index]
    
    // Setup candle conditions
    is_setup_bearish = setup_close < setup_open
    has_top_wick = (setup_high - setup_close) > (setup_open - setup_close) * 0.3 // Top wick at least 30% of body
    
    // Confirmation conditions
    is_confirm_bullish = confirm_close > confirm_open
    
    // Engulfing condition based on user preference
    engulfing_condition = if wick_close_confirm
        confirm_close > setup_high // Close above entire setup candle including wick
    else if body_close_confirm
        confirm_close > setup_open // Close above setup candle body
    else
        confirm_close > setup_close // Default: close above setup close
    
    is_setup_bearish and has_top_wick and is_confirm_bullish and engulfing_condition

// Function to create EOB box
create_eob_box(eob_top, eob_bottom, eob_left, eob_color, is_bullish) =>
    box_right = extend_eob ? bar_index + 20 : bar_index
    box.new(eob_left, eob_top, box_right, eob_bottom, 
             border_color=eob_color, 
             bgcolor=eob_color,
             border_width=ltf_width,
             extend=extend_eob ? extend.right : extend.none)

// Function to create EQ line
create_eq_line(eob_top, eob_bottom, eob_left) =>
    if show_eq
        eq_level = (eob_top + eob_bottom) / 2
        line_right = extend_eob ? bar_index + 20 : bar_index
        line.new(eob_left, eq_level, line_right, eq_level,
                 color=eq_line_color,
                 width=1,
                 style=line.style_dashed,
                 extend=extend_eob ? extend.right : extend.none)

// Function to check mitigation
check_mitigation(eob_top, eob_bottom, is_bullish) =>
    eob_range = eob_top - eob_bottom
    threshold_level = is_bullish ? eob_bottom + (eob_range * mitigation_threshold) : eob_top - (eob_range * mitigation_threshold)
    
    if is_bullish
        low <= threshold_level
    else
        high >= threshold_level

// ==========================================
// MAIN LOGIC
// ==========================================

// Current timeframe EOB detection
var box[] bullish_eobs = array.new<box>()
var box[] bearish_eobs = array.new<box>()
var line[] eq_lines = array.new<line>()

// Detect current timeframe EOBs
if barstate.isconfirmed
    // Bearish EOB
    if is_bearish_eob(1, 0)
        eob_top = high[1]
        eob_bottom = low[1]
        eob_left = bar_index[1]
        
        bearish_box = create_eob_box(eob_top, eob_bottom, eob_left, bearish_eob_color, false)
        array.push(bearish_eobs, bearish_box)
        
        if show_eq
            eq_line = create_eq_line(eob_top, eob_bottom, eob_left)
            array.push(eq_lines, eq_line)
    
    // Bullish EOB
    if is_bullish_eob(1, 0)
        eob_top = high[1]
        eob_bottom = low[1]
        eob_left = bar_index[1]
        
        bullish_box = create_eob_box(eob_top, eob_bottom, eob_left, bullish_eob_color, true)
        array.push(bullish_eobs, bullish_box)
        
        if show_eq
            eq_line = create_eq_line(eob_top, eob_bottom, eob_left)
            array.push(eq_lines, eq_line)

// ==========================================
// MITIGATION MANAGEMENT
// ==========================================

// Check for mitigation and update colors
if barstate.isconfirmed
    // Check bullish EOBs
    if array.size(bullish_eobs) > 0
        for i = array.size(bullish_eobs) - 1 to 0
            eob_box = array.get(bullish_eobs, i)
            if not na(eob_box)
                box_top = box.get_top(eob_box)
                box_bottom = box.get_bottom(eob_box)
                
                if check_mitigation(box_top, box_bottom, true)
                    if delete_mitigated
                        box.delete(eob_box)
                        array.remove(bullish_eobs, i)
                    else
                        box.set_bgcolor(eob_box, partially_mitigated_color)
                        box.set_border_color(eob_box, partially_mitigated_color)
    
    // Check bearish EOBs
    if array.size(bearish_eobs) > 0
        for i = array.size(bearish_eobs) - 1 to 0
            eob_box = array.get(bearish_eobs, i)
            if not na(eob_box)
                box_top = box.get_top(eob_box)
                box_bottom = box.get_bottom(eob_box)
                
                if check_mitigation(box_top, box_bottom, false)
                    if delete_mitigated
                        box.delete(eob_box)
                        array.remove(bearish_eobs, i)
                    else
                        box.set_bgcolor(eob_box, partially_mitigated_color)
                        box.set_border_color(eob_box, partially_mitigated_color)

// ==========================================
// ALERTS
// ==========================================

// Alert conditions
bearish_eob_formed = is_bearish_eob(1, 0)
bullish_eob_formed = is_bullish_eob(1, 0)

alertcondition(bearish_eob_formed, title="Bearish EOB Formed", message="🔴 Bearish Enhanced Order Block formed on {{ticker}} {{interval}}")
alertcondition(bullish_eob_formed, title="Bullish EOB Formed", message="🟢 Bullish Enhanced Order Block formed on {{ticker}} {{interval}}")

// ==========================================
// PLOTTING
// ==========================================

// Plot small markers for EOB formation
plotshape(bearish_eob_formed, title="Bearish EOB", location=location.abovebar, color=color.red, style=shape.triangledown, size=size.tiny)
plotshape(bullish_eob_formed, title="Bullish EOB", location=location.belowbar, color=color.green, style=shape.triangleup, size=size.tiny)

// Table for current EOB count
if barstate.islast
    var table info_table = table.new(position.top_right, 2, 3, bgcolor=color.white, border_width=1)
    table.cell(info_table, 0, 0, "EOB Type", text_color=color.black, text_size=size.small)
    table.cell(info_table, 1, 0, "Count", text_color=color.black, text_size=size.small)
    table.cell(info_table, 0, 1, "Bullish", text_color=color.green, text_size=size.small)
    table.cell(info_table, 1, 1, str.tostring(array.size(bullish_eobs)), text_color=color.black, text_size=size.small)
    table.cell(info_table, 0, 2, "Bearish", text_color=color.red, text_size=size.small)
    table.cell(info_table, 1, 2, str.tostring(array.size(bearish_eobs)), text_color=color.black, text_size=size.small)