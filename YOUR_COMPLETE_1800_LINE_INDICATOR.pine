//@version=6
indicator('Comprehensive Trading Indicator - CRT + FVG + CISD + 3x MACD + RSI DIVERGENCE + BOLLINGER BANDS', overlay = true, max_lines_count = 500, max_labels_count = 500, max_bars_back = 5000)

//==============================================================================
// ENHANCED SIGNAL FILTERING SETTINGS (Multiple Confirmation Methods)
//==============================================================================

var g_FILTER = "🔧 Signal Filtering"
enable_volume_filter = input.bool(false, "Enable Volume Filter", group=g_FILTER, tooltip="Only signals when volume is above average")
volume_multiplier = input.float(1.2, "Volume Multiplier", minval=0.5, maxval=3.0, step=0.1, group=g_FILTER)
enable_trend_filter = input.bool(true, "Enable Multi-Confirmation Trend Filter", group=g_FILTER, tooltip="Uses multiple methods for trend detection")
enable_confirmation = input.bool(false, "Enable Signal Confirmation", group=g_FILTER, tooltip="Wait for next bar confirmation")
min_signal_strength = input.int(50, "Minimum Signal Strength (%)", minval=30, maxval=90, group=g_FILTER)

var g_TREND = "📈 Multi-Confirmation Trend Detection"
use_rsi_divergence = input.bool(true, "Use RSI Divergence Detection", group=g_TREND, tooltip="RSI divergence helps detect trend reversals")
use_macd_trend = input.bool(true, "Use Triple MACD for Trend Confirmation", group=g_TREND, tooltip="3 MACD systems for comprehensive trend analysis")
use_price_action = input.bool(true, "Use Price Action Signals", group=g_TREND, tooltip="Higher highs/lows and breakouts")
use_volume_trend = input.bool(true, "Use Volume Trend Analysis", group=g_TREND, tooltip="Volume confirms trend strength")
use_structure_analysis = input.bool(true, "Use Market Structure Analysis", group=g_TREND, tooltip="Analyzes market structure for trend confirmation")
use_momentum_divergence = input.bool(true, "Use Momentum Divergence", group=g_TREND, tooltip="Detects trend exhaustion via divergence")
use_bollinger_bands = input.bool(true, "Use Bollinger Bands Analysis", group=g_TREND, tooltip="BB squeeze and breakout detection")
trend_sensitivity = input.string("Medium", "Trend Detection Sensitivity", options=["High", "Medium", "Low"], group=g_TREND, tooltip="High=Early signals, Low=Confirmed signals")

// 🎯 MULTI-CONFIRMATION REVERSAL DETECTION SETTINGS (ENHANCED)
var g_REVERSAL = "🔄 Multi-Confirmation Reversal Detection"
enable_reversal_filter = input.bool(true, "Enable Multi-Confirmation Reversal Filter", group=g_REVERSAL, tooltip="Uses multiple methods to confirm reversals")
reversal_confirmation_bars = input.int(3, "Reversal Confirmation Bars", minval=1, maxval=10, group=g_REVERSAL, tooltip="Bars needed to confirm reversal")
htf_trend_lookback = input.int(20, "HTF Trend Lookback", minval=10, maxval=50, group=g_REVERSAL, tooltip="Bars to analyze for HTF trend context")
min_reversal_strength = input.int(70, "Minimum Reversal Strength (%)", minval=50, maxval=95, group=g_REVERSAL, tooltip="Minimum strength for valid reversal")
min_confirmation_methods = input.int(3, "Minimum Confirmation Methods", minval=2, maxval=6, group=g_REVERSAL, tooltip="How many methods must agree for signal")

// Enhanced market analysis for filtering
volume_avg = ta.sma(volume, 20)
atr_value = ta.atr(14)

//==============================================================================
// SECTION 1: BREAKOUT DETECTION
//==============================================================================

// Inputs for Breakout Detection
length = input(14, "Lookbook Length", group="Breakout Detection")
threshold = input(1.5, "Range Multiplier", group="Breakout Detection")

// Calculate candle range
candleRange = high - low
averageRange = ta.sma(candleRange, length)

// Define conditions
bullishBreakout = candleRange > (averageRange * threshold) and close > open
bearishBreakout = candleRange > (averageRange * threshold) and close < open

// Plot signals
plotshape(series=bullishBreakout, location=location.belowbar, color=color.green, style=shape.labelup, title="Bullish Breakout")
plotshape(series=bearishBreakout, location=location.abovebar, color=color.red, style=shape.labeldown, title="Bearish Breakout")

// Highlight breakout candles
bgcolor(bullishBreakout ? color.new(color.green, 80) : bearishBreakout ? color.new(color.red, 80) : na)

//==============================================================================
// SECTION 2: MULTI-CONFIRMATION TREND ANALYSIS SYSTEM
//==============================================================================

// 🚀 METHOD 1: RSI DIVERGENCE DETECTION
rsi_length = input.int(14, "RSI Length", minval=2, group="RSI Divergence")
rsi_source = input.source(close, "RSI Source", group="RSI Divergence")
rsi_lookback = input.int(5, "Divergence Lookback", minval=2, maxval=20, group="RSI Divergence")

rsi = ta.rsi(rsi_source, rsi_length)

// Pivot detection for divergence
pivot_left = input.int(5, "Pivot Left", minval=1, group="RSI Divergence")
pivot_right = input.int(5, "Pivot Right", minval=1, group="RSI Divergence")

// Find pivots
ph = ta.pivothigh(rsi_lookback, rsi_lookback)
pl = ta.pivotlow(rsi_lookback, rsi_lookback)
ph_price = ta.pivothigh(high, rsi_lookback, rsi_lookback)
pl_price = ta.pivotlow(low, rsi_lookback, rsi_lookback)

// Divergence detection
var float last_ph_rsi = na
var float last_ph_price = na
var int last_ph_bar = na
var float last_pl_rsi = na
var float last_pl_price = na
var int last_pl_bar = na

// Bullish divergence (price makes lower low, RSI makes higher low)
bullish_divergence = false
if not na(pl) and not na(pl_price)
    if not na(last_pl_rsi) and not na(last_pl_price)
        if pl_price < last_pl_price and pl > last_pl_rsi and bar_index - last_pl_bar <= 50
            bullish_divergence := true
    last_pl_rsi := pl
    last_pl_price := pl_price
    last_pl_bar := bar_index

// Bearish divergence (price makes higher high, RSI makes lower high)
bearish_divergence = false
if not na(ph) and not na(ph_price)
    if not na(last_ph_rsi) and not na(last_ph_price)
        if ph_price > last_ph_price and ph < last_ph_rsi and bar_index - last_ph_bar <= 50
            bearish_divergence := true
    last_ph_rsi := ph
    last_ph_price := ph_price
    last_ph_bar := bar_index

// RSI-based signals
rsi_bullish = bullish_divergence or (rsi < 30 and rsi > rsi[1])
rsi_bearish = bearish_divergence or (rsi > 70 and rsi < rsi[1])

// 📈 METHOD 2: TRIPLE MACD SYSTEM
// MACD 1: Fast (13, 7, 21)
[macd_line_1, signal_line_1, macd_histogram_1] = ta.macd(close, 13, 7, 21)
macd_1_bullish = macd_line_1 > signal_line_1 and macd_line_1 > macd_line_1[1]
macd_1_bearish = macd_line_1 < signal_line_1 and macd_line_1 < macd_line_1[1]
macd_1_bullish_cross = ta.crossover(macd_line_1, signal_line_1)
macd_1_bearish_cross = ta.crossunder(macd_line_1, signal_line_1)

// MACD 2: Medium (13, 52, 18)
[macd_line_2, signal_line_2, macd_histogram_2] = ta.macd(close, 13, 52, 18)
macd_2_bullish = macd_line_2 > signal_line_2 and macd_line_2 > macd_line_2[1]
macd_2_bearish = macd_line_2 < signal_line_2 and macd_line_2 < macd_line_2[1]
macd_2_bullish_cross = ta.crossover(macd_line_2, signal_line_2)
macd_2_bearish_cross = ta.crossunder(macd_line_2, signal_line_2)

// MACD 3: Slow (52, 208, 72)
[macd_line_3, signal_line_3, macd_histogram_3] = ta.macd(close, 52, 208, 72)
macd_3_bullish = macd_line_3 > signal_line_3 and macd_line_3 > macd_line_3[1]
macd_3_bearish = macd_line_3 < signal_line_3 and macd_line_3 < macd_line_3[1]
macd_3_bullish_cross = ta.crossover(macd_line_3, signal_line_3)
macd_3_bearish_cross = ta.crossunder(macd_line_3, signal_line_3)

// Combined MACD signals (require at least 2 out of 3 to agree)
macd_bull_count = (macd_1_bullish or macd_1_bullish_cross ? 1 : 0) + (macd_2_bullish or macd_2_bullish_cross ? 1 : 0) + (macd_3_bullish or macd_3_bullish_cross ? 1 : 0)
macd_bear_count = (macd_1_bearish or macd_1_bearish_cross ? 1 : 0) + (macd_2_bearish or macd_2_bearish_cross ? 1 : 0) + (macd_3_bearish or macd_3_bearish_cross ? 1 : 0)

macd_bullish = macd_bull_count >= 2
macd_bearish = macd_bear_count >= 2
macd_bullish_cross = macd_1_bullish_cross or macd_2_bullish_cross or macd_3_bullish_cross
macd_bearish_cross = macd_1_bearish_cross or macd_2_bearish_cross or macd_3_bearish_cross

// 📊 METHOD 3: BOLLINGER BANDS ANALYSIS
bb_length = input.int(20, "BB Length", minval=1, group="Bollinger Bands")
bb_mult = input.float(2.0, "BB Multiplier", minval=0.1, step=0.1, group="Bollinger Bands")
bb_source = input.source(close, "BB Source", group="Bollinger Bands")

bb_basis = ta.sma(bb_source, bb_length)
bb_dev = bb_mult * ta.stdev(bb_source, bb_length)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev

// Plot Bollinger Bands
plot(bb_upper, title="BB Upper", color=color.blue, linewidth=1)
plot(bb_basis, title="BB Basis", color=color.orange, linewidth=1)
plot(bb_lower, title="BB Lower", color=color.blue, linewidth=1)
fill(plot(bb_upper), plot(bb_lower), color=color.new(color.blue, 95), title="BB Background")

// BB Analysis
bb_width = bb_upper - bb_lower
bb_width_avg = ta.sma(bb_width, 20)
bb_squeeze = bb_width < bb_width_avg * 0.8  // Squeeze when width is 80% of average
bb_expansion = bb_width > bb_width_avg * 1.2  // Expansion when width is 120% of average

bb_bullish = (close > bb_upper) or (close > bb_basis and close[1] <= bb_basis and bb_expansion)
bb_bearish = (close < bb_lower) or (close < bb_basis and close[1] >= bb_basis and bb_expansion)
bb_squeeze_breakout_bull = bb_squeeze[1] and not bb_squeeze and close > bb_basis
bb_squeeze_breakout_bear = bb_squeeze[1] and not bb_squeeze and close < bb_basis

// 🏗️ METHOD 4: MARKET STRUCTURE ANALYSIS (ENHANCED)
calculate_market_structure() =>
    // Higher Highs and Higher Lows analysis (lookback periods)
    short_lookback = 5
    medium_lookback = 10
    long_lookback = 20
    
    // Short-term structure
    hh_short = high > ta.highest(high[1], short_lookback)
    hl_short = low > ta.lowest(low[1], short_lookback)
    lh_short = high < ta.highest(high[1], short_lookback)
    ll_short = low < ta.lowest(low[1], short_lookback)
    
    // Medium-term structure
    hh_medium = high > ta.highest(high[1], medium_lookback)
    hl_medium = low > ta.lowest(low[1], medium_lookback)
    lh_medium = high < ta.highest(high[1], medium_lookback)
    ll_medium = low < ta.lowest(low[1], medium_lookback)
    
    // Long-term structure
    hh_long = high > ta.highest(high[1], long_lookback)
    hl_long = low > ta.lowest(low[1], long_lookback)
    lh_long = high < ta.highest(high[1], long_lookback)
    ll_long = low < ta.lowest(low[1], long_lookback)
    
    // Structure scoring system
    bullish_structure_score = 0
    bearish_structure_score = 0
    
    // Short-term structure votes
    if hh_short and hl_short
        bullish_structure_score += 1
    if lh_short and ll_short
        bearish_structure_score += 1
        
    // Medium-term structure votes  
    if hh_medium and hl_medium
        bullish_structure_score += 2
    if lh_medium and ll_medium
        bearish_structure_score += 2
        
    // Long-term structure votes
    if hh_long and hl_long
        bullish_structure_score += 3
    if lh_long and ll_long
        bearish_structure_score += 3
    
    // Structure signals
    structure_bullish = bullish_structure_score >= 3
    structure_bearish = bearish_structure_score >= 3
    
    [structure_bullish, structure_bearish, bullish_structure_score, bearish_structure_score]

[structure_bullish, structure_bearish, bull_structure_score, bear_structure_score] = calculate_market_structure()

// 📊 METHOD 5: VOLUME ANALYSIS
calculate_volume_analysis() =>
    // Volume trend analysis
    vol_sma_short = ta.sma(volume, 10)
    vol_sma_long = ta.sma(volume, 30)
    
    // Volume trend direction
    volume_trend_up = vol_sma_short > vol_sma_long and volume > vol_sma_short
    volume_trend_down = vol_sma_short < vol_sma_long and volume > vol_sma_short
    
    // Price-Volume relationship
    up_volume = close > open ? volume : 0
    down_volume = close < open ? volume : 0
    
    up_vol_avg = ta.sma(up_volume, 10)
    down_vol_avg = ta.sma(down_volume, 10)
    
    // Volume confirmation
    volume_confirms_bull = up_vol_avg > down_vol_avg and volume_trend_up
    volume_confirms_bear = down_vol_avg > up_vol_avg and volume_trend_down
    
    // On-Balance Volume (OBV) trend
    obv = ta.cum(close > close[1] ? volume : close < close[1] ? -volume : 0)
    obv_trend_bull = obv > ta.sma(obv, 20)
    obv_trend_bear = obv < ta.sma(obv, 20)
    
    volume_bullish = volume_confirms_bull and obv_trend_bull
    volume_bearish = volume_confirms_bear and obv_trend_bear
    
    [volume_bullish, volume_bearish, obv_trend_bull, obv_trend_bear]

[volume_bullish, volume_bearish, obv_bull, obv_bear] = calculate_volume_analysis()

// 🎯 MULTI-CONFIRMATION CONSENSUS SYSTEM
calculate_trend_consensus() =>
    bullish_votes = 0
    bearish_votes = 0
    
    // Method 1: RSI Divergence votes
    if use_rsi_divergence
        if rsi_bullish
            bullish_votes += 1
        if rsi_bearish
            bearish_votes += 1
    
    // Method 2: Triple MACD votes
    if use_macd_trend
        if macd_bullish or macd_bullish_cross
            bullish_votes += 1
        if macd_bearish or macd_bearish_cross
            bearish_votes += 1
    
    // Method 3: Bollinger Bands votes
    if use_bollinger_bands
        if bb_bullish or bb_squeeze_breakout_bull
            bullish_votes += 1
        if bb_bearish or bb_squeeze_breakout_bear
            bearish_votes += 1
    
    // Method 4: Market Structure votes
    if use_structure_analysis
        if structure_bullish
            bullish_votes += 1
        if structure_bearish
            bearish_votes += 1
    
    // Method 5: Volume Analysis votes
    if use_volume_trend
        if volume_bullish
            bullish_votes += 1
        if volume_bearish
            bearish_votes += 1
    
    // Consensus determination
    total_possible_votes = 5
    consensus_threshold = math.max(min_confirmation_methods, 3)
    
    strong_bullish_consensus = bullish_votes >= consensus_threshold and bullish_votes > bearish_votes
    strong_bearish_consensus = bearish_votes >= consensus_threshold and bearish_votes > bullish_votes
    
    // Trend strength based on vote margin
    vote_margin = math.abs(bullish_votes - bearish_votes)
    trend_strength = math.round((vote_margin / total_possible_votes) * 100)
    
    [strong_bullish_consensus, strong_bearish_consensus, bullish_votes, bearish_votes, trend_strength]

[bullish_consensus, bearish_consensus, bull_votes, bear_votes, trend_strength] = calculate_trend_consensus()

// Enhanced Function to check if signal aligns with trend
trend_aligned_signal(is_bullish_signal) =>
    if not enable_trend_filter
        true
    else if is_bullish_signal
        bullish_consensus or (bull_votes >= 2)
    else
        bearish_consensus or (bear_votes >= 2)

// Final trend decisions
bullish_trend = bullish_consensus
bearish_trend = bearish_consensus
sideways_trend = not bullish_consensus and not bearish_consensus

//==============================================================================
// SECTION 3: FAIR VALUE GAP (FVG) DETECTION - SESSION BASED
//==============================================================================

// Define session times
sess = input.session("0932-1600", title="Session", tooltip="A 9:30 FVG can start at 9:30 but takes 3 candles to form", group="FVG Settings")
// User input for box color
boxColorUp = input.color(color.new(color.green, 80), "Box Color Up", group="FVG Settings")
boxColorDn = input.color(color.new(color.red, 80), "Box Color Down", group="FVG Settings")
max_days = input.int(3, title="Max # of days to draw", group="FVG Settings")
drawOpenTime = input.bool(true, title="Draw 9:30 NY open vertical line", group="FVG Settings")
drawOpenPrice = input.bool(true, title="Draw 9:30 opening price", group="FVG Settings")

//lines, boxes and labels
var timezone = "America/New_York"
var boxes = array.new<box>()
var ny_open_labels = array.new<box>()
var labels = array.new<label>()
var ny_open_prices = array.new<line>()
var ny_open_times = array.new<line>()
var ny_930_labels = array.new<label>()

var box ny_open_label = na
var box fvg_box = na
var line ny_open_time = na
var line ny_open_price = na
var label ny_930_label = na
var label fvg_lb = na
var bool first_fvg_found = false

boxColor = color.new(color.gray, 80)
is_target_time = (hour(time, timezone) == 8 and minute == 30) // CME servers in Chicago (CST). 9:30 EST = 8:30 CST
lowest_so_far = ta.lowest(50) - 5*ta.atr(14)

// Get day of week in text
day_of_week_text() =>
     dayofweek == dayofweek.monday    ? "Mon" :
     dayofweek == dayofweek.tuesday   ? "Tue" :
     dayofweek == dayofweek.wednesday ? "Wed" :
     dayofweek == dayofweek.thursday  ? "Thu" :
     dayofweek == dayofweek.friday    ? "Fri" :
     dayofweek == dayofweek.saturday  ? "Sat" :
     dayofweek == dayofweek.sunday    ? "Sun" : "N/A"

// Box creation
make_box(_left, _right, _top, _bottom, col) =>
    box.new(left=_left, right=_right, top=_top, bottom=_bottom, border_color=color.new(col, 70), bgcolor=col, text="1st FVG - " + day_of_week_text(), text_halign = text.align_right, text_size=size.small, text_color = color.black)

// Manage array of lines and labels
manage_lines(li_time, li_price, lb_price, lb_930) =>
    array.push(ny_open_times, li_time)
    array.push(ny_open_prices, li_price)
    array.push(ny_open_labels, lb_price)
    array.push(ny_930_labels, lb_930)
    if array.size(ny_open_times) > max_days
        line.delete(array.shift(ny_open_prices))
        line.delete(array.shift(ny_open_times))
        box.delete(array.shift(ny_open_labels))
        label.delete(array.shift(ny_930_labels))

// Manage array of boxes
manage_boxes(b) =>
    array.push(boxes, b)
    if array.size(boxes) > max_days
        box.delete(array.shift(boxes))

// Update FVG box
update_box(b) =>
    box.set_right(b, bar_index+10)

//@function calculates session valid times
in_session(sess) => not na(time(timeframe.period, sess, timezone))

// Core Logic
if in_session(sess) 
    if not first_fvg_found
        // FVG condition
        fvgUp   = close[1] > open[1] and high[2] < low[0]
        fvgDown = close[1] < open[1] and low[2] > high[0]
        if fvgUp or fvgDown
            first_fvg_found := true
            boxColor := fvgUp ? boxColorUp : boxColorDn
            // Define box coordinates
            boxTop      = fvgUp ? high[2] : low[2]
            boxBottom   = fvgUp ? low[0] : high[0]

            // Create the box
            fvg_box := make_box(bar_index-2, bar_index + 5, boxTop, boxBottom, boxColor)
            manage_boxes(fvg_box)

// Reset FVG flag at the end of the session
if not in_session(sess) and in_session(sess)[1]
    first_fvg_found := false

// Extend the box to session end
if first_fvg_found and na(fvg_box) == false
    update_box(fvg_box)

//Draw NY Open at 9:30 am EST / NY Time
if is_target_time
    if drawOpenTime
        ny_open_time    := line.new(x1=time, y1=high, x2=time, y2=low, xloc=xloc.bar_time, color=color.gray, style=line.style_dashed, width=1, extend = extend.both)
        ny_930_label    := label.new(x=bar_index, y=lowest_so_far, text="9:30", style=label.style_none, color=color.new(color.gray, 90), textcolor=color.black)
        manage_lines(ny_open_time, ny_open_price, ny_open_label, ny_930_label)
    if drawOpenPrice
        ny_open_price   := line.new(x1=bar_index, y1=open, x2=bar_index + 10, y2=open, xloc=xloc.bar_index, color=color.gray, style=line.style_dotted, width=1, extend = extend.none)
        ny_open_label   := box.new(left=bar_index+25, top=open+10, 
         right=bar_index + 55, 
         bottom=open-10, 
         text = day_of_week_text() + " NY Open - " + str.format("{0,number,#,###.00}", close), 
         bgcolor=color.new(color.white, 100), 
         text_halign = text.align_right, 
         text_size = size.small, 
         text_color = color.black, 
         border_color = color.new(color.white, 50))
    
// Keep extended objects until end of the session
if in_session(sess)
    box.set_right(ny_open_label, bar_index + 55)
    line.set_x2(ny_open_price, bar_index + 20)

//==============================================================================
// MULTI-CONFIRMATION ANALYSIS DASHBOARD
//==============================================================================

var g_MULTI_DASHBOARD = "🎯 Multi-Confirmation Dashboard"
show_multi_dashboard = input.bool(true, "Show Multi-Confirmation Dashboard", group=g_MULTI_DASHBOARD)

if show_multi_dashboard and barstate.islast
    var table multi_table = table.new(position.top_right, 4, 7, bgcolor=color.new(color.black, 85), border_width=1)
    
    // Header
    table.cell(multi_table, 0, 0, "🎯 MULTI-CONFIRMATION", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 70))
    table.cell(multi_table, 1, 0, "BULLISH", text_color=color.lime, text_size=size.normal, bgcolor=color.new(color.blue, 70))
    table.cell(multi_table, 2, 0, "BEARISH", text_color=color.red, text_size=size.normal, bgcolor=color.new(color.blue, 70))
    table.cell(multi_table, 3, 0, "STATUS", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 70))
    
    // RSI Divergence Analysis
    table.cell(multi_table, 0, 1, "⚡ RSI DIV", text_color=color.white, text_size=size.small)
    rsi_bull_text = rsi_bullish ? "✅" : "❌"
    rsi_bear_text = rsi_bearish ? "✅" : "❌"
    rsi_status = bullish_divergence ? "BULL DIV" : bearish_divergence ? "BEAR DIV" : rsi > 70 ? "OB" : rsi < 30 ? "OS" : "MID"
    table.cell(multi_table, 1, 1, rsi_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 1, rsi_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 1, rsi_status, text_color=color.white, text_size=size.small)
    
    // Triple MACD Analysis
    table.cell(multi_table, 0, 2, "📈 3x MACD", text_color=color.white, text_size=size.small)
    macd_bull_text = (macd_bullish or macd_bullish_cross) ? "✅" : "❌"
    macd_bear_text = (macd_bearish or macd_bearish_cross) ? "✅" : "❌"
    macd_status = str.tostring(macd_bull_count) + ":" + str.tostring(macd_bear_count)
    table.cell(multi_table, 1, 2, macd_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 2, macd_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 2, macd_status, text_color=color.white, text_size=size.small)
    
    // Bollinger Bands Analysis
    table.cell(multi_table, 0, 3, "📊 BB", text_color=color.white, text_size=size.small)
    bb_bull_text = (bb_bullish or bb_squeeze_breakout_bull) ? "✅" : "❌"
    bb_bear_text = (bb_bearish or bb_squeeze_breakout_bear) ? "✅" : "❌"
    bb_status = bb_squeeze ? "SQUEEZE" : bb_expansion ? "EXPAND" : "NORMAL"
    table.cell(multi_table, 1, 3, bb_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 3, bb_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 3, bb_status, text_color=color.white, text_size=size.small)
    
    // Market Structure Analysis
    table.cell(multi_table, 0, 4, "🏗️ Structure", text_color=color.white, text_size=size.small)
    struct_bull_text = structure_bullish ? "✅" : "❌"
    struct_bear_text = structure_bearish ? "✅" : "❌"
    struct_status = str.tostring(bull_structure_score) + ":" + str.tostring(bear_structure_score)
    table.cell(multi_table, 1, 4, struct_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 4, struct_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 4, struct_status, text_color=color.white, text_size=size.small)
    
    // Volume Analysis
    table.cell(multi_table, 0, 5, "📊 Volume", text_color=color.white, text_size=size.small)
    vol_bull_text = volume_bullish ? "✅" : "❌"
    vol_bear_text = volume_bearish ? "✅" : "❌"
    vol_status = obv_bull ? "OBV+" : obv_bear ? "OBV-" : "OBV="
    table.cell(multi_table, 1, 5, vol_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 5, vol_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 5, vol_status, text_color=color.white, text_size=size.small)
    
    // Final Consensus
    table.cell(multi_table, 0, 6, "🎯 CONSENSUS", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.purple, 70))
    table.cell(multi_table, 1, 6, str.tostring(bull_votes), text_color=color.lime, text_size=size.normal, bgcolor=color.new(color.purple, 70))
    table.cell(multi_table, 2, 6, str.tostring(bear_votes), text_color=color.red, text_size=size.normal, bgcolor=color.new(color.purple, 70))
    table.cell(multi_table, 3, 6, str.tostring(trend_strength) + "%", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.purple, 70))

// Show current trend status on chart
var label trend_label = na
if barstate.islast
    if not na(trend_label)
        label.delete(trend_label)
    
    trend_text = ""
    trend_color = color.gray
    
    if bullish_consensus
        trend_text := "📈 BULLISH CONSENSUS [" + str.tostring(bull_votes) + " votes]"
        trend_color := color.new(color.lime, 20)
    else if bearish_consensus
        trend_text := "📉 BEARISH CONSENSUS [" + str.tostring(bear_votes) + " votes]"
        trend_color := color.new(color.red, 20)
    else
        trend_text := "⚠️ NO CONSENSUS [" + str.tostring(bull_votes) + "v" + str.tostring(bear_votes) + "]"
        trend_color := color.new(color.yellow, 30)
    
    trend_label := label.new(bar_index, high + ta.atr(14), text=trend_text, style=label.style_label_down, color=trend_color, textcolor=color.white, size=size.normal)

//==============================================================================
