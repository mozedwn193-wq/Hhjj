//==============================================================================
// ENHANCED TREND STATUS DISPLAY WITH MULTI-CONFIRMATION (NO EMA DEPENDENCY)
//==============================================================================

// Show current trend status on chart with multi-confirmation system
var label trend_label = na
if barstate.islast
    if not na(trend_label)
        label.delete(trend_label)
    
    trend_text = ""
    trend_color = color.gray
    
    if true_bullish_reversal
        trend_text := "🔄 MULTI-CONFIRMED BULLISH REVERSAL [" + str.tostring(bull_votes) + " votes]"
        trend_color := color.new(color.lime, 0)
    else if true_bearish_reversal
        trend_text := "🔄 MULTI-CONFIRMED BEARISH REVERSAL [" + str.tostring(bear_votes) + " votes]"
        trend_color := color.new(color.red, 0)
    else if bullish_continuation
        trend_text := "➡️ BULLISH CONTINUATION [" + str.tostring(bull_votes) + " votes]"
        trend_color := color.new(color.green, 20)
    else if bearish_continuation
        trend_text := "➡️ BEARISH CONTINUATION [" + str.tostring(bear_votes) + " votes]"
        trend_color := color.new(color.red, 20)
    else if new_bullish_trend
        trend_text := "🚀 NEW BULLISH TREND [" + str.tostring(bull_votes) + " votes]"
        trend_color := color.new(color.lime, 0)
    else if new_bearish_trend
        trend_text := "🚀 NEW BEARISH TREND [" + str.tostring(bear_votes) + " votes]"
        trend_color := color.new(color.red, 0)
    else if strong_bullish_trend
        trend_text := "💪 STRONG BULLISH CONSENSUS [" + str.tostring(bull_votes) + " votes]"
        trend_color := color.new(color.lime, 20)
    else if strong_bearish_trend
        trend_text := "💪 STRONG BEARISH CONSENSUS [" + str.tostring(bear_votes) + " votes]"
        trend_color := color.new(color.red, 20)
    else if bullish_trend
        trend_text := "📈 BULLISH CONSENSUS [" + str.tostring(bull_votes) + " votes]"
        trend_color := color.new(color.green, 30)
    else if bearish_trend
        trend_text := "📉 BEARISH CONSENSUS [" + str.tostring(bear_votes) + " votes]"
        trend_color := color.new(color.red, 30)
    else
        trend_text := "⚠️ NO CONSENSUS [" + str.tostring(bull_votes) + "v" + str.tostring(bear_votes) + "]"
        trend_color := color.new(color.yellow, 30)
    
    trend_label := label.new(bar_index, high + ta.atr(14), text=trend_text, style=label.style_label_down, color=trend_color, textcolor=color.white, size=size.normal)

//==============================================================================
// MULTI-CONFIRMATION ANALYSIS DASHBOARD (NEW)
//==============================================================================

var g_MULTI_DASHBOARD = "🎯 Multi-Confirmation Dashboard"
show_multi_dashboard = input.bool(true, "Show Multi-Confirmation Dashboard", group=g_MULTI_DASHBOARD)

if show_multi_dashboard and barstate.islast
    var table multi_table = table.new(position.top_right, 4, 8, bgcolor=color.new(color.black, 85), border_width=1)
    
    // Header
    table.cell(multi_table, 0, 0, "🎯 MULTI-CONFIRMATION", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 70))
    table.cell(multi_table, 1, 0, "BULLISH", text_color=color.lime, text_size=size.normal, bgcolor=color.new(color.blue, 70))
    table.cell(multi_table, 2, 0, "BEARISH", text_color=color.red, text_size=size.normal, bgcolor=color.new(color.blue, 70))
    table.cell(multi_table, 3, 0, "STATUS", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 70))
    
    // RSI Analysis
    table.cell(multi_table, 0, 1, "⚡ RSI", text_color=color.white, text_size=size.small)
    rsi_bull_text = (rsi_bullish or rsi_oversold_bounce) ? "✅" : "❌"
    rsi_bear_text = (rsi_bearish or rsi_overbought_drop) ? "✅" : "❌"
    rsi_status = rsi > 70 ? "OB" : rsi < 30 ? "OS" : "MID"
    table.cell(multi_table, 1, 1, rsi_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 1, rsi_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 1, rsi_status, text_color=color.white, text_size=size.small)
    
    // MACD Analysis
    table.cell(multi_table, 0, 2, "📈 MACD", text_color=color.white, text_size=size.small)
    macd_bull_text = (macd_bullish or macd_bullish_cross) ? "✅" : "❌"
    macd_bear_text = (macd_bearish or macd_bearish_cross) ? "✅" : "❌"
    macd_status = macd_line > signal_line ? "+" : "-"
    table.cell(multi_table, 1, 2, macd_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 2, macd_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 2, macd_status, text_color=color.white, text_size=size.small)
    
    // Market Structure Analysis
    table.cell(multi_table, 0, 3, "🏗️ Structure", text_color=color.white, text_size=size.small)
    struct_bull_text = (structure_bullish or resistance_break) ? "✅" : "❌"
    struct_bear_text = (structure_bearish or support_break) ? "✅" : "❌"
    struct_status = str.tostring(bull_structure_score) + ":" + str.tostring(bear_structure_score)
    table.cell(multi_table, 1, 3, struct_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 3, struct_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 3, struct_status, text_color=color.white, text_size=size.small)
    
    // Volume Profile Analysis
    table.cell(multi_table, 0, 4, "📊 Volume", text_color=color.white, text_size=size.small)
    vol_bull_text = volume_bullish ? "✅" : "❌"
    vol_bear_text = volume_bearish ? "✅" : "❌"
    vol_status = obv_bull ? "OBV+" : obv_bear ? "OBV-" : "OBV="
    table.cell(multi_table, 1, 4, vol_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 4, vol_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 4, vol_status, text_color=color.white, text_size=size.small)
    
    // Momentum Divergence Analysis
    table.cell(multi_table, 0, 5, "⚡ Momentum", text_color=color.white, text_size=size.small)
    mom_bull_text = (momentum_bullish or bullish_divergence) ? "✅" : "❌"
    mom_bear_text = (momentum_bearish or bearish_divergence) ? "✅" : "❌"
    mom_status = bullish_divergence ? "DIV+" : bearish_divergence ? "DIV-" : "SYNC"
    table.cell(multi_table, 1, 5, mom_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 5, mom_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 5, mom_status, text_color=color.white, text_size=size.small)
    
    // HTF Price Action Analysis
    table.cell(multi_table, 0, 6, "📐 HTF Action", text_color=color.white, text_size=size.small)
    htf_bull_text = (daily_uptrend and weekly_uptrend) ? "✅" : "❌"
    htf_bear_text = (daily_downtrend and weekly_downtrend) ? "✅" : "❌"
    htf_status = str.tostring(daily_bull_count) + "D:" + str.tostring(daily_bear_count)
    table.cell(multi_table, 1, 6, htf_bull_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 2, 6, htf_bear_text, text_color=color.white, text_size=size.small)
    table.cell(multi_table, 3, 6, htf_status, text_color=color.white, text_size=size.small)
    
    // Final Consensus
    table.cell(multi_table, 0, 7, "🎯 CONSENSUS", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.purple, 70))
    table.cell(multi_table, 1, 7, str.tostring(bull_votes), text_color=color.lime, text_size=size.normal, bgcolor=color.new(color.purple, 70))
    table.cell(multi_table, 2, 7, str.tostring(bear_votes), text_color=color.red, text_size=size.normal, bgcolor=color.new(color.purple, 70))
    table.cell(multi_table, 3, 7, str.tostring(trend_strength) + "%", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.purple, 70))

// NOTE: Sections 5-8 would continue with all original functionality preserved
// This includes Advanced FVG, CISD, CRT Time Analysis, and HTF Candles
// All sections maintain their original functionality while benefiting from the new multi-confirmation system

//==============================================================================
// SECTION 5: ADVANCED FVG DETECTION WITH MITIGATION
//==============================================================================

//Settings
thresholdPer = input.float(0, "Threshold %", minval = 0, maxval = 100, step = .1, inline = 'threshold', group="Advanced FVG")
auto = input(false, "Auto", inline = 'threshold', group="Advanced FVG")

showLast = input.int(0, 'Unmitigated Levels', minval = 0, group="Advanced FVG")
mitigationLevels = input.bool(false, 'Mitigation Levels', group="Advanced FVG")

tf = input.timeframe('', "Timeframe", group="Advanced FVG")

//Style
extend = input.int(20, 'Extend', minval = 0, inline = 'extend', group = 'Advanced FVG Style')
dynamic = input(false, 'Dynamic', inline = 'extend', group = 'Advanced FVG Style')

bullCss = input.color(color.new(#089981, 70), "Bullish FVG", group = 'Advanced FVG Style')
bearCss = input.color(color.new(#f23645, 70), "Bearish FVG", group = 'Advanced FVG Style')

//Dashboard
showDash  = input(false, 'Show Dashboard', group = 'Advanced FVG Dashboard')
dashLoc  = input.string('Top Right', 'Location', options = ['Top Right', 'Bottom Right', 'Bottom Left'], group = 'Advanced FVG Dashboard')
textSize = input.string('Small', 'Size'        , options = ['Tiny', 'Small', 'Normal']                 , group = 'Advanced FVG Dashboard')

//UDT's
type fvg
    float max
    float min
    bool  isbull
    int   t = time

//Methods/Functions
n = bar_index

method tosolid(color id)=> color.rgb(color.r(id),color.g(id),color.b(id))

detect()=>
    var fvg new_fvg = fvg.new(na, na, false, na)
    threshold = auto ? ta.cum((high - low) / low) / bar_index : thresholdPer / 100

    bull_fvg = low > high[2] and close[1] > high[2] and (low - high[2]) / high[2] > threshold
    bear_fvg = high < low[2] and close[1] < low[2] and (low[2] - high) / high > threshold
    
    if bull_fvg
        new_fvg := fvg.new(low, high[2], true)
    else if bear_fvg
        new_fvg := fvg.new(low[2], high, false)

    [bull_fvg, bear_fvg, new_fvg]

//FVG's detection/display
var float max_bull_fvg = na, var float min_bull_fvg = na, var bull_count = 0, var bull_mitigated = 0
var float max_bear_fvg = na, var float min_bear_fvg = na, var bear_count = 0, var bear_mitigated = 0
var t = 0

var fvg_records = array.new<fvg>(0)
var fvg_areas = array.new<box>(0)

fvg_data = request.security(syminfo.tickerid, tf, detect())
bull_fvg = array.get(fvg_data, 0)
bear_fvg = array.get(fvg_data, 1)
new_fvg = array.get(fvg_data, 2)

//Bull FVG's
if bull_fvg and new_fvg.t != t
    if dynamic
        max_bull_fvg := new_fvg.max
        min_bull_fvg := new_fvg.min
    
    //Populate FVG array
    if not dynamic
        fvg_areas.unshift(box.new(n-2, new_fvg.max, n+extend, new_fvg.min, na, bgcolor = bullCss))
    fvg_records.unshift(new_fvg)

    bull_count += 1
    t := new_fvg.t
else if dynamic
    max_bull_fvg := math.max(math.min(close, max_bull_fvg), min_bull_fvg)

//Bear FVG's
if bear_fvg and new_fvg.t != t
    if dynamic
        max_bear_fvg := new_fvg.max
        min_bear_fvg := new_fvg.min
    
    //Populate FVG array
    if not dynamic
        fvg_areas.unshift(box.new(n-2, new_fvg.max, n+extend, new_fvg.min, na, bgcolor = bearCss))
    fvg_records.unshift(new_fvg)

    bear_count += 1
    t := new_fvg.t
else if dynamic
    min_bear_fvg := math.min(math.max(close, min_bear_fvg), max_bear_fvg) 

//Unmitigated/Mitigated lines
//Test for mitigation
if fvg_records.size() > 0
    for i = fvg_records.size()-1 to 0
        get = fvg_records.get(i)

        if get.isbull
            if close < get.min
                //Display line if mitigated
                if mitigationLevels
                    line.new(get.t
                      , get.min
                      , time
                      , get.min
                      , xloc.bar_time
                      , color = bullCss
                      , style = line.style_dashed)

                //Delete box
                if not dynamic
                    area = fvg_areas.remove(i)
                    area.delete()

                fvg_records.remove(i)
                bull_mitigated += 1
        else if close > get.max
            //Display line if mitigated
            if mitigationLevels
                line.new(get.t
                  , get.max
                  , time
                  , get.max
                  , xloc.bar_time
                  , color = bearCss
                  , style = line.style_dashed)

            //Delete box
            if not dynamic
                area = fvg_areas.remove(i)
                area.delete()
            
            fvg_records.remove(i)
            bear_mitigated += 1

//Unmitigated lines
var unmitigated = array.new<line>(0)

//Remove umitigated lines 
if barstate.islast and showLast > 0 and fvg_records.size() > 0
    if unmitigated.size() > 0 
        for element in unmitigated
            element.delete()
        unmitigated.clear()

    for i = 0 to math.min(showLast-1, fvg_records.size()-1)
        get = fvg_records.get(i)

        unmitigated.push(line.new(get.t
          , get.isbull ? get.min : get.max 
          , time
          , get.isbull ? get.min : get.max
          , xloc.bar_time
          , color = get.isbull ? bullCss : bearCss))

//Dashboard
var table_position = dashLoc == 'Bottom Left' ? position.bottom_left 
  : dashLoc == 'Top Right' ? position.top_right 
  : position.bottom_right

var table_size = textSize == 'Tiny' ? size.tiny 
  : textSize == 'Small' ? size.small 
  : size.normal

var tb = table.new(table_position, 3, 3
  , bgcolor = #1e222d
  , border_color = #373a46
  , border_width = 1
  , frame_color = #373a46
  , frame_width = 1)

if showDash
    if barstate.isfirst
        tb.cell(1, 0, 'Bullish', text_color = bullCss.tosolid(), text_size = table_size)
        tb.cell(2, 0, 'Bearish', text_color = bearCss.tosolid(), text_size = table_size)
    
        tb.cell(0, 1, 'Count', text_size = table_size, text_color = color.white)
        tb.cell(0, 2, 'Mitigated', text_size = table_size, text_color = color.white)
    
    if barstate.islast
        tb.cell(1, 1, str.tostring(bull_count), text_color = bullCss.tosolid(), text_size = table_size)
        tb.cell(2, 1, str.tostring(bear_count), text_color = bearCss.tosolid(), text_size = table_size)
        
        tb.cell(1, 2, str.tostring(bull_mitigated / bull_count * 100, format.percent), text_color = bullCss.tosolid(), text_size = table_size)
        tb.cell(2, 2, str.tostring(bear_mitigated / bear_count * 100, format.percent), text_color = bearCss.tosolid(), text_size = table_size)

//Plots
//Dynamic Bull FVG
max_bull_plot = plot(max_bull_fvg, color = na)
min_bull_plot = plot(min_bull_fvg, color = na)
fill(max_bull_plot, min_bull_plot, color = bullCss)

//Dynamic Bear FVG
max_bear_plot = plot(max_bear_fvg, color = na)
min_bear_plot = plot(min_bear_fvg, color = na)
fill(max_bear_plot, min_bear_plot, color = bearCss)

//Alerts
alertcondition(bull_count > bull_count[1], 'Bullish FVG', 'Bullish FVG detected')
alertcondition(bear_count > bear_count[1], 'Bearish FVG', 'Bearish FVG detected')

alertcondition(bull_mitigated > bull_mitigated[1], 'Bullish FVG Mitigation', 'Bullish FVG mitigated')
alertcondition(bear_mitigated > bear_mitigated[1], 'Bearish FVG Mitigation', 'Bearish FVG mitigated')

//==============================================================================
// SECTION 6: CISD (CHANGE IN STATE OF DELIVERY) DETECTION
//==============================================================================

// CISD Input Settings
var string G_CISD_SETTINGS = "CISD Settings"
showLabels = input.bool(true, "Show Labels", group=G_CISD_SETTINGS)
lineColor = input.color(color.black, "CISD Line Color", group=G_CISD_SETTINGS)
textColor = input.color(color.black, "Label Color", group=G_CISD_SETTINGS)
lineWidth = input.int(2, "Line Width", minval=1, maxval=4, group=G_CISD_SETTINGS)
lineStyle = input.string("Solid", "Line Style", options=["Solid", "Dashed", "Dotted"], group=G_CISD_SETTINGS)
lineLength = input.int(15, "Line Extension (bars)", minval=5, maxval=50, group=G_CISD_SETTINGS)
labelSizex = input.string("Small", "Label Size", options=["Tiny", "Small", "Normal", "Large"], group=G_CISD_SETTINGS)

// Variables for CISD Detection
var line[] cisdLines = array.new_line()
var label[] cisdLabels = array.new_label()

// Variables for sequence tracking
var float sequenceStartPrice = na
var int sequenceStartIndex = na
var bool waitingForDisplacement = false
var float[] priorBullishOpens = array.new_float()  // Store opens of prior bullish candles
var float[] priorBearishOpens = array.new_float()  // Store opens of prior bearish candles
var int lastBullishStart = na  // Index where last bullish sequence started
var int lastBearishStart = na  // Index where last bearish sequence started

// Liquidity Detection Variables
var swingStrength = 3
var float[] bslPrices = array.new_float()
var float[] sslPrices = array.new_float()
var int[] bslTimes = array.new_int()
var int[] sslTimes = array.new_int()

// Function to get label size from input
getLabelSizex() =>
    switch labelSizex
        "Tiny" => size.tiny
        "Small" => size.small
        "Normal" => size.normal
        "Large" => size.large
        => size.small

// Function to detect and manage liquidity levels
manageLiquidityLevels() =>
    float ph = ta.pivothigh(swingStrength, swingStrength)
    float pl = ta.pivotlow(swingStrength, swingStrength)
    
    if not na(ph)
        array.push(bslPrices, ph)
        array.push(bslTimes, bar_index[swingStrength])
    
    if not na(pl)
        array.push(sslPrices, pl)
        array.push(sslTimes, bar_index[swingStrength])

// Function to check for liquidity sweeps
checkLiquiditySweep() =>
    bool bslSwept = false
    bool sslSwept = false
    
    if array.size(bslPrices) > 0
        for i = array.size(bslPrices) - 1 to 0
            if high > array.get(bslPrices, i)
                bslSwept := true
                array.remove(bslPrices, i)
                array.remove(bslTimes, i)
                break
    
    if array.size(sslPrices) > 0
        for i = array.size(sslPrices) - 1 to 0
            if low < array.get(sslPrices, i)
                sslSwept := true
                array.remove(sslPrices, i)
                array.remove(sslTimes, i)
                break
    
    [bslSwept, sslSwept]

// Function to draw CISD
drawCisd(startPrice, startIndex, isBull) =>
    chosenStyle = switch lineStyle
        "Solid" => line.style_solid
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid
    
    newLine = line.new(startIndex, startPrice, bar_index + lineLength, startPrice,
         color=lineColor,
         style=chosenStyle,
         width=lineWidth,
         extend=extend.none)
    array.push(cisdLines, newLine)
    
    if showLabels
        newLabel = label.new(bar_index + 2, startPrice,
             text=isBull ? "CISD+" : "CISD-",
             style=label.style_none,
             textcolor=textColor,
             size=getLabelSizex(),
             textalign=text.align_left)
        array.push(cisdLabels, newLabel)

// Function to find most recent sequence of same-direction candles
findRecentSequence(bull) =>
    var int count = 0
    var float firstOpen = na
    var int firstIndex = na
    
    if bull
        if close > open  // Current candle is bullish
            if count == 0 or close[1] <= open[1]  // Start of new sequence
                count := 1
                firstOpen := open
                firstIndex := bar_index
            else
                count := count + 1
        else
            if count > 0  // End of sequence
                firstOpen := na
                firstIndex := na
            count := 0
    else
        if close < open  // Current candle is bearish
            if count == 0 or close[1] >= open[1]  // Start of new sequence
                count := 1
                firstOpen := open
                firstIndex := bar_index
            else
                count := count + 1
        else
            if count > 0  // End of sequence
                firstOpen := na
                firstIndex := na
            count := 0
    
    [count, firstOpen, firstIndex]

// CISD Detection Logic
if barstate.isconfirmed
    // Update liquidity levels
    manageLiquidityLevels()
    cisd_sweep_data = checkLiquiditySweep()
    bslSwept = array.get(cisd_sweep_data, 0)
    sslSwept = array.get(cisd_sweep_data, 1)
    
    bool bull = close > open
    bool bear = close < open

    // Track consecutive candles
    bull_seq_data = findRecentSequence(true)
    bullCount = array.get(bull_seq_data, 0)
    bullFirstOpen = array.get(bull_seq_data, 1)
    bullFirstIndex = array.get(bull_seq_data, 2)
    
    bear_seq_data = findRecentSequence(false)
    bearCount = array.get(bear_seq_data, 0)
    bearFirstOpen = array.get(bear_seq_data, 1)
    bearFirstIndex = array.get(bear_seq_data, 2)

    // When BSL is swept, look for most recent bullish sequence
    if bslSwept and not waitingForDisplacement
        if not na(bullFirstOpen)
            sequenceStartPrice := bullFirstOpen
            sequenceStartIndex := bullFirstIndex
            waitingForDisplacement := true
            array.clear(priorBullishOpens)
            array.push(priorBullishOpens, bullFirstOpen)

    // When SSL is swept, look for most recent bearish sequence
    if sslSwept and not waitingForDisplacement
        if not na(bearFirstOpen)
            sequenceStartPrice := bearFirstOpen
            sequenceStartIndex := bearFirstIndex
            waitingForDisplacement := true
            array.clear(priorBearishOpens)
            array.push(priorBearishOpens, bearFirstOpen)

    // Check for displacement after sweep
    if waitingForDisplacement
        if array.size(priorBullishOpens) > 0 and bear  // Check bearish displacement after BSL sweep
            if close < array.get(priorBullishOpens, 0)
                drawCisd(sequenceStartPrice, sequenceStartIndex, false)
                waitingForDisplacement := false
                array.clear(priorBullishOpens)
        
        if array.size(priorBearishOpens) > 0 and bull  // Check bullish displacement after SSL sweep
            if close > array.get(priorBearishOpens, 0)
                drawCisd(sequenceStartPrice, sequenceStartIndex, true)
                waitingForDisplacement := false
                array.clear(priorBearishOpens)

    // Reset if too much time has passed
    if bar_index - sequenceStartIndex > 20
        waitingForDisplacement := false
        array.clear(priorBullishOpens)
        array.clear(priorBearishOpens)

// Cleanup and maintain visual elements
if barstate.islast
    // Cleanup old labels
    if array.size(cisdLabels) > 0
        for i = array.size(cisdLabels) - 1 to 0
            label currentLabel = array.get(cisdLabels, i)
            if not na(currentLabel)
                if bar_index - label.get_x(currentLabel) > 200
                    label.delete(currentLabel)
                    array.remove(cisdLabels, i)
                else
                    labelX = label.get_x(currentLabel)
                    if labelX > bar_index + 2
                        label.set_x(currentLabel, bar_index + 2)

    // Cleanup and maintain lines
    if array.size(cisdLines) > 0
        for i = array.size(cisdLines) - 1 to 0
            line currentLine = array.get(cisdLines, i)
            if not na(currentLine)
                if bar_index - line.get_x1(currentLine) > 200
                    line.delete(currentLine)
                    array.remove(cisdLines, i)
                else
                    line.set_x2(currentLine, line.get_x1(currentLine) + lineLength) 

//==============================================================================
// SECTION 7: CRT SPECIFIC TIME ANALYSIS
//==============================================================================

// Inputs for CRT Time Analysis
enable_crt_h1_check = input.bool(true, title="Turn on CRT H1 test?", tooltip="Select 'True' to enable CRT H1 test", group="CRT Time Analysis", inline="1")

green = input.color(#02fc7f, title="Green", group="CRT Time Analysis", inline = "1")
red = input.color(#fd0901, title="Red", group="CRT Time Analysis", inline = "1")

//logic erc
check_large_candle_only = input.bool(true, title="Only check big candles?", tooltip="Select 'true' to check only large candles", group="CRT Time Analysis")
max_wick_ratio = input.float(0.25, title="Maximum candle wick ratio (compared to the entire candle)", minval=0.01, maxval=1, step=0.01, tooltip="Apply when testing large candles.", group="CRT Time Analysis")

// Higher Timeframe Check
isHigherTimeframe = (timeframe.period == tf)

// CRT hour
hourEST1 = 6
hourEST2 = 10
hourEST3 = 14

isTargetCandle = enable_crt_h1_check and (hour(time) == hourEST1 or hour(time) == hourEST2 or hour(time) == hourEST3)

// Variables to Store High, Low, and Index
var float crtHigh = na
var float crtLow = na
var int crtIndex = na

if (isTargetCandle and isHigherTimeframe and barstate.isconfirmed)
    crtHigh := high
    crtLow := low
    crtIndex := bar_index

if (not na(crtHigh) and bar_index == crtIndex + 1)
    if (low < crtHigh and high > crtHigh and close < crtHigh and barstate.isconfirmed)
        line.new(x1=crtIndex, y1=crtHigh, x2=bar_index, y2=crtHigh, color=green, width=2, extend=extend.none)
        alert("High CRT sweep!  " + "\nMã:" + syminfo.ticker + " " + timeframe.period + "\nAbout LTF wait for confirmation to place order", alert.freq_once_per_bar)

if (not na(crtLow) and bar_index == crtIndex + 1)
    if (high > crtLow and low < crtLow and close > crtLow and barstate.isconfirmed)
        line.new(x1=crtIndex, y1=crtLow, x2=bar_index, y2=crtLow, color=red, width=2, extend=extend.none)
        alert("Low CRT sweep!  " + "\nMã:" + syminfo.ticker + " " + timeframe.period + "\nAbout LTF wait for confirmation to place order", alert.freq_once_per_bar)

barcolor(isTargetCandle and isHigherTimeframe ? color.new(color.red, 35) : na)

// Calculate the length of the candle body and wick
body_size = math.abs(close - open)
upper_wick = high - math.max(open, close)
lower_wick = math.min(open, close) - low
total_wick_size = upper_wick + lower_wick
total_candle_size = high - low

// Conditions to determine large candles
is_large_candle = (total_wick_size / total_candle_size) <= max_wick_ratio

// Candle test condition
should_check = check_large_candle_only ? is_large_candle : true

// Color the large candle if testing a large candle
barcolor(check_large_candle_only and is_large_candle ? (close > open ? color.green : color.red) : na)

// Variable to store the high/low price and index of the candle being tested
var float crtHighs = na
var float crtLows = na
var int crtIndexs = na

// Save the price of the current candle if the test condition is met
if (should_check and barstate.isconfirmed)
    crtHighs := high
    crtLows := low
    crtIndexs := bar_index

//draw line
if (not na(crtHighs) and bar_index == crtIndexs + 1)
    if (low < crtHighs and high > crtHighs and close < crtHighs and barstate.isconfirmed and close < open)
        line.new(x1=crtIndexs, y1=crtHighs, x2=bar_index, y2=crtHighs, color=color.new(color.green, 0), width=2, extend=extend.none)
        alert("Mức cao của nến CRT bị quét!  " + "\nMã:" + syminfo.ticker + " " + timeframe.period + "\nAbout LTF wait for confirmation to place order", alert.freq_once_per_bar)

if (not na(crtLows) and bar_index == crtIndexs + 1)
    if (high > crtLows and low < crtLows and close > crtLows and barstate.isconfirmed and close> open)
        line.new(x1=crtIndexs, y1=crtLows, x2=bar_index, y2=crtLows, color=color.new(color.red, 0), width=2, extend=extend.none)
        alert("Mức thấp của nến CRT bị quét!  " + "\nMã:" + syminfo.ticker + " " + timeframe.period + "\nAbout LTF wait for confirmation to place order", alert.freq_once_per_bar)

//==============================================================================
// SECTION 8: HTF CANDLE VISUALIZATION
//==============================================================================

// Function to create and manage boxes for HTF Candles
type Candle
    float o
    float c
    float h
    float l
    int o_time
    int o_idx
    int c_idx
    int h_idx
    int l_idx
    string dow
    box body
    line wick_up
    line wick_down
    label dow_label

type CandleSettings
    bool show
    string htf
    int max_display

type Settings
    color bull_body
    color bull_border
    color bull_wick
    color bear_body
    color bear_border
    color bear_wick
    int offset
    int buffer
    int htf_buffer
    int width

type CandleSet
    array<Candle> candles
    CandleSettings settings

type Helper
    string name = 'Helper'

Settings settings = Settings.new()

var CandleSettings SettingsHTF3 = CandleSettings.new()
var array<Candle> candles_3 = array.new<Candle>(0)
var CandleSet htf3 = CandleSet.new()
htf3.settings := SettingsHTF3
htf3.candles := candles_3
htf3.settings.show              := input.bool(true, 'HTF Candle', inline = 'htf3', group="HTF Candles")
htf_3                           = input.timeframe('60', '', inline = 'htf3', group="HTF Candles")
htf3.settings.htf := htf_3
htf3.settings.max_display       := input.int(10, '', inline = 'htf3', group="HTF Candles")
settings.bull_body              := color.green
settings.bear_body              := color.red
settings.bull_border            := color.black
settings.bull_wick              := color.black
settings.bear_wick              := color.black
settings.offset                 := 10
settings.buffer                 := 1
settings.htf_buffer             := 10
settings.width                  := 2

Helper helper = Helper.new()
color color_transparent = #ffffff00

method HTFEnabled(Helper helper) =>
    helper.name := 'HTFEnabled'
    int enabled = 0
    enabled := enabled + (htf3.settings.show ? 1 : 0)
    enabled

method CandleSetHigh(Helper helper, array<Candle> candles, float h) =>
    helper.name := 'CandlesSetHigh'
    float _h = h
    if array.size(candles) > 0
        for i = 0 to array.size(candles) - 1 by 1
            Candle c = array.get(candles, i)
            if c.h > _h
                _h := c.h
    _h

method CandleSetLow(Helper helper, array<Candle> candles, float l) =>
    helper.name := 'CandlesSetLow'
    float _l = l
    if array.size(candles) > 0
        for i = 0 to array.size(candles) - 1 by 1
            Candle c = array.get(candles, i)
            if c.l < _l
                _l := c.l
    _l

method CandlesHigh(Helper helper, array<Candle> candles) =>
    helper.name := 'CandlesHigh'
    h = 0.0
    int cnt = 0
    int last = helper.HTFEnabled()

    if array.size(candles) > 0
        for i = 0 to array.size(candles) - 1 by 1
            Candle c = array.get(candles, i)
            cnt += 1
            if cnt == 1
                h := c.h
            else
                h := math.max(h, c.h)
            if cnt == last
                break
    h

method CandlesLow(Helper helper, array<Candle> candles) =>
    helper.name := 'CandlesLow'
    l = 0.0
    int cnt = 0
    int last = helper.HTFEnabled()

    if array.size(candles) > 0
        for i = 0 to array.size(candles) - 1 by 1
            Candle c = array.get(candles, i)
            cnt += 1
            if cnt == 1
                l := c.l
            else
                l := math.min(l, c.l)
            if cnt == last
                break
    l

method Reorder(Helper helper, array<Candle> candles) =>
    helper.name := 'Reorder'
    if array.size(candles) > 0
        for i = 0 to array.size(candles) - 1 by 1
            Candle c = array.get(candles, i)
            if not na(c.body)
                box.set_left(c.body, c.o_idx - settings.offset)
                box.set_right(c.body, c.c_idx + settings.offset)
            
            if not na(c.wick_up)
                line.set_x1(c.wick_up, c.h_idx)
                line.set_x2(c.wick_up, c.h_idx)
            
            if not na(c.wick_down)
                line.set_x1(c.wick_down, c.l_idx)
                line.set_x2(c.wick_down, c.l_idx)

method Monitor(Helper helper, CandleSet candleSet) =>
    helper.name := 'Monitor'
    
    if candleSet.settings.show
        htf_data = request.security(syminfo.tickerid, candleSet.settings.htf, [open, high, low, close, time])
        htf_open = array.get(htf_data, 0)
        htf_high = array.get(htf_data, 1)
        htf_low = array.get(htf_data, 2)
        htf_close = array.get(htf_data, 3)
        htf_time = array.get(htf_data, 4)
        
        if ta.change(htf_time)
            Candle c = Candle.new()
            c.o := htf_open
            c.h := htf_high
            c.l := htf_low
            c.c := htf_close
            c.o_time := htf_time
            c.o_idx := bar_index
            c.c_idx := bar_index
            c.h_idx := bar_index
            c.l_idx := bar_index
            
            if array.size(candleSet.candles) >= candleSet.settings.max_display
                old_candle = array.pop(candleSet.candles)
                if not na(old_candle.body)
                    box.delete(old_candle.body)
                if not na(old_candle.wick_up)
                    line.delete(old_candle.wick_up)
                if not na(old_candle.wick_down)
                    line.delete(old_candle.wick_down)
                if not na(old_candle.dow_label)
                    label.delete(old_candle.dow_label)
            
            array.unshift(candleSet.candles, c)

method Update(Helper helper, CandleSet candleSet) =>
    helper.name := 'Update'
    
    if candleSet.settings.show and array.size(candleSet.candles) > 0
        htf_data = request.security(syminfo.tickerid, candleSet.settings.htf, [open, high, low, close, time])
        htf_open = array.get(htf_data, 0)
        htf_high = array.get(htf_data, 1)
        htf_low = array.get(htf_data, 2)
        htf_close = array.get(htf_data, 3)
        htf_time = array.get(htf_data, 4)
        
        Candle c = array.get(candleSet.candles, 0)
        c.c := htf_close
        c.h := htf_high
        c.l := htf_low
        c.c_idx := bar_index
        
        if htf_high == high
            c.h_idx := bar_index
        if htf_low == low
            c.l_idx := bar_index
        
        // Update visual elements
        if not na(c.body)
            box.delete(c.body)
        if not na(c.wick_up)
            line.delete(c.wick_up)
        if not na(c.wick_down)
            line.delete(c.wick_down)
        
        // Create new visual elements
        body_color = c.c >= c.o ? settings.bull_body : settings.bear_body
        border_color = c.c >= c.o ? settings.bull_border : settings.bull_border
        
        c.body := box.new(c.o_idx - settings.offset, math.max(c.o, c.c), c.c_idx + settings.offset, math.min(c.o, c.c), 
                         border_color=border_color, bgcolor=body_color, border_width=settings.width)
        
        if c.h > math.max(c.o, c.c)
            wick_color = c.c >= c.o ? settings.bull_wick : settings.bear_wick
            c.wick_up := line.new(c.h_idx, c.h, c.h_idx, math.max(c.o, c.c), color=wick_color, width=settings.width)
        
        if c.l < math.min(c.o, c.c)
            wick_color = c.c >= c.o ? settings.bull_wick : settings.bear_wick
            c.wick_down := line.new(c.l_idx, c.l, c.l_idx, math.min(c.o, c.c), color=wick_color, width=settings.width)

// Monitor and update HTF candles
helper.Monitor(htf3)
helper.Update(htf3)
helper.Reorder(htf3.candles)