    bullishTouch4 := array.get(plot_results_4, 0)
    bearishTouch4 := array.get(plot_results_4, 1)
if use_tf5
    plot_results_5 = plot_lines(tf5_color, tf5_mid_color, high5, low5, mid5, start5, inRange5, newBar5, use_tf5_mid, bullishTouch5, bearishTouch5, 'D')
    bullishTouch5 := array.get(plot_results_5, 0)
    bearishTouch5 := array.get(plot_results_5, 1)
if use_tf6
    plot_results_6 = plot_lines(tf6_color, tf6_mid_color, high6, low6, mid6, start6, inRange6, newBar6, use_tf6_mid, bullishTouch6, bearishTouch6, 'W')
    bullishTouch6 := array.get(plot_results_6, 0)
    bearishTouch6 := array.get(plot_results_6, 1)
if use_tf7
    plot_results_7 = plot_lines(tf7_color, tf7_mid_color, high7, low7, mid7, start7, inRange7, newBar7, use_tf7_mid, bullishTouch7, bearishTouch7, 'M')
    bullishTouch7 := array.get(plot_results_7, 0)
    bearishTouch7 := array.get(plot_results_7, 1)

// Function to convert string input to label style (UNCHANGED)
getLabelStyle(styleString) =>
    switch styleString
        'None' => label.style_none
        'Label Up' => label.style_label_up
        'Label Down' => label.style_label_down
        'Label Left' => label.style_label_left
        'Label Right' => label.style_label_right
        'Label Center' => label.style_label_center
        'Triangle Up' => label.style_triangleup
        'Triangle Down' => label.style_triangledown
        'Flag' => label.style_flag
        'Circle' => label.style_circle
        'Square' => label.style_square
        'Diamond' => label.style_diamond
        'Cross' => label.style_cross
        'X-Cross' => label.style_xcross
        'Arrow Up' => label.style_arrowup
        'Arrow Down' => label.style_arrowdown
        => label.style_label_up // default

// Function to convert string input to size (UNCHANGED)
getLabelSize(sizeString) =>
    switch sizeString
        'Auto' => size.auto
        'Tiny' => size.tiny
        'Small' => size.small
        'Normal' => size.normal
        'Large' => size.large
        'Huge' => size.huge
        => size.auto // default

// Enhanced label management with multi-confirmation filtering
manageLabelCount(labelText, y, bgColor, textColor, style, size) =>
    if array.size(labels) >= max_labels
        label.delete(array.shift(labels))
    newLabel = label.new(bar_index, y, labelText, color = bgColor, textcolor = textColor, style = style, size = size)
    array.push(labels, newLabel)

// ENHANCED function with MULTI-CONFIRMATION SYSTEM (NO EMA DEPENDENCY)
checkAndCreateLabel(show, bullishTouch, bearishTouch, tfText) =>
    // Check volume condition if enabled
    volume_ok = not enable_volume_filter or (volume > volume_avg * volume_multiplier)
    
    if show and bullishTouch and volume_ok
        // For bullish CRT signals, check multi-confirmation consensus
        if trend_aligned_signal(true)
            // ENHANCED: Multi-confirmation status (not EMA-dependent)
            trend_status = ""
            if true_bullish_reversal
                trend_status := "🔄REV[" + str.tostring(bull_votes) + "v]"  // Multi-confirmed reversal
            else if bullish_continuation
                trend_status := "➡️CONT[" + str.tostring(bull_votes) + "v]"  // Multi-confirmed continuation
            else if new_bullish_trend
                trend_status := "🚀NEW[" + str.tostring(bull_votes) + "v]"  // Multi-confirmed new trend
            else if strong_bullish_trend
                trend_status := "💪STR[" + str.tostring(bull_votes) + "v]"  // Multi-confirmed strong trend
            else if bullish_trend
                trend_status := "📈BULL[" + str.tostring(bull_votes) + "v]" // Multi-confirmed bullish
            else
                trend_status := "⚠️[" + str.tostring(bull_votes) + "v" + str.tostring(bear_votes) + "]"  // Weak/conflicting signals
            
            enhanced_label = 'BUY-' + tfText + trend_status
            manageLabelCount(enhanced_label, low, bullishBgColor, bullishTextColor, getLabelStyle(bullishLabelStyle), getLabelSize(labelSize))
    
    if show and bearishTouch and volume_ok
        // For bearish CRT signals, check multi-confirmation consensus
        if trend_aligned_signal(false)
            // ENHANCED: Multi-confirmation status (not EMA-dependent)
            trend_status = ""
            if true_bearish_reversal
                trend_status := "🔄REV[" + str.tostring(bear_votes) + "v]"  // Multi-confirmed reversal
            else if bearish_continuation
                trend_status := "➡️CONT[" + str.tostring(bear_votes) + "v]"  // Multi-confirmed continuation
            else if new_bearish_trend
                trend_status := "🚀NEW[" + str.tostring(bear_votes) + "v]"  // Multi-confirmed new trend
            else if strong_bearish_trend
                trend_status := "💪STR[" + str.tostring(bear_votes) + "v]"  // Multi-confirmed strong trend
            else if bearish_trend
                trend_status := "📉BEAR[" + str.tostring(bear_votes) + "v]" // Multi-confirmed bearish
            else
                trend_status := "⚠️[" + str.tostring(bear_votes) + "v" + str.tostring(bull_votes) + "]"  // Weak/conflicting signals
            
            enhanced_label = 'SELL-' + tfText + trend_status
            manageLabelCount(enhanced_label, high, bearishBgColor, bearishTextColor, getLabelStyle(bearishLabelStyle), getLabelSize(labelSize))

// Apply ENHANCED labels for each timeframe
checkAndCreateLabel(show_m15_labels, bullishTouch1, bearishTouch1, 'M15')
checkAndCreateLabel(show_h1_labels, bullishTouch2, bearishTouch2, 'H1')
checkAndCreateLabel(show_h2_labels, bullishTouch3, bearishTouch3, 'H2')
checkAndCreateLabel(show_h4_labels, bullishTouch4, bearishTouch4, 'H4')
checkAndCreateLabel(show_daily_labels, bullishTouch5, bearishTouch5, 'D')
checkAndCreateLabel(show_weekly_labels, bullishTouch6, bearishTouch6, 'W')
checkAndCreateLabel(show_monthly_labels, bullishTouch7, bearishTouch7, 'M')

// Enhanced Alert conditions with multi-confirmation filtering
if alert_on_m15 and ((bullishTouch1 and trend_aligned_signal(true)) or (bearishTouch1 and trend_aligned_signal(false)))
    trend_direction = bullishTouch1 ? "BULLISH" : "BEARISH"
    confirmation_votes = bullishTouch1 ? bull_votes : bear_votes
    trend_type = ""
    if bullishTouch1 and true_bullish_reversal
        trend_type := "MULTI-CONFIRMED REVERSAL"
    else if bearishTouch1 and true_bearish_reversal
        trend_type := "MULTI-CONFIRMED REVERSAL"
    else if bullishTouch1 and bullish_continuation
        trend_type := "MULTI-CONFIRMED CONTINUATION"
    else if bearishTouch1 and bearish_continuation
        trend_type := "MULTI-CONFIRMED CONTINUATION"
    else
        trend_type := "CONSENSUS ALIGNED"
    alert('M15 ' + trend_direction + ' touch detected - ' + trend_type + ' [' + str.tostring(confirmation_votes) + ' confirmations]', alert.freq_once_per_bar_close)

if alert_on_h1 and ((bullishTouch2 and trend_aligned_signal(true)) or (bearishTouch2 and trend_aligned_signal(false)))
    trend_direction = bullishTouch2 ? "BULLISH" : "BEARISH"
    confirmation_votes = bullishTouch2 ? bull_votes : bear_votes
    trend_type = ""
    if bullishTouch2 and true_bullish_reversal
        trend_type := "MULTI-CONFIRMED REVERSAL"
    else if bearishTouch2 and true_bearish_reversal
        trend_type := "MULTI-CONFIRMED REVERSAL"
    else if bullishTouch2 and bullish_continuation
        trend_type := "MULTI-CONFIRMED CONTINUATION"
    else if bearishTouch2 and bearish_continuation
        trend_type := "MULTI-CONFIRMED CONTINUATION"
    else
