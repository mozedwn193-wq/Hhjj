//@version=6
indicator('Comprehensive Trading Indicator - CRT + FVG + CISD + EMAs + MULTI-CONFIRMATION SYSTEM', overlay = true, max_lines_count = 500, max_labels_count = 500, max_bars_back = 5000)

//==============================================================================
// ENHANCED SIGNAL FILTERING SETTINGS (Multiple Confirmation Methods)
//==============================================================================

var g_FILTER = "🔧 Signal Filtering"
enable_volume_filter = input.bool(false, "Enable Volume Filter", group=g_FILTER, tooltip="Only signals when volume is above average")
volume_multiplier = input.float(1.2, "Volume Multiplier", minval=0.5, maxval=3.0, step=0.1, group=g_FILTER)
enable_trend_filter = input.bool(true, "Enable Multi-Confirmation Trend Filter", group=g_FILTER, tooltip="Uses multiple methods for trend detection")
enable_confirmation = input.bool(false, "Enable Signal Confirmation", group=g_FILTER, tooltip="Wait for next bar confirmation")
min_signal_strength = input.int(50, "Minimum Signal Strength (%)", minval=30, maxval=90, group=g_FILTER)

var g_TREND = "📈 Multi-Confirmation Trend Detection"
use_rsi_trend = input.bool(true, "Use RSI for Early Trend Detection", group=g_TREND, tooltip="RSI helps detect momentum changes early")
use_macd_trend = input.bool(true, "Use MACD for Trend Confirmation", group=g_TREND, tooltip="MACD crossovers detect trend changes")
use_price_action = input.bool(true, "Use Price Action Signals", group=g_TREND, tooltip="Higher highs/lows and breakouts")
use_volume_trend = input.bool(true, "Use Volume Trend Analysis", group=g_TREND, tooltip="Volume confirms trend strength")
use_structure_analysis = input.bool(true, "Use Market Structure Analysis", group=g_TREND, tooltip="Analyzes market structure for trend confirmation")
use_momentum_divergence = input.bool(true, "Use Momentum Divergence", group=g_TREND, tooltip="Detects trend exhaustion via divergence")
trend_sensitivity = input.string("Medium", "Trend Detection Sensitivity", options=["High", "Medium", "Low"], group=g_TREND, tooltip="High=Early signals, Low=Confirmed signals")

// 🎯 MULTI-CONFIRMATION REVERSAL DETECTION SETTINGS (ENHANCED)
var g_REVERSAL = "🔄 Multi-Confirmation Reversal Detection"
enable_reversal_filter = input.bool(true, "Enable Multi-Confirmation Reversal Filter", group=g_REVERSAL, tooltip="Uses multiple methods to confirm reversals")
reversal_confirmation_bars = input.int(3, "Reversal Confirmation Bars", minval=1, maxval=10, group=g_REVERSAL, tooltip="Bars needed to confirm reversal")
htf_trend_lookback = input.int(20, "HTF Trend Lookback", minval=10, maxval=50, group=g_REVERSAL, tooltip="Bars to analyze for HTF trend context")
min_reversal_strength = input.int(70, "Minimum Reversal Strength (%)", minval=50, maxval=95, group=g_REVERSAL, tooltip="Minimum strength for valid reversal")
min_confirmation_methods = input.int(3, "Minimum Confirmation Methods", minval=2, maxval=6, group=g_REVERSAL, tooltip="How many methods must agree for signal")

// Enhanced market analysis for filtering
volume_avg = ta.sma(volume, 20)
atr_value = ta.atr(14)

//==============================================================================
// SECTION 1: BREAKOUT DETECTION
//==============================================================================

// Inputs for Breakout Detection
length = input(14, "Lookback Length", group="Breakout Detection")
threshold = input(1.5, "Range Multiplier", group="Breakout Detection")

// Calculate candle range
candleRange = high - low
averageRange = ta.sma(candleRange, length)

// Define conditions
bullishBreakout = candleRange > (averageRange * threshold) and close > open
bearishBreakout = candleRange > (averageRange * threshold) and close < open

// Plot signals
plotshape(series=bullishBreakout, location=location.belowbar, color=color.green, style=shape.labelup, title="Bullish Breakout")
plotshape(series=bearishBreakout, location=location.abovebar, color=color.red, style=shape.labeldown, title="Bearish Breakout")

// Highlight breakout candles
bgcolor(bullishBreakout ? color.new(color.green, 80) : bearishBreakout ? color.new(color.red, 80) : na)

//==============================================================================
// SECTION 2: MULTI-CONFIRMATION TREND ANALYSIS SYSTEM
//==============================================================================

// Traditional EMAs (Just one component, not the main dependency)
ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)
ema100 = ta.ema(close, 100)
ema200 = ta.ema(close, 200)

// Traditional EMA trend (just one vote, not decisive)
ema_bullish_trend = ema20 > ema50 and ema50 > ema100 and ema100 > ema200
ema_bearish_trend = ema20 < ema50 and ema50 < ema100 and ema100 < ema200

// 🚀 METHOD 1: RSI-BASED TREND DETECTION
rsi = ta.rsi(close, 14)
rsi_bullish = rsi > 50 and rsi > rsi[1] and rsi[1] > rsi[2]
rsi_bearish = rsi < 50 and rsi < rsi[1] and rsi[1] < rsi[2]
rsi_oversold_bounce = rsi < 30 and rsi > rsi[1]
rsi_overbought_drop = rsi > 70 and rsi < rsi[1]

// 📈 METHOD 2: MACD-BASED TREND DETECTION
[macd_line, signal_line, macd_histogram] = ta.macd(close, 12, 26, 9)
macd_bullish = macd_line > signal_line and macd_line > macd_line[1]
macd_bearish = macd_line < signal_line and macd_line < macd_line[1]
macd_bullish_cross = ta.crossover(macd_line, signal_line)
macd_bearish_cross = ta.crossunder(macd_line, signal_line)

// 🏗️ METHOD 3: MARKET STRUCTURE ANALYSIS (NEW - ENHANCED)
calculate_market_structure() =>
    // Higher Highs and Higher Lows analysis (lookback periods)
    short_lookback = 5
    medium_lookback = 10
    long_lookback = 20
    
    // Short-term structure
    hh_short = high > ta.highest(high[1], short_lookback)
    hl_short = low > ta.lowest(low[1], short_lookback)
    lh_short = high < ta.highest(high[1], short_lookback)
    ll_short = low < ta.lowest(low[1], short_lookback)
    
    // Medium-term structure
    hh_medium = high > ta.highest(high[1], medium_lookback)
    hl_medium = low > ta.lowest(low[1], medium_lookback)
    lh_medium = high < ta.highest(high[1], medium_lookback)
    ll_medium = low < ta.lowest(low[1], medium_lookback)
    
    // Long-term structure
    hh_long = high > ta.highest(high[1], long_lookback)
    hl_long = low > ta.lowest(low[1], long_lookback)
    lh_long = high < ta.highest(high[1], long_lookback)
    ll_long = low < ta.lowest(low[1], long_lookback)
    
    // Structure strength scoring
    bullish_structure_score = 0
    bearish_structure_score = 0
    
    // Short-term structure votes
    if hh_short or hl_short
        bullish_structure_score += 1
    if lh_short or ll_short
        bearish_structure_score += 1
    
    // Medium-term structure votes (weighted more)
    if hh_medium or hl_medium
        bullish_structure_score += 2
    if lh_medium or ll_medium
        bearish_structure_score += 2
    
    // Long-term structure votes (weighted most)
    if hh_long or hl_long
        bullish_structure_score += 3
    if lh_long or ll_long
        bearish_structure_score += 3
    
    // Structure trend determination
    structure_bullish = bullish_structure_score > bearish_structure_score and bullish_structure_score >= 3
    structure_bearish = bearish_structure_score > bullish_structure_score and bearish_structure_score >= 3
    
    // Breakout confirmation
    resistance_break = close > ta.highest(high[1], 10)
    support_break = close < ta.lowest(low[1], 10)
    
    [structure_bullish, structure_bearish, resistance_break, support_break, bullish_structure_score, bearish_structure_score]

[structure_bullish, structure_bearish, resistance_break, support_break, bull_structure_score, bear_structure_score] = calculate_market_structure()

// 📊 METHOD 4: ADVANCED VOLUME PROFILE ANALYSIS (NEW)
calculate_volume_profile() =>
    // Volume trend analysis
    vol_sma_short = ta.sma(volume, 10)
    vol_sma_long = ta.sma(volume, 30)
    
    // Volume trend direction
    volume_trend_up = vol_sma_short > vol_sma_long and volume > vol_sma_short
    volume_trend_down = vol_sma_short < vol_sma_long and volume > vol_sma_short
    
    // Price-Volume relationship
    up_volume = close > open ? volume : 0
    down_volume = close < open ? volume : 0
    
    up_vol_avg = ta.sma(up_volume, 10)
    down_vol_avg = ta.sma(down_volume, 10)
    
    // Volume confirmation
    volume_confirms_bull = up_vol_avg > down_vol_avg and volume_trend_up
    volume_confirms_bear = down_vol_avg > up_vol_avg and volume_trend_down
    
    // Volume breakout confirmation
    volume_breakout = volume > ta.sma(volume, 20) * 1.5
    
    // On-Balance Volume (OBV) trend
    obv = ta.cum(close > close[1] ? volume : close < close[1] ? -volume : 0)
    obv_trend_bull = obv > ta.sma(obv, 20)
    obv_trend_bear = obv < ta.sma(obv, 20)
    
    volume_bullish = volume_confirms_bull and obv_trend_bull
    volume_bearish = volume_confirms_bear and obv_trend_bear
    
    [volume_bullish, volume_bearish, volume_breakout, obv_trend_bull, obv_trend_bear]

[volume_bullish, volume_bearish, volume_breakout, obv_bull, obv_bear] = calculate_volume_profile()

// ⚡ METHOD 5: MOMENTUM DIVERGENCE ANALYSIS (NEW)
calculate_momentum_divergence() =>
    // Multiple momentum indicators
    roc = ta.roc(close, 14)  // Rate of Change
    mom = ta.mom(close, 14)  // Momentum
    stoch_k = ta.stoch(close, high, low, 14)  // Stochastic
    
    // Price swing analysis
    price_swing_high = ta.pivothigh(high, 5, 5)
    price_swing_low = ta.pivotlow(low, 5, 5)
    
    // Momentum at swing points
    var float last_high_price = na
    var float last_high_roc = na
    var float last_low_price = na
    var float last_low_roc = na
    
    if not na(price_swing_high)
        last_high_price := price_swing_high
        last_high_roc := roc
    
    if not na(price_swing_low)
        last_low_price := price_swing_low
        last_low_roc := roc
    
    // Divergence detection
    bullish_divergence = not na(last_low_price) and low < last_low_price and roc > last_low_roc
    bearish_divergence = not na(last_high_price) and high > last_high_price and roc < last_high_roc
    
    // Momentum trend
    momentum_bullish = roc > 0 and mom > 0 and stoch_k > 50
    momentum_bearish = roc < 0 and mom < 0 and stoch_k < 50
    
    [momentum_bullish, momentum_bearish, bullish_divergence, bearish_divergence]

[momentum_bullish, momentum_bearish, bullish_divergence, bearish_divergence] = calculate_momentum_divergence()

// 📐 METHOD 6: MULTI-TIMEFRAME PRICE ACTION (NEW)
calculate_htf_price_action() =>
    // Get higher timeframe data (not just EMAs)
    [htf_daily_close, htf_daily_high, htf_daily_low, htf_daily_open] = request.security(syminfo.tickerid, "1D", [close, high, low, open], barmerge.gaps_off, barmerge.lookahead_off)
    [htf_weekly_close, htf_weekly_high, htf_weekly_low] = request.security(syminfo.tickerid, "1W", [close, high, low], barmerge.gaps_off, barmerge.lookahead_off)
    [htf_4h_close, htf_4h_high, htf_4h_low] = request.security(syminfo.tickerid, "240", [close, high, low], barmerge.gaps_off, barmerge.lookahead_off)
    
    // HTF candle analysis (not EMA dependent)
    daily_bullish_candle = htf_daily_close > htf_daily_open and (htf_daily_close - htf_daily_open) > (htf_daily_high - htf_daily_low) * 0.6
    daily_bearish_candle = htf_daily_close < htf_daily_open and (htf_daily_open - htf_daily_close) > (htf_daily_high - htf_daily_low) * 0.6
    
    // HTF trend based on price action (not EMAs)
    daily_uptrend = htf_daily_close > htf_daily_close[1] and htf_daily_close[1] > htf_daily_close[2]
    daily_downtrend = htf_daily_close < htf_daily_close[1] and htf_daily_close[1] < htf_daily_close[2]
    
    weekly_uptrend = htf_weekly_close > htf_weekly_close[1]
    weekly_downtrend = htf_weekly_close < htf_weekly_close[1]
    
    // HTF support/resistance levels
    daily_above_mid = htf_daily_close > (htf_daily_high + htf_daily_low) / 2
    daily_below_mid = htf_daily_close < (htf_daily_high + htf_daily_low) / 2
    
    // HTF trend strength (consecutive closes)
    var int daily_bull_consecutive = 0
    var int daily_bear_consecutive = 0
    
    if daily_uptrend
        daily_bull_consecutive := daily_bull_consecutive + 1
        daily_bear_consecutive := 0
    else if daily_downtrend
        daily_bear_consecutive := daily_bear_consecutive + 1
        daily_bull_consecutive := 0
    else
        daily_bull_consecutive := 0
        daily_bear_consecutive := 0
    
    // HTF trend maturity (for reversal detection)
    htf_mature_bull = daily_bull_consecutive >= htf_trend_lookback
    htf_mature_bear = daily_bear_consecutive >= htf_trend_lookback
    
    // HTF reversal signals (price action based)
    htf_reversal_to_bear = htf_mature_bull and daily_bearish_candle and daily_below_mid
    htf_reversal_to_bull = htf_mature_bear and daily_bullish_candle and daily_above_mid
    
    // HTF continuation signals
    htf_continuation_bull = daily_uptrend and not htf_mature_bull and daily_above_mid
    htf_continuation_bear = daily_downtrend and not htf_mature_bear and daily_below_mid
    
    [daily_uptrend, daily_downtrend, weekly_uptrend, weekly_downtrend, htf_reversal_to_bull, htf_reversal_to_bear, htf_continuation_bull, htf_continuation_bear, daily_bull_consecutive, daily_bear_consecutive]

[daily_uptrend, daily_downtrend, weekly_uptrend, weekly_downtrend, htf_reversal_to_bull, htf_reversal_to_bear, htf_continuation_bull, htf_continuation_bear, daily_bull_count, daily_bear_count] = calculate_htf_price_action()

// 🎯 MULTI-CONFIRMATION CONSENSUS SYSTEM (REPLACES EMA DEPENDENCY)

// Count confirmation votes from each method
calculate_trend_consensus() =>
    bullish_votes = 0
    bearish_votes = 0
    
    // Method 1: RSI votes
    if use_rsi_trend
        if rsi_bullish or rsi_oversold_bounce
            bullish_votes += 1
        if rsi_bearish or rsi_overbought_drop
            bearish_votes += 1
    
    // Method 2: MACD votes
    if use_macd_trend
        if macd_bullish or macd_bullish_cross
            bullish_votes += 1
        if macd_bearish or macd_bearish_cross
            bearish_votes += 1
    
    // Method 3: Market Structure votes
    if use_structure_analysis
        if structure_bullish or resistance_break
            bullish_votes += 1
        if structure_bearish or support_break
            bearish_votes += 1
    
    // Method 4: Volume Profile votes
    if use_volume_trend
        if volume_bullish
            bullish_votes += 1
        if volume_bearish
            bearish_votes += 1
    
    // Method 5: Momentum Divergence votes
    if use_momentum_divergence
        if momentum_bullish or bullish_divergence
            bullish_votes += 1
        if momentum_bearish or bearish_divergence
            bearish_votes += 1
    
    // Method 6: HTF Price Action votes (strongest weight)
    if daily_uptrend and weekly_uptrend
        bullish_votes += 2  // Double weight for HTF alignment
    if daily_downtrend and weekly_downtrend
        bearish_votes += 2  // Double weight for HTF alignment
    
    // EMA gets only 1 vote (not decisive)
    if ema_bullish_trend
        bullish_votes += 1
    if ema_bearish_trend
        bearish_votes += 1
    
    // Consensus determination
    total_possible_votes = 8  // 6 methods + HTF double weight + EMA
    consensus_threshold = math.max(min_confirmation_methods, 3)
    
    strong_bullish_consensus = bullish_votes >= consensus_threshold and bullish_votes > bearish_votes
    strong_bearish_consensus = bearish_votes >= consensus_threshold and bearish_votes > bullish_votes
    
    // Trend strength based on vote margin
    vote_margin = math.abs(bullish_votes - bearish_votes)
    trend_strength = math.round((vote_margin / total_possible_votes) * 100)
    
    [strong_bullish_consensus, strong_bearish_consensus, bullish_votes, bearish_votes, trend_strength]

[bullish_consensus, bearish_consensus, bull_votes, bear_votes, trend_strength] = calculate_trend_consensus()

// 🔄 MULTI-CONFIRMATION REVERSAL DETECTION (ENHANCED)

// True reversal detection (requires multiple confirmations)
true_bullish_reversal = bullish_consensus and not bullish_consensus[1] and 
                       htf_reversal_to_bull and 
                       (bullish_divergence or rsi_oversold_bounce) and
                       bull_votes >= min_confirmation_methods

true_bearish_reversal = bearish_consensus and not bearish_consensus[1] and 
                       htf_reversal_to_bear and 
                       (bearish_divergence or rsi_overbought_drop) and
                       bear_votes >= min_confirmation_methods

// Continuation detection (multiple confirmations of ongoing trend)
bullish_continuation = bullish_consensus and htf_continuation_bull and bull_votes >= 4
bearish_continuation = bearish_consensus and htf_continuation_bear and bear_votes >= 4

// Final trend decisions (consensus-based, not EMA-dependent)
bullish_trend = bullish_consensus
bearish_trend = bearish_consensus
sideways_trend = not bullish_consensus and not bearish_consensus

// Strong trend detection (high consensus)
strong_bullish_trend = bullish_consensus and bull_votes >= 6 and trend_strength >= 70
strong_bearish_trend = bearish_consensus and bear_votes >= 6 and trend_strength >= 70

// New trend beginning detection (proper reversal confirmation)
new_bullish_trend = true_bullish_reversal
new_bearish_trend = true_bearish_reversal

// Enhanced Function to check if signal aligns with trend (MULTI-CONFIRMATION)
trend_aligned_signal(is_bullish_signal) =>
    if not enable_trend_filter
        true
    else if is_bullish_signal
        // For bullish CRT signals: require consensus agreement
        if enable_reversal_filter
            bullish_trend or true_bullish_reversal or (bull_votes >= 3 and not bearish_consensus)
        else
            bullish_trend or new_bullish_trend or (bull_votes >= 2)
    else
        // For bearish CRT signals: require consensus agreement
        if enable_reversal_filter
            bearish_trend or true_bearish_reversal or (bear_votes >= 3 and not bullish_consensus)
        else
            bearish_trend or new_bearish_trend or (bear_votes >= 2)

// Dynamic Colors Based on Consensus (not just EMA slope)
color20 = bullish_consensus ? color.lime : bearish_consensus ? color.red : color.gray
color50 = ema50 > ema50[1] ? color.orange : color.maroon
color100 = ema100 > ema100[1] ? color.aqua : color.navy
color200 = ema200 > ema200[1] ? color.blue : color.gray

// Plot EMAs (now just visual aids, not decision makers)
plot(ema20, title="EMA 20", color=color20, linewidth=1)
plot(ema50, title="EMA 50", color=color50, linewidth=1)
plot(ema100, title="EMA 100", color=color100, linewidth=1)
plot(ema200, title="EMA 200", color=color200, linewidth=1)

// Enhanced Labels with Multi-Confirmation Info
consensus_text_suffix = " [" + str.tostring(bull_votes) + "v" + str.tostring(bear_votes) + "]"
plotshape(bar_index == ta.highest(bar_index, 1) ? ema20 : na, location=location.absolute, style=shape.labelup, text="EMA 20" + consensus_text_suffix, color=color.new(color20, 80), textcolor=color.white)
plotshape(bar_index == ta.highest(bar_index, 1) ? ema50 : na, location=location.absolute, style=shape.labelup, text="EMA 50", color=color.new(color50, 80), textcolor=color.white)
plotshape(bar_index == ta.highest(bar_index, 1) ? ema100 : na, location=location.absolute, style=shape.labelup, text="EMA 100", color=color.new(color100, 80), textcolor=color.white)
plotshape(bar_index == ta.highest(bar_index, 1) ? ema200 : na, location=location.absolute, style=shape.labelup, text="EMA 200", color=color.new(color200, 80), textcolor=color.white)

//==============================================================================
// SECTION 3: FAIR VALUE GAP (FVG) DETECTION - SESSION BASED
//==============================================================================

// Define session times
sess = input.session("0932-1600", title="Session", tooltip="A 9:30 FVG can start at 9:30 but takes 3 candles to form, thus the 9:32 start time for the session. Adjust accordingly.", group="FVG Settings")
// User input for box color
boxColorUp = input.color(color.new(color.green, 80), "Box Color Up", group="FVG Settings")
boxColorDn = input.color(color.new(color.red, 80), "Box Color Down", group="FVG Settings")
max_days = input.int(3, title="Max # of days to draw", group="FVG Settings")
drawOpenTime = input.bool(true, title="Draw 9:30 NY open vertical line", group="FVG Settings")
drawOpenPrice = input.bool(true, title="Draw 9:30 opening price", group="FVG Settings")

//lines, boxes and labels
var timezone = "America/New_York"
var boxes = array.new<box>()
var ny_open_labels = array.new<box>()
var labels = array.new<label>()
var ny_open_prices = array.new<line>()
var ny_open_times = array.new<line>()
var ny_930_labels = array.new<label>()

var box ny_open_label = na
var box fvg_box = na
var line ny_open_time = na
var line ny_open_price = na
var label ny_930_label = na
var label fvg_lb = na
var bool first_fvg_found = false

boxColor = color.new(color.gray, 80)
is_target_time = (hour(time, timezone) == 8 and minute == 30) // CME servers in Chicago (CST). 9:30 EST = 8:30 CST
lowest_so_far = ta.lowest(50) - 5*ta.atr(14)

// Calculations
// Get day of week in text
day_of_week_text() =>
     dayofweek == dayofweek.monday    ? "Mon" :
     dayofweek == dayofweek.tuesday   ? "Tue" :
     dayofweek == dayofweek.wednesday ? "Wed" :
     dayofweek == dayofweek.thursday  ? "Thu" :
     dayofweek == dayofweek.friday    ? "Fri" :
     dayofweek == dayofweek.saturday  ? "Sat" :
     dayofweek == dayofweek.sunday    ? "Sun" : "N/A"

// Box creation
make_box(_left, _right, _top, _bottom, col) =>
    box.new(left=_left, right=_right, top=_top, bottom=_bottom, border_color=color.new(col, 70), bgcolor=col, text="1st FVG - " + day_of_week_text(), text_halign = text.align_right, text_size=size.small, text_color = color.black)

// Manage array of lines and labels
manage_lines(li_time, li_price, lb_price, lb_930) =>
    array.push(ny_open_times, li_time)
    array.push(ny_open_prices, li_price)
    array.push(ny_open_labels, lb_price)
    array.push(ny_930_labels, lb_930)
    if array.size(ny_open_times) > max_days
        line.delete(array.shift(ny_open_prices))
        line.delete(array.shift(ny_open_times))
        box.delete(array.shift(ny_open_labels))
        label.delete(array.shift(ny_930_labels))

// Manage array of boxes
manage_boxes(b) =>
    array.push(boxes, b)
    if array.size(boxes) > max_days
        box.delete(array.shift(boxes))

// Update FVG box
update_box(b) =>
    box.set_right(b, bar_index+10)

//@function calculates session valid times
in_session(sess) => not na(time(timeframe.period, sess, timezone))

// Core Logic
if in_session(sess) 
    if not first_fvg_found
        // FVG condition
        fvgUp   = close[1] > open[1] and high[2] < low[0]
        fvgDown = close[1] < open[1] and low[2] > high[0]
        if fvgUp or fvgDown
            first_fvg_found := true
            boxColor := fvgUp ? boxColorUp : boxColorDn
            // Define box coordinates
            boxTop      = fvgUp ? high[2] : low[2]
            boxBottom   = fvgUp ? low[0] : high[0]

            // Create the box
            fvg_box := make_box(bar_index-2, bar_index + 5, boxTop, boxBottom, boxColor)
            manage_boxes(fvg_box)

// Reset FVG flag at the end of the session
if not in_session(sess) and in_session(sess)[1]
    first_fvg_found := false

// Extend the box to session end
if first_fvg_found and na(fvg_box) == false
    update_box(fvg_box)

//Draw NY Open at 9:30 am EST / NY Time
if is_target_time
    if drawOpenTime
        ny_open_time    := line.new(x1=time, y1=high, x2=time, y2=low, xloc=xloc.bar_time, color=color.gray, style=line.style_dashed, width=1, extend = extend.both)
        ny_930_label    := label.new(x=bar_index, y=lowest_so_far, text="9:30", style=label.style_none, color=color.new(color.gray, 90), textcolor=color.black)
        manage_lines(ny_open_time, ny_open_price, ny_open_label, ny_930_label)
    if drawOpenPrice
        ny_open_price   := line.new(x1=bar_index, y1=open, x2=bar_index + 10, y2=open, xloc=xloc.bar_index, color=color.gray, style=line.style_dotted, width=1, extend = extend.none)
        ny_open_label   := box.new(left=bar_index+25, top=open+10, 
         right=bar_index + 55, 
         bottom=open-10, 
         text = day_of_week_text() + " NY Open - " + str.format("{0,number,#,###.00}", close), 
         bgcolor=color.new(color.white, 100), 
         text_halign = text.align_right, 
         text_size = size.small, 
         text_color = color.black, 
         border_color = color.new(color.white, 50))
    
// Keep extended objects until end of the session
if in_session(sess)
    box.set_right(ny_open_label, bar_index + 55)
    line.set_x2(ny_open_price, bar_index + 20)

