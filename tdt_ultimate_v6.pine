grp_mtf = "7. Multi-Timeframe (MTF)"
i_enable_mtf = input.bool(false, "Enable MTF Counting", group=grp_mtf)
i_mtf_timeframe = input.timeframe("60", "Higher Timeframe", group=grp_mtf)
i_mtf_sequence_str_1 = input.string("1,7,13,21,33", "MTF Sequence 1", group=grp_mtf)
i_mtf_sequence_str_2 = input.string("1,4,8,15,23,34,46", "MTF Sequence 2", group=grp_mtf)
i_mtf_sequence_str_3 = input.string("1,2,3,5,8,13,21", "MTF Sequence 3", group=grp_mtf)
i_mtf_sequence_str_4 = input.string("1,4,9,16,25,36,49", "MTF Sequence 4", group=grp_mtf)
i_active_mtf_sequence = input.string("MTF Sequence 1", "Active MTF 1 Sequence", options=["MTF Sequence 1", "MTF Sequence 2", "MTF Sequence 3", "MTF Sequence 4"], group=grp_mtf)
i_active_mtf_sequence_2 = input.string("MTF Sequence 1", "Active MTF 2 Sequence", options=["MTF Sequence 1", "MTF Sequence 2", "MTF Sequence 3", "MTF Sequence 4"], group=grp_mtf)
i_mtf1_enable_shift = input.bool(false, "MTF 1 Enable Shift Mode", group=grp_mtf)
i_mtf1_shift_start_val = input.int(1, "MTF 1 Start Count At", minval=1, group=grp_mtf)
i_enable_mtf_2 = input.bool(false, "Enable Second MTF Counting", group=grp_mtf)
i_mtf_timeframe_2 = input.timeframe("D", "Higher Timeframe 2", group=grp_mtf)
i_mtf2_enable_shift = input.bool(false, "MTF 2 Enable Shift Mode", group=grp_mtf)
