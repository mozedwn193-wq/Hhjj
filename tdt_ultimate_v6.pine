//@version=6
indicator("TDT Ultimate v6 - Complete Time Dilation Theory", shorttitle="TDTv6", overlay=true, max_labels_count=500, max_lines_count=300, max_boxes_count=200)

// =========================================================
// 1) SHARED HELPERS
// =========================================================

// Parse comma-separated sequence into array<float>
f_parse_sequence(string _seq_str) =>
    _arr = array.new_float()
    _parts = str.split(_seq_str, ",")
    for _part in _parts
        _value = str.tonumber(str.trim(_part))
        if not na(_value)
            array.push(_arr, _value)
    _arr

// Convert label size from either "size.*" or simple strings (tiny, small, normal, large, huge)
f_str_to_size(string _size_str) =>
    // Accept both styles
    _s = str.trim(_size_str)
    switch _s
        "size.auto"   => size.auto
        "size.tiny"   => size.tiny
        "size.small"  => size.small
        "size.large"  => size.large
        "size.huge"   => size.huge
        "auto"        => size.auto
        "tiny"        => size.tiny
        "small"       => size.small
        "large"       => size.large
        "huge"        => size.huge
        => size.normal

// Floating point equality with tolerance
f_levels_equal(float level1, float level2, float tolerance = 0.0001) =>
    math.abs(level1 - level2) <= tolerance

// Line style from string
f_str_to_line_style(string _style_str) =>
    switch _style_str
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid

// ATR (shared)
atr_val = ta.atr(14)

// =========================================================
// 2) SECTION: ORIGINAL TDT INDICATOR (ANCHOR, TD, MTF, FVG/EOB)
// =========================================================

grp_core = "1. Core Settings"
i_mode = input.string("Forward Only", "Counting Mode", options=["Forward Only", "Backward-to-Forward Mirror"], group=grp_core)
i_sequence_str = input.string("7,13,21,31,42", "Sequence 1 (comma-separated)", group=grp_core)
i_sequence_str_2 = input.string("1,5,9,11,17,25,37", "Sequence 2 (comma-separated)", group=grp_core)
i_sequence_str_3 = input.string("1,7,13,21,31,43,57", "Sequence 3 (comma-separated)", group=grp_core)
i_sequence_str_4 = input.string("1,2,3,5,8,13,21", "Sequence 4 (comma-separated)", group=grp_core)
i_sequence_str_5 = input.string("1,4,9,16,25,36,49", "Sequence 5 (comma-separated)", group=grp_core)
