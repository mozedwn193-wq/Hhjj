s1_l_swept = request.security(s1, tf, f_lswept(s1, htf_used), lookahead=barmerge.lookahead_on, ignore_invalid_symbol=true)
s2_l_swept = request.security(s2, tf, f_lswept(s2, htf_used), lookahead=barmerge.lookahead_on, ignore_invalid_symbol=true)
s3_l_swept = request.security(s3, tf, f_lswept(s3, htf_used), lookahead=barmerge.lookahead_on, ignore_invalid_symbol=true)
s4_l_swept = request.security(s4, tf, f_lswept(s4, htf_used), lookahead=barmerge.lookahead_on, ignore_invalid_symbol=true)
s5_l_swept = request.security(s5, tf, f_lswept(s5, htf_used), lookahead=barmerge.lookahead_on, ignore_invalid_symbol=true)
s6_l_swept = request.security(s6, tf, f_lswept(s6, htf_used), lookahead=barmerge.lookahead_on, ignore_invalid_symbol=true)

// Swept label
swept_label = "       " + f_text(htf_used) + " Swept \n ------------------------\n"
swept_label := s1_h_swept and ok1 ? swept_label + "⚠️ " + tickerShort(s1) + " " + f_text(htf_used) + " 🔴 " + "\n" : swept_label
swept_label := s2_h_swept and ok2 ? swept_label + "⚠️ " + tickerShort(s2) + " " + f_text(htf_used) + " 🔴 " + "\n" : swept_label
swept_label := s3_h_swept and ok3 ? swept_label + "⚠️ " + tickerShort(s3) + " " + f_text(htf_used) + " 🔴 " + "\n" : swept_label
swept_label := s4_h_swept and ok4 ? swept_label + "⚠️ " + tickerShort(s4) + " " + f_text(htf_used) + " 🔴 " + "\n" : swept_label
swept_label := s5_h_swept and ok5 ? swept_label + "⚠️ " + tickerShort(s5) + " " + f_text(htf_used) + " 🔴 " + "\n" : swept_label
swept_label := s6_h_swept and ok6 ? swept_label + "⚠️ " + tickerShort(s6) + " " + f_text(htf_used) + " 🔴 " + "\n" : swept_label
swept_label := s1_l_swept and ok1 ? swept_label + "⚠️ " + tickerShort(s1) + " " + f_text(htf_used) + " 🟢 " + "\n" : swept_label
swept_label := s2_l_swept and ok2 ? swept_label + "⚠️ " + tickerShort(s2) + " " + f_text(htf_used) + " 🟢 " + "\n" : swept_label
swept_label := s3_l_swept and ok3 ? swept_label + "⚠️ " + tickerShort(s3) + " " + f_text(htf_used) + " 🟢 " + "\n" : swept_label
swept_label := s4_l_swept and ok4 ? swept_label + "⚠️ " + tickerShort(s4) + " " + f_text(htf_used) + " 🟢 " + "\n" : swept_label
swept_label := s5_l_swept and ok5 ? swept_label + "⚠️ " + tickerShort(s5) + " " + f_text(htf_used) + " 🟢 " + "\n" : swept_label
swept_label := s6_l_swept and ok6 ? swept_label + "⚠️ " + tickerShort(s6) + " " + f_text(htf_used) + " 🟢 " + "\n" : swept_label

// Table
var dataTable = table.new(position=i_pos, columns=1, rows=3, bgcolor=#00000000)
if tableOn and barstate.islast
    table.cell(dataTable, column=0, row=0, text=swept_label, height=0, text_color=i_textcolor, text_halign=text.align_left, text_valign=text.align_center, text_size=font_size, bgcolor=i_bgcolor)

// CISD small table
f_tb2_text(_alarm) => _alarm ? "🔥" : "🕒"

var tablo2 = table.new(position=position.bottom_right, columns=3, rows=11, frame_color=i_textcolor, frame_width=2, border_color=i_textcolor, border_width=1)
if show_cisd
    table.cell(tablo2, 0, 0, text="CISD", text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
    table.cell(tablo2, 1, 0, text="Bullish", text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
    table.cell(tablo2, 2, 0, text="Bearish", text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
    if ok1
        table.cell(tablo2, 0, 1, text=tickerShort(s1), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
        table.cell(tablo2, 1, 1, text=f_tb2_text(s1_bull), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
        table.cell(tablo2, 2, 1, text=f_tb2_text(s1_bear), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
    if ok2
        table.cell(tablo2, 0, 2, text=tickerShort(s2), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
        table.cell(tablo2, 1, 2, text=f_tb2_text(s2_bull), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
        table.cell(tablo2, 2, 2, text=f_tb2_text(s2_bear), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
    if ok3
        table.cell(tablo2, 0, 3, text=tickerShort(s3), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
        table.cell(tablo2, 1, 3, text=f_tb2_text(s3_bull), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
        table.cell(tablo2, 2, 3, text=f_tb2_text(s3_bear), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
    if ok4
        table.cell(tablo2, 0, 4, text=tickerShort(s4), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
        table.cell(tablo2, 1, 4, text=f_tb2_text(s4_bull), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
        table.cell(tablo2, 2, 4, text=f_tb2_text(s4_bear), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
    if ok5
        table.cell(tablo2, 0, 5, text=tickerShort(s5), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
        table.cell(tablo2, 1, 5, text=f_tb2_text(s5_bull), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
        table.cell(tablo2, 2, 5, text=f_tb2_text(s5_bear), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
    if ok6
        table.cell(tablo2, 0, 6, text=tickerShort(s6), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
        table.cell(tablo2, 1, 6, text=f_tb2_text(s6_bull), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)
        table.cell(tablo2, 2, 6, text=f_tb2_text(s6_bear), text_color=i_textcolor, bgcolor=i_bgcolor, text_size=font_size)

// ========================= Bias =========================
var bo0 = open
var bh0 = high
var bl0 = low
var bt0 = time
var bc0 = close
var bh1 = high
var bl1 = low
var bt1 = time
var bc1 = close
var bo1 = open
var bh2 = high
var bl2 = low
var bo2 = open
var bc2 = close
var bias = 0

if timeframe.change(htfbias)
    bt0 := time
    bo0 := open
    bh0 := high
    bl0 := low
if high >= bh0
    bh0 := high
if low <= bl0
    bl0 := low
bc0 := close
if timeframe.change(htfbias)
    bo1 := bo0[1]
    bh1 := bh0[1]
    bl1 := bl0[1]
    bt1 := bt0[1]
    bc1 := close[1]
    bh2 := bh1[1]
    bl2 := bl1[1]
    bo2 := bo1[1]
    bc2 := bc1[1]

if timeframe.change(htfbias)
    bias := 0
    if bc1 > bh2 
        bias := 1
    if bc1 < bl2
        bias := -1
    if bc1 < bh2 and bc1 > bl2 and bh1 > bh2 and bl1 > bl2
        bias := -1
    if bc1 > bl2 and bc1 < bh2 and bh1 < bh2 and bl1 < bl2
        bias := 1
    if bh1 <= bh2 and bl1 >= bl2  
        bias := bc2 > bo2 ? 1 : -1

plotshape(plotbias, 'htf Bias', style=shape.square, size=size.tiny, location=location.bottom, color=bias == 1 ? bull_color : bias == -1 ? bear_color : color.gray)

// ========================= SMT =========================
var lb1 = label.new(na, na)
var lb2 = label.new(na, na)
csym  = str.contains(sym, s1) and ok1 ? ss1 : str.contains(sym, s2) and ok2 ? ss2 : str.contains(sym, s3) and ok3 ? ss3 : str.contains(sym, s4) and ok4 ? ss4 : str.contains(sym, s5) and ok5 ? ss5 : str.contains(sym, s6) and ok6 ? ss6 : sym 
par_ok = csym != sym
c_l   = request.security(csym, htf_used, low < low[1],  lookahead=barmerge.lookahead_on, ignore_invalid_symbol=true)
c_h   = request.security(csym, htf_used, high > high[1], lookahead=barmerge.lookahead_on, ignore_invalid_symbol=true)
da    = ta.atr(20) * 1.25
isLowerTF = timeframe.in_seconds(tf) < timeframe.in_seconds(htf_used)
if looksmt and isLowerTF and par_ok
    if ((l0 < l1 and not c_l) or (l0 >= l1 and c_l))
        lb1 := label.new(x=l0t, y=l0 - da, xloc=xloc.bar_time, text="SMT", color=color.teal, style=label.style_label_up, textcolor=color.white, size=font_size)
        label.delete(lb1[1])
    else
        label.delete(lb1[1]) 
if looksmt and isLowerTF and par_ok
    if ((h0 > h1 and not c_h) or (h0 <= h1 and c_h))
        lb2 := label.new(x=h0t, y=h0 + da, xloc=xloc.bar_time, text="SMT", color=color.teal, style=label.style_label_down, textcolor=color.white, size=font_size)
        label.delete(lb2[1])
    else
        label.delete(lb2[1]) 

bull_alarm := false
bear_alarm := false

// ========================= Live mini for key levels =========================
f_live_mini(_htf) =>
    var _o0 = open
    var _h0 = high
    var _l0 = low
    var _t0 = time
    var _c0 = close
    var _h1 = high
    var _l1 = low
    var _t1 = time
    var _c1 = close
    var _o1 = open
    if timeframe.change(_htf)
        _t0 := time
        _o0 := open
        _h0 := high
        _l0 := low
    if high >= _h0
        _h0 := high
    if low <= _l0
        _l0 := low
    if timeframe.change(_htf)        
        _o1 := _o0[1]
        _h1 := _h0[1]
        _l1 := _l0[1]
        _t1 := _t0[1]
        _c1 := close[1] 
    _c0 := close
    [_h1, _l1, _c1, _o1, _t1, _h0, _l0, _c0, _o0, _t0]

// ========================= Key levels =========================
f_key_auto_from_chart_tf(_chartTf) =>
    switch _chartTf
        "1"   => ["15","60","240"]
        "3"   => ["15","60","240"]
        "5"   => ["30","60","240"]
        "15"  => ["60","240","D"]
        "30"  => ["240","D","D"]
        "60"  => ["240","D","D"]
        "240" => ["D","W","M"]
        "D"   => ["W","M","3M"]
        "W"   => ["M","3M","3M"]
        => [keytf1, keytf2, keytf3]

f_key_manual_from_chart_tf(_chartTf) =>
    _sec = timeframe.in_seconds(_chartTf)
    _r1 = kmap_1m_1
    _r2 = kmap_1m_2
    _r3 = kmap_1m_3
    if _sec <= timeframe.in_seconds("1")
        _r1 := kmap_1m_1
        _r2 := kmap_1m_2
        _r3 := kmap_1m_3
    else if _sec <= timeframe.in_seconds("5")
        _r1 := kmap_5m_1
        _r2 := kmap_5m_2
        _r3 := kmap_5m_3
    else if _sec <= timeframe.in_seconds("15")
        _r1 := kmap_15m_1
        _r2 := kmap_15m_2
        _r3 := kmap_15m_3
    else if _sec <= timeframe.in_seconds("30")
        _r1 := kmap_30m_1
        _r2 := kmap_30m_2
        _r3 := kmap_30m_3
    else if _sec <= timeframe.in_seconds("60")
        _r1 := kmap_1h_1
        _r2 := kmap_1h_2
        _r3 := kmap_1h_3
    else if _sec <= timeframe.in_seconds("D")
        _r1 := kmap_1d_1
        _r2 := kmap_1d_2
        _r3 := kmap_1d_3
    else
        _r1 := keytf1
        _r2 := keytf2
        _r3 := keytf3
    [_r1, _r2, _r3]

[auto_k1, auto_k2, auto_k3] = f_key_auto_from_chart_tf(tf)
[map_k1,  map_k2,  map_k3]  = f_key_manual_from_chart_tf(tf)

key1_used = keyAutoMap ? auto_k1 : keyManualMode == "Fixed TFs" ? keytf1 : map_k1
key2_used = keyAutoMap ? auto_k2 : keyManualMode == "Fixed TFs" ? keytf2 : map_k2
key3_used = keyAutoMap ? auto_k3 : keyManualMode == "Fixed TFs" ? keytf3 : map_k3

[tf1h1, tf1l1, tf1c1, tf1o1, tf1t1, wh0, wl0, wc0, wo0, wt0] = f_live_mini(key1_used)
[tf2h1, tf2l1, tf2c1, tf2o1, tf2t1, dh0, dl0, dc0, do0, dt0] = f_live_mini(key2_used)
[tf3h1, tf3l1, tf3c1, tf3o1, tf3t1, h40, l40, c40, o40, t40] = f_live_mini(key3_used)

nx = 8
dt = timeframe.in_seconds(tf) * 1000
if show_keylvl and barstate.islast
    if tf_ok(key1_used) and showkeytf1
        add1h = wh0 >= tf1h1 ? "(-)" : ""
        add1l = wl0 <= tf1l1 ? "(-)" : ""  
        wbox1 = box.new(left=t0, top=tf1h1, right=time + nx * dt, bottom=tf1h1, xloc=xloc.bar_time, border_color=keytf1_clr, bgcolor=color.new(color.gray,100), text="p " + f_text(key1_used) + " h " + add1h, text_color=key_txtcolor, text_valign=text.align_bottom, text_halign=text.align_right, text_size=size.tiny, border_style=line.style_dotted)
        wbox2 = box.new(left=t0, top=tf1l1, right=time + nx * dt, bottom=tf1l1, xloc=xloc.bar_time, border_color=keytf1_clr, bgcolor=color.new(color.gray,100), text="p " + f_text(key1_used) + " l " + add1l, text_color=key_txtcolor, text_valign=text.align_top, text_halign=text.align_right, text_size=size.tiny, border_style=line.style_dotted)
        wbox3 = box.new(left=t0, top=wo0,   right=time + nx * dt, bottom=wo0,   xloc=xloc.bar_time, border_color=keytf1_clr, bgcolor=color.new(color.gray,100), text=f_text(key1_used) + " open ", text_color=key_txtcolor, text_valign=text.align_bottom, text_halign=text.align_right, text_size=size.tiny, border_style=line.style_dotted)
        box.delete(wbox1[1])
        box.delete(wbox2[1])
        box.delete(wbox3[1])

    if tf_ok(key2_used) and showkeytf2
        add2h = dh0 >= tf2h1 ? "(-)" : ""
        add2l = dl0 <= tf2l1 ? "(-)" : ""         
        dbox1 = box.new(left=t0, top=tf2h1, right=time + nx * dt, bottom=tf2h1, xloc=xloc.bar_time, border_color=keytf2_clr, bgcolor=color.new(color.gray,100), text="p " + f_text(key2_used) + " h " + add2h, text_color=key_txtcolor, text_valign=text.align_top, text_halign=text.align_right, text_size=size.tiny, border_style=line.style_dotted)
        dbox2 = box.new(left=t0, top=tf2l1, right=time + nx * dt, bottom=tf2l1, xloc=xloc.bar_time, border_color=keytf2_clr, bgcolor=color.new(color.gray,100), text="p " + f_text(key2_used) + " l " + add2l, text_color=key_txtcolor, text_valign=text.align_bottom, text_halign=text.align_right, text_size=size.tiny, border_style=line.style_dotted)
        dbox3 = box.new(left=t0, top=do0,   right=time + nx * dt, bottom=do0,   xloc=xloc.bar_time, border_color=keytf2_clr, bgcolor=color.new(color.gray,100), text=f_text(key2_used) + " open ", text_color=key_txtcolor, text_valign=text.align_top, text_halign=text.align_right, text_size=size.tiny, border_style=line.style_dotted)
        box.delete(dbox1[1])
        box.delete(dbox2[1])
        box.delete(dbox3[1])

    if tf_ok(key3_used) and showkeytf3
        add3h = h40 >= tf3h1 ? "(-)" : ""
        add3l = l40 <= tf3l1 ? "(-)" : ""         
        h4box1 = box.new(left=t0, top=tf3h1, right=time + nx * dt, bottom=tf3h1, xloc=xloc.bar_time, border_color=keytf3_clr, bgcolor=color.new(color.gray,100), text="p " + f_text(key3_used) + " h " + add3h, text_color=key_txtcolor, text_valign=text.align_bottom, text_halign=text.align_right, text_size=size.tiny, border_style=line.style_dotted)
        h4box2 = box.new(left=t0, top=tf3l1, right=time + nx * dt, bottom=tf3l1, xloc=xloc.bar_time, border_color=keytf3_clr, bgcolor=color.new(color.gray,100), text="p " + f_text(key3_used) + " l " + add3l, text_color=key_txtcolor, text_valign=text.align_top, text_halign=text.align_right, text_size=size.tiny, border_style=line.style_dotted)
        h4box3 = box.new(left=t0, top=o40,   right=time + nx * dt, bottom=o40,   xloc=xloc.bar_time, border_color=keytf3_clr, bgcolor=color.new(color.gray,100), text=f_text(key3_used) + " open ", text_color=key_txtcolor, text_valign=text.align_bottom, text_halign=text.align_right, text_size=size.tiny, border_style=line.style_dotted)
        box.delete(h4box1[1])
        box.delete(h4box2[1])
        box.delete(h4box3[1])

