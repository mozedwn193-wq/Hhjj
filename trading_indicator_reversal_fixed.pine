//@version=6
indicator('Comprehensive Trading Indicator - CRT + FVG + CISD + EMAs + SMART REVERSAL FIXED', overlay = true, max_lines_count = 500, max_labels_count = 500, max_bars_back = 5000)

//==============================================================================
// ENHANCED SIGNAL FILTERING SETTINGS (Leading + Lagging Indicators)
//==============================================================================

var g_FILTER = "🔧 Signal Filtering"
enable_volume_filter = input.bool(false, "Enable Volume Filter", group=g_FILTER, tooltip="Only signals when volume is above average")
volume_multiplier = input.float(1.2, "Volume Multiplier", minval=0.5, maxval=3.0, step=0.1, group=g_FILTER)
enable_trend_filter = input.bool(true, "Enable Advanced Trend Filter", group=g_FILTER, tooltip="Uses leading + lagging indicators for early trend detection")
enable_confirmation = input.bool(false, "Enable Signal Confirmation", group=g_FILTER, tooltip="Wait for next bar confirmation")
min_signal_strength = input.int(50, "Minimum Signal Strength (%)", minval=30, maxval=90, group=g_FILTER)

var g_TREND = "📈 Advanced Trend Detection"
use_rsi_trend = input.bool(true, "Use RSI for Early Trend Detection", group=g_TREND, tooltip="RSI helps detect momentum changes early")
use_macd_trend = input.bool(true, "Use MACD for Trend Confirmation", group=g_TREND, tooltip="MACD crossovers detect trend changes")
use_price_action = input.bool(true, "Use Price Action Signals", group=g_TREND, tooltip="Higher highs/lows and breakouts")
use_volume_trend = input.bool(true, "Use Volume Trend Analysis", group=g_TREND, tooltip="Volume confirms trend strength")
trend_sensitivity = input.string("Medium", "Trend Detection Sensitivity", options=["High", "Medium", "Low"], group=g_TREND, tooltip="High=Early signals, Low=Confirmed signals")

// 🎯 SMART REVERSAL DETECTION SETTINGS (NEW)
var g_REVERSAL = "🔄 Smart Reversal Detection"
enable_reversal_filter = input.bool(true, "Enable Smart Reversal Filter", group=g_REVERSAL, tooltip="Distinguishes reversals from continuations")
reversal_confirmation_bars = input.int(3, "Reversal Confirmation Bars", minval=1, maxval=10, group=g_REVERSAL, tooltip="Bars needed to confirm reversal")
htf_trend_lookback = input.int(20, "HTF Trend Lookback", minval=10, maxval=50, group=g_REVERSAL, tooltip="Bars to analyze for HTF trend context")
min_reversal_strength = input.int(70, "Minimum Reversal Strength (%)", minval=50, maxval=95, group=g_REVERSAL, tooltip="Minimum strength for valid reversal")

// Enhanced market analysis for filtering
volume_avg = ta.sma(volume, 20)
atr_value = ta.atr(14)

//==============================================================================
// SECTION 1: BREAKOUT DETECTION
//==============================================================================

// Inputs for Breakout Detection
length = input(14, "Lookback Length", group="Breakout Detection")
threshold = input(1.5, "Range Multiplier", group="Breakout Detection")

// Calculate candle range
candleRange = high - low
averageRange = ta.sma(candleRange, length)

// Define conditions
bullishBreakout = candleRange > (averageRange * threshold) and close > open
bearishBreakout = candleRange > (averageRange * threshold) and close < open

// Plot signals
plotshape(series=bullishBreakout, location=location.belowbar, color=color.green, style=shape.labelup, title="Bullish Breakout")
plotshape(series=bearishBreakout, location=location.abovebar, color=color.red, style=shape.labeldown, title="Bearish Breakout")

// Highlight breakout candles
bgcolor(bullishBreakout ? color.new(color.green, 80) : bearishBreakout ? color.new(color.red, 80) : na)

//==============================================================================
// SECTION 2: ADVANCED TREND ANALYSIS WITH SMART REVERSAL DETECTION
//==============================================================================

// Traditional EMAs (Lagging indicators)
ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)
ema100 = ta.ema(close, 100)
ema200 = ta.ema(close, 200)

// Traditional EMA trend (lagging)
ema_bullish_trend = ema20 > ema50 and ema50 > ema100 and ema100 > ema200
ema_bearish_trend = ema20 < ema50 and ema50 < ema100 and ema100 < ema200

// 🚀 LEADING INDICATORS FOR EARLY TREND DETECTION

// 1. RSI-based trend detection (Leading)
rsi = ta.rsi(close, 14)
rsi_bullish = rsi > 50 and rsi > rsi[1] and rsi[1] > rsi[2]  // RSI rising above 50
rsi_bearish = rsi < 50 and rsi < rsi[1] and rsi[1] < rsi[2]  // RSI falling below 50
rsi_oversold_bounce = rsi < 30 and rsi > rsi[1]  // Bounce from oversold
rsi_overbought_drop = rsi > 70 and rsi < rsi[1]  // Drop from overbought

// 2. MACD-based trend detection (Leading)
[macd_line, signal_line, macd_histogram] = ta.macd(close, 12, 26, 9)
macd_bullish = macd_line > signal_line and macd_line > macd_line[1]
macd_bearish = macd_line < signal_line and macd_line < macd_line[1]
macd_bullish_cross = ta.crossover(macd_line, signal_line)
macd_bearish_cross = ta.crossunder(macd_line, signal_line)

// 3. Price Action-based trend detection (Leading)
// Higher highs and higher lows for bullish trend
hh = high > ta.highest(high[1], 5)  // Higher high
hl = low > ta.lowest(low[1], 5)     // Higher low
lh = high < ta.highest(high[1], 5)  // Lower high  
ll = low < ta.lowest(low[1], 5)     // Lower low

price_action_bullish = hh or hl
price_action_bearish = lh or ll

// Breakout detection
resistance_break = close > ta.highest(high[1], 10)
support_break = close < ta.lowest(low[1], 10)

// 4. Volume-based trend confirmation (Leading)
volume_increasing = volume > ta.sma(volume, 5)
volume_bullish = volume_increasing and close > open
volume_bearish = volume_increasing and close < open

// 5. Momentum-based signals (Leading)
momentum = close - close[10]
momentum_bullish = momentum > 0 and momentum > momentum[1]
momentum_bearish = momentum < 0 and momentum < momentum[1]

// 🎯 HIGHER TIMEFRAME TREND CONTEXT (NEW - CRITICAL FOR REVERSAL DETECTION)

// Get higher timeframe trend context
[htf_daily_close, htf_daily_ema20, htf_daily_ema50] = request.security(syminfo.tickerid, "1D", [close, ta.ema(close, 20), ta.ema(close, 50)], barmerge.gaps_off, barmerge.lookahead_off)
[htf_weekly_close, htf_weekly_ema20] = request.security(syminfo.tickerid, "1W", [close, ta.ema(close, 20)], barmerge.gaps_off, barmerge.lookahead_off)
[htf_4h_close, htf_4h_ema20, htf_4h_ema50] = request.security(syminfo.tickerid, "240", [close, ta.ema(close, 20), ta.ema(close, 50)], barmerge.gaps_off, barmerge.lookahead_off)

// HTF Trend Analysis
htf_daily_bullish = htf_daily_close > htf_daily_ema20 and htf_daily_ema20 > htf_daily_ema50
htf_daily_bearish = htf_daily_close < htf_daily_ema20 and htf_daily_ema20 < htf_daily_ema50
htf_weekly_bullish = htf_weekly_close > htf_weekly_ema20
htf_weekly_bearish = htf_weekly_close < htf_weekly_ema20
htf_4h_bullish = htf_4h_close > htf_4h_ema20 and htf_4h_ema20 > htf_4h_ema50
htf_4h_bearish = htf_4h_close < htf_4h_ema20 and htf_4h_ema20 < htf_4h_ema50

// HTF Trend Strength (how long has trend been in place)
var int daily_bull_count = 0
var int daily_bear_count = 0
var int weekly_bull_count = 0
var int weekly_bear_count = 0
var int h4_bull_count = 0
var int h4_bear_count = 0

if htf_daily_bullish
    daily_bull_count := daily_bull_count + 1
    daily_bear_count := 0
else if htf_daily_bearish
    daily_bear_count := daily_bear_count + 1
    daily_bull_count := 0
else
    daily_bull_count := 0
    daily_bear_count := 0

if htf_weekly_bullish
    weekly_bull_count := weekly_bull_count + 1
    weekly_bear_count := 0
else if htf_weekly_bearish
    weekly_bear_count := weekly_bear_count + 1
    weekly_bull_count := 0
else
    weekly_bull_count := 0
    weekly_bear_count := 0

if htf_4h_bullish
    h4_bull_count := h4_bull_count + 1
    h4_bear_count := 0
else if htf_4h_bearish
    h4_bear_count := h4_bear_count + 1
    h4_bull_count := 0
else
    h4_bull_count := 0
    h4_bear_count := 0

// 🔄 SMART REVERSAL DETECTION LOGIC (NEW)

// Function to detect if we're at end of trend (mature trend ready for reversal)
is_mature_trend(bull_count, bear_count, min_bars) =>
    (bull_count >= min_bars and bear_count == 0) or (bear_count >= min_bars and bull_count == 0)

// Mature trend detection
daily_mature_bull = is_mature_trend(daily_bull_count, daily_bear_count, htf_trend_lookback)
daily_mature_bear = is_mature_trend(daily_bear_count, daily_bull_count, htf_trend_lookback)
weekly_mature_bull = is_mature_trend(weekly_bull_count, weekly_bear_count, htf_trend_lookback)
weekly_mature_bear = is_mature_trend(weekly_bear_count, weekly_bull_count, htf_trend_lookback)
h4_mature_bull = is_mature_trend(h4_bull_count, h4_bear_count, htf_trend_lookback)
h4_mature_bear = is_mature_trend(h4_bear_count, h4_bull_count, htf_trend_lookback)

// Reversal signals (when mature trend shows signs of exhaustion)
daily_reversal_to_bear = daily_mature_bull and htf_daily_close < htf_daily_ema20
daily_reversal_to_bull = daily_mature_bear and htf_daily_close > htf_daily_ema20
weekly_reversal_to_bear = weekly_mature_bull and htf_weekly_close < htf_weekly_ema20
weekly_reversal_to_bull = weekly_mature_bear and htf_weekly_close > htf_weekly_ema20
h4_reversal_to_bear = h4_mature_bull and htf_4h_close < htf_4h_ema20
h4_reversal_to_bull = h4_mature_bear and htf_4h_close > htf_4h_ema20

// Continuation signals (trend is still strong)
daily_continuation_bull = htf_daily_bullish and not daily_mature_bull
daily_continuation_bear = htf_daily_bearish and not daily_mature_bear
weekly_continuation_bull = htf_weekly_bullish and not weekly_mature_bull
weekly_continuation_bear = htf_weekly_bearish and not weekly_mature_bear
h4_continuation_bull = htf_4h_bullish and not h4_mature_bull
h4_continuation_bear = htf_4h_bearish and not h4_mature_bear

// 🎯 COMBINED TREND DETECTION (Leading + Lagging + HTF Context)

// Early trend detection (Leading indicators)
early_bullish_signals = 0
early_bearish_signals = 0

if use_rsi_trend
    early_bullish_signals += (rsi_bullish or rsi_oversold_bounce) ? 1 : 0
    early_bearish_signals += (rsi_bearish or rsi_overbought_drop) ? 1 : 0

if use_macd_trend
    early_bullish_signals += (macd_bullish or macd_bullish_cross) ? 1 : 0
    early_bearish_signals += (macd_bearish or macd_bearish_cross) ? 1 : 0

if use_price_action
    early_bullish_signals += (price_action_bullish or resistance_break) ? 1 : 0
    early_bearish_signals += (price_action_bearish or support_break) ? 1 : 0

if use_volume_trend
    early_bullish_signals += volume_bullish ? 1 : 0
    early_bearish_signals += volume_bearish ? 1 : 0

// Add momentum
early_bullish_signals += momentum_bullish ? 1 : 0
early_bearish_signals += momentum_bearish ? 1 : 0

// Sensitivity thresholds
sensitivity_threshold = trend_sensitivity == "High" ? 2 : trend_sensitivity == "Medium" ? 3 : 4

// Combined trend detection
early_bullish_trend = early_bullish_signals >= sensitivity_threshold
early_bearish_trend = early_bearish_signals >= sensitivity_threshold

// Final trend decision (Leading indicators + EMA confirmation + HTF context)
bullish_trend = early_bullish_trend or (ema_bullish_trend and not early_bearish_trend)
bearish_trend = early_bearish_trend or (ema_bearish_trend and not early_bullish_trend)
sideways_trend = not bullish_trend and not bearish_trend

// Strong trend detection
strong_bullish_trend = early_bullish_trend and ema_bullish_trend and close > ema20
strong_bearish_trend = early_bearish_trend and ema_bearish_trend and close < ema20

// 🔄 SMART REVERSAL vs CONTINUATION DETECTION (NEW)

// True reversal detection (requires HTF context + confirmation)
true_bullish_reversal = early_bullish_trend and not early_bullish_trend[1] and 
                       (daily_reversal_to_bull or weekly_reversal_to_bull or h4_reversal_to_bull) and
                       early_bullish_signals >= min_reversal_strength / 20

true_bearish_reversal = early_bearish_trend and not early_bearish_trend[1] and 
                       (daily_reversal_to_bear or weekly_reversal_to_bear or h4_reversal_to_bear) and
                       early_bearish_signals >= min_reversal_strength / 20

// Continuation detection (trend continues in same HTF direction)
bullish_continuation = early_bullish_trend and 
                      (daily_continuation_bull or weekly_continuation_bull or h4_continuation_bull)

bearish_continuation = early_bearish_trend and 
                      (daily_continuation_bear or weekly_continuation_bear or h4_continuation_bear)

// New trend beginning detection (FIXED - now considers HTF context)
new_bullish_trend = true_bullish_reversal  // Only true reversals, not continuations
new_bearish_trend = true_bearish_reversal  // Only true reversals, not continuations

// Enhanced Function to check if signal aligns with trend (FIXED)
trend_aligned_signal(is_bullish_signal) =>
    if not enable_trend_filter
        true
    else if is_bullish_signal
        // For bullish CRT signals: allow if bullish trend OR true bullish reversal
        if enable_reversal_filter
            bullish_trend or true_bullish_reversal or (not bearish_trend and close > ema50)
        else
            bullish_trend or new_bullish_trend or (not bearish_trend and close > ema50)
    else
        // For bearish CRT signals: allow if bearish trend OR true bearish reversal  
        if enable_reversal_filter
            bearish_trend or true_bearish_reversal or (not bullish_trend and close < ema50)
        else
            bearish_trend or new_bearish_trend or (not bullish_trend and close < ema50)

// Dynamic Colors Based on Slope
color20 = ema20 > ema20[1] ? color.lime : color.red
color50 = ema50 > ema50[1] ? color.orange : color.maroon
color100 = ema100 > ema100[1] ? color.aqua : color.navy
color200 = ema200 > ema200[1] ? color.blue : color.gray

// Plot EMAs
plot(ema20, title="EMA 20", color=color20, linewidth=1)
plot(ema50, title="EMA 50", color=color50, linewidth=1)
plot(ema100, title="EMA 100", color=color100, linewidth=1)
plot(ema200, title="EMA 200", color=color200, linewidth=1)

// Labels on latest bar
plotshape(bar_index == ta.highest(bar_index, 1) ? ema20 : na, location=location.absolute, style=shape.labelup, text="EMA 20", color=color.new(color20, 80), textcolor=color.white)
plotshape(bar_index == ta.highest(bar_index, 1) ? ema50 : na, location=location.absolute, style=shape.labelup, text="EMA 50", color=color.new(color50, 80), textcolor=color.white)
plotshape(bar_index == ta.highest(bar_index, 1) ? ema100 : na, location=location.absolute, style=shape.labelup, text="EMA 100", color=color.new(color100, 80), textcolor=color.white)
plotshape(bar_index == ta.highest(bar_index, 1) ? ema200 : na, location=location.absolute, style=shape.labelup, text="EMA 200", color=color.new(color200, 80), textcolor=color.white)

//==============================================================================
// SECTION 3: FAIR VALUE GAP (FVG) DETECTION - SESSION BASED
//==============================================================================

// Define session times
sess = input.session("0932-1600", title="Session", tooltip="A 9:30 FVG can start at 9:30 but takes 3 candles to form, thus the 9:32 start time for the session. Adjust accordingly.", group="FVG Settings")
// User input for box color
boxColorUp = input.color(color.new(color.green, 80), "Box Color Up", group="FVG Settings")
boxColorDn = input.color(color.new(color.red, 80), "Box Color Down", group="FVG Settings")
max_days = input.int(3, title="Max # of days to draw", group="FVG Settings")
drawOpenTime = input.bool(true, title="Draw 9:30 NY open vertical line", group="FVG Settings")
drawOpenPrice = input.bool(true, title="Draw 9:30 opening price", group="FVG Settings")

//lines, boxes and labels
var timezone = "America/New_York"
var boxes = array.new<box>()
var ny_open_labels = array.new<box>()
var labels = array.new<label>()
var ny_open_prices = array.new<line>()
var ny_open_times = array.new<line>()
var ny_930_labels = array.new<label>()

var box ny_open_label = na
var box fvg_box = na
var line ny_open_time = na
var line ny_open_price = na
var label ny_930_label = na
var label fvg_lb = na
var bool first_fvg_found = false

boxColor = color.new(color.gray, 80)
is_target_time = (hour(time, timezone) == 8 and minute == 30) // CME servers in Chicago (CST). 9:30 EST = 8:30 CST
lowest_so_far = ta.lowest(50) - 5*ta.atr(14)

// Calculations
// Get day of week in text
day_of_week_text() =>
     dayofweek == dayofweek.monday    ? "Mon" :
     dayofweek == dayofweek.tuesday   ? "Tue" :
     dayofweek == dayofweek.wednesday ? "Wed" :
     dayofweek == dayofweek.thursday  ? "Thu" :
     dayofweek == dayofweek.friday    ? "Fri" :
     dayofweek == dayofweek.saturday  ? "Sat" :
     dayofweek == dayofweek.sunday    ? "Sun" : "N/A"

// Box creation
make_box(_left, _right, _top, _bottom, col) =>
    box.new(left=_left, right=_right, top=_top, bottom=_bottom, border_color=color.new(col, 70), bgcolor=col, text="1st FVG - " + day_of_week_text(), text_halign = text.align_right, text_size=size.small, text_color = color.black)

// Manage array of lines and labels
manage_lines(li_time, li_price, lb_price, lb_930) =>
    array.push(ny_open_times, li_time)
    array.push(ny_open_prices, li_price)
    array.push(ny_open_labels, lb_price)
    array.push(ny_930_labels, lb_930)
    if array.size(ny_open_times) > max_days
        line.delete(array.shift(ny_open_prices))
        line.delete(array.shift(ny_open_times))
        box.delete(array.shift(ny_open_labels))
        label.delete(array.shift(ny_930_labels))

// Manage array of boxes
manage_boxes(b) =>
    array.push(boxes, b)
    if array.size(boxes) > max_days
        box.delete(array.shift(boxes))

// Update FVG box
update_box(b) =>
    box.set_right(b, bar_index+10)

//@function calculates session valid times
in_session(sess) => not na(time(timeframe.period, sess, timezone))

// Core Logic
if in_session(sess) 
    if not first_fvg_found
        // FVG condition
        fvgUp   = close[1] > open[1] and high[2] < low[0]
        fvgDown = close[1] < open[1] and low[2] > high[0]
        if fvgUp or fvgDown
            first_fvg_found := true
            boxColor := fvgUp ? boxColorUp : boxColorDn
            // Define box coordinates
            boxTop      = fvgUp ? high[2] : low[2]
            boxBottom   = fvgUp ? low[0] : high[0]

            // Create the box
            fvg_box := make_box(bar_index-2, bar_index + 5, boxTop, boxBottom, boxColor)
            manage_boxes(fvg_box)

// Reset FVG flag at the end of the session
if not in_session(sess) and in_session(sess)[1]
    first_fvg_found := false

// Extend the box to session end
if first_fvg_found and na(fvg_box) == false
    update_box(fvg_box)

//Draw NY Open at 9:30 am EST / NY Time
if is_target_time
    if drawOpenTime
        ny_open_time    := line.new(x1=time, y1=high, x2=time, y2=low, xloc=xloc.bar_time, color=color.gray, style=line.style_dashed, width=1, extend = extend.both)
        ny_930_label    := label.new(x=bar_index, y=lowest_so_far, text="9:30", style=label.style_none, color=color.new(color.gray, 90), textcolor=color.black)
        manage_lines(ny_open_time, ny_open_price, ny_open_label, ny_930_label)
    if drawOpenPrice
        ny_open_price   := line.new(x1=bar_index, y1=open, x2=bar_index + 10, y2=open, xloc=xloc.bar_index, color=color.gray, style=line.style_dotted, width=1, extend = extend.none)
        ny_open_label   := box.new(left=bar_index+25, top=open+10, 
         right=bar_index + 55, 
         bottom=open-10, 
         text = day_of_week_text() + " NY Open - " + str.format("{0,number,#,###.00}", close), 
         bgcolor=color.new(color.white, 100), 
         text_halign = text.align_right, 
         text_size = size.small, 
         text_color = color.black, 
         border_color = color.new(color.white, 50))
    
// Keep extended objects until end of the session
if in_session(sess)
    box.set_right(ny_open_label, bar_index + 55)
    line.set_x2(ny_open_price, bar_index + 20)

//==============================================================================
// SECTION 4: MULTI-TIMEFRAME CRT (ENHANCED WITH SMART REVERSAL FILTERING)
//==============================================================================

// Explicitly set max_bars_back for key variables
max_bars_back(time, 5000)
max_bars_back(high, 5000)
max_bars_back(low, 5000)
max_bars_back(close, 5000)
max_bars_back(open, 5000)

// Inputs
var g_TF = 'CRT Timeframes'
use_tf1 = input.bool(true, '15 Minutes', inline = 'TF1', group = g_TF)
tf1 = input.timeframe('15', '', inline = 'TF1', group = g_TF)
tf1_color = input.color(color.new(#FF1493, 70), '', inline = 'TF1', group = g_TF)
use_tf1_mid = input.bool(true, '50% Level', inline = 'TF1M', group = g_TF)
tf1_mid_color = input.color(color.new(#FF1493, 50), '', inline = 'TF1M', group = g_TF)

use_tf2 = input.bool(true, '1 Hour', inline = 'TF2', group = g_TF)
tf2 = input.timeframe('60', '', inline = 'TF2', group = g_TF)
tf2_color = input.color(color.new(#FF4500, 70), '', inline = 'TF2', group = g_TF)
use_tf2_mid = input.bool(true, '50% Level', inline = 'TF2M', group = g_TF)
tf2_mid_color = input.color(color.new(#FF4500, 50), '', inline = 'TF2M', group = g_TF)

use_tf3 = input.bool(true, '2 Hours', inline = 'TF3', group = g_TF)
tf3 = input.timeframe('120', '', inline = 'TF3', group = g_TF)
tf3_color = input.color(color.new(#32CD32, 70), '', inline = 'TF3', group = g_TF)
use_tf3_mid = input.bool(true, '50% Level', inline = 'TF3M', group = g_TF)
tf3_mid_color = input.color(color.new(#32CD32, 50), '', inline = 'TF3M', group = g_TF)

use_tf4 = input.bool(true, '4 Hours', inline = 'TF4', group = g_TF)
tf4 = input.timeframe('240', '', inline = 'TF4', group = g_TF)
tf4_color = input.color(color.new(#1E90FF, 70), '', inline = 'TF4', group = g_TF)
use_tf4_mid = input.bool(true, '50% Level', inline = 'TF4M', group = g_TF)
tf4_mid_color = input.color(color.new(#1E90FF, 50), '', inline = 'TF4M', group = g_TF)

use_tf5 = input.bool(true, 'Daily', inline = 'TF5', group = g_TF)
tf5 = input.timeframe('D', '', inline = 'TF5', group = g_TF)
tf5_color = input.color(color.new(#9932CC, 70), '', inline = 'TF5', group = g_TF)
use_tf5_mid = input.bool(true, '50% Level', inline = 'TF5M', group = g_TF)
tf5_mid_color = input.color(color.new(#9932CC, 50), '', inline = 'TF5M', group = g_TF)

use_tf6 = input.bool(true, 'Weekly', inline = 'TF6', group = g_TF)
tf6 = input.timeframe('W', '', inline = 'TF6', group = g_TF)
