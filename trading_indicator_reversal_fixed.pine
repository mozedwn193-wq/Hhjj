//==============================================================================
// ENHANCED TREND STATUS DISPLAY WITH REVERSAL DETECTION (FIXED)
//==============================================================================

// Show current trend status on chart with smart reversal detection
var label trend_label = na
if barstate.islast
    if not na(trend_label)
        label.delete(trend_label)
    
    trend_text = ""
    trend_color = color.gray
    
    if true_bullish_reversal
        trend_text := "🔄 TRUE BULLISH REVERSAL DETECTED!"
        trend_color := color.new(color.lime, 0)
    else if true_bearish_reversal
        trend_text := "🔄 TRUE BEARISH REVERSAL DETECTED!"
        trend_color := color.new(color.red, 0)
    else if bullish_continuation
        trend_text := "➡️ BULLISH CONTINUATION"
        trend_color := color.new(color.green, 20)
    else if bearish_continuation
        trend_text := "➡️ BEARISH CONTINUATION"
        trend_color := color.new(color.red, 20)
    else if new_bullish_trend
        trend_text := "🚀 NEW BULLISH TREND DETECTED!"
        trend_color := color.new(color.lime, 0)
    else if new_bearish_trend
        trend_text := "🚀 NEW BEARISH TREND DETECTED!"
        trend_color := color.new(color.red, 0)
    else if strong_bullish_trend
        trend_text := "💪 STRONG BULLISH TREND"
        trend_color := color.new(color.lime, 20)
    else if strong_bearish_trend
        trend_text := "💪 STRONG BEARISH TREND"
        trend_color := color.new(color.red, 20)
    else if bullish_trend
        trend_text := "📈 BULLISH TREND"
        trend_color := color.new(color.green, 30)
    else if bearish_trend
        trend_text := "📉 BEARISH TREND"
        trend_color := color.new(color.red, 30)
    else
        trend_text := "⚠️ SIDEWAYS TREND"
        trend_color := color.new(color.yellow, 30)
    
    trend_label := label.new(bar_index, high + ta.atr(14), text=trend_text, style=label.style_label_down, color=trend_color, textcolor=color.white, size=size.normal)

//==============================================================================
// SMART REVERSAL DASHBOARD (NEW)
//==============================================================================

var g_REV_DASHBOARD = "🔄 Smart Reversal Dashboard"
show_reversal_dashboard = input.bool(true, "Show Reversal Dashboard", group=g_REV_DASHBOARD)

if show_reversal_dashboard and barstate.islast
    var table reversal_table = table.new(position.bottom_right, 4, 6, bgcolor=color.new(color.black, 85), border_width=1)
    
    // Header
    table.cell(reversal_table, 0, 0, "🔄 REVERSAL ANALYSIS", text_color=color.white, text_size=size.normal, bgcolor=color.new(color.purple, 70))
    table.cell(reversal_table, 1, 0, "DAILY", text_color=color.white, text_size=size.small, bgcolor=color.new(color.purple, 70))
    table.cell(reversal_table, 2, 0, "WEEKLY", text_color=color.white, text_size=size.small, bgcolor=color.new(color.purple, 70))
    table.cell(reversal_table, 3, 0, "4H", text_color=color.white, text_size=size.small, bgcolor=color.new(color.purple, 70))
    
    // Trend Status
    table.cell(reversal_table, 0, 1, "Current Trend", text_color=color.white, text_size=size.small)
    daily_trend_text = htf_daily_bullish ? "🟢 BULL" : htf_daily_bearish ? "🔴 BEAR" : "⚪ SIDE"
    weekly_trend_text = htf_weekly_bullish ? "🟢 BULL" : htf_weekly_bearish ? "🔴 BEAR" : "⚪ SIDE"
    h4_trend_text = htf_4h_bullish ? "🟢 BULL" : htf_4h_bearish ? "🔴 BEAR" : "⚪ SIDE"
    table.cell(reversal_table, 1, 1, daily_trend_text, text_color=color.white, text_size=size.small)
    table.cell(reversal_table, 2, 1, weekly_trend_text, text_color=color.white, text_size=size.small)
    table.cell(reversal_table, 3, 1, h4_trend_text, text_color=color.white, text_size=size.small)
    
    // Trend Duration
    table.cell(reversal_table, 0, 2, "Duration (bars)", text_color=color.white, text_size=size.small)
    table.cell(reversal_table, 1, 2, str.tostring(math.max(daily_bull_count, daily_bear_count)), text_color=color.white, text_size=size.small)
    table.cell(reversal_table, 2, 2, str.tostring(math.max(weekly_bull_count, weekly_bear_count)), text_color=color.white, text_size=size.small)
    table.cell(reversal_table, 3, 2, str.tostring(math.max(h4_bull_count, h4_bear_count)), text_color=color.white, text_size=size.small)
    
    // Maturity Status
    table.cell(reversal_table, 0, 3, "Mature Trend", text_color=color.white, text_size=size.small)
    daily_mature_text = (daily_mature_bull or daily_mature_bear) ? "⚠️ YES" : "✅ NO"
    weekly_mature_text = (weekly_mature_bull or weekly_mature_bear) ? "⚠️ YES" : "✅ NO"
    h4_mature_text = (h4_mature_bull or h4_mature_bear) ? "⚠️ YES" : "✅ NO"
    table.cell(reversal_table, 1, 3, daily_mature_text, text_color=color.white, text_size=size.small)
    table.cell(reversal_table, 2, 3, weekly_mature_text, text_color=color.white, text_size=size.small)
    table.cell(reversal_table, 3, 3, h4_mature_text, text_color=color.white, text_size=size.small)
    
    // Reversal Signals
    table.cell(reversal_table, 0, 4, "Reversal Signal", text_color=color.white, text_size=size.small)
    daily_rev_text = (daily_reversal_to_bull or daily_reversal_to_bear) ? "🔄 YES" : "❌ NO"
    weekly_rev_text = (weekly_reversal_to_bull or weekly_reversal_to_bear) ? "🔄 YES" : "❌ NO"
    h4_rev_text = (h4_reversal_to_bull or h4_reversal_to_bear) ? "🔄 YES" : "❌ NO"
    table.cell(reversal_table, 1, 4, daily_rev_text, text_color=color.white, text_size=size.small)
    table.cell(reversal_table, 2, 4, weekly_rev_text, text_color=color.white, text_size=size.small)
    table.cell(reversal_table, 3, 4, h4_rev_text, text_color=color.white, text_size=size.small)
    
    // Overall Status
    table.cell(reversal_table, 0, 5, "Status", text_color=color.white, text_size=size.small)
    overall_status = ""
    if true_bullish_reversal or true_bearish_reversal
        overall_status := "🔄 REVERSAL"
    else if bullish_continuation or bearish_continuation
        overall_status := "➡️ CONTINUATION"
    else
        overall_status := "⚖️ NEUTRAL"
    table.cell(reversal_table, 1, 5, overall_status, text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 70))
    table.cell(reversal_table, 2, 5, "", text_color=color.white, text_size=size.small)
    table.cell(reversal_table, 3, 5, "", text_color=color.white, text_size=size.small)

